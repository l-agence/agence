# ShellSpec project marker
# Use absolute path - Windows PATH pollution in WSL requires explicit shell path
--shell /bin/bash
# Run examples from project root so validate_execution_context passes
--execdir @project
# GIT_ROOT / AI_ROOT are resolved dynamically from the script's own location
# by lib/env.sh — do NOT hardcode them here (breaks on any machine but the
# original author's WSL path).
