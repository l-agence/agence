################################################################################
# ishell: Interactive hybrid PowerShell for agent + human collaboration
#
# hybrid interactive shell combining human control (planning, debugging) with
# agentic capabilities. Enforces CODEX validation, captures session logs, and
# maintains chroot-like $GIT_ROOT isolation.
#
# Usage: pwsh -NoProfile -NoExit -File ishell
# Environment variables (set by VS Code or caller):
#   AI_ROLE       - Terminal role: "interactive" (default), or "planner", "human"
#   AI_SESSION    - Session ID (e.g., "abc123-2026-03-06")
#   AI_AGENT      - Agent ID (e.g., "user", "haiku", "gpt4", etc.)
#   GIT_ROOT      - Repository root (set by wrapper, enforced chroot)
#
# Features:
#   - Hybrid human + agent mode (both can interact in same session)
#   - Session logging via transcript → nexus/.aisessions/
#   - CODEX validation on every command
#   - Path sandbox enforcement (no escape from GIT_ROOT)
#   - Format control (text/md/json)
#   - Color-coded prompt showing role/session/agent
#   - Sticky session (visible to both human and agent)
################################################################################

# ============================================================================
# ENVIRONMENT SETUP
# ============================================================================

# Get GIT_ROOT from environment or compute from script location
if ([string]::IsNullOrEmpty($env:GIT_ROOT)) {
    $scriptDir = Split-Path -Parent $PSCommandPath
    $env:GIT_ROOT = Split-Path -Parent $scriptDir
}

# Session metadata (provided by VS Code extension or caller)
$AIRole = $env:AI_ROLE ?? "interactive"
$AISession = $env:AI_SESSION ?? "unknown"
$AIAgent = $env:AI_AGENT ?? "user"
$GITRoot = $env:GIT_ROOT

# Session logging paths
$sessionDir = Join-Path $GITRoot "nexus" ".aisessions"
$sessionLog = Join-Path $sessionDir "$($AISession)_$($AIRole).typescript"
$sessionMeta = Join-Path $sessionDir "$($AISession)_$($AIRole).meta.json"

# Ensure session directory exists
if (-not (Test-Path $sessionDir)) {
    New-Item -ItemType Directory -Path $sessionDir -Force | Out-Null
}

# ============================================================================
# SESSION LOGGING INITIALIZATION
# ============================================================================

function Initialize-SessionLogging {
    if (-not (Test-Path $sessionMeta)) {
        $metadata = @{
            session_id        = $AISession
            role              = $AIRole
            agent             = $AIAgent
            shell             = "powershell"
            mode              = "hybrid"
            timestamp_start   = (Get-Date -Format "yyyy-MM-ddTHH:mm:ssZ")
            git_root          = $GITRoot
            typescript_file   = $sessionLog
            commands_executed = 0
            exit_code         = $null
        }
        
        $metadata | ConvertTo-Json | Set-Content -Path $sessionMeta -Force
    }
    
    # Start PowerShell transcript logging
    Start-Transcript -Path $sessionLog -Append -NoClobber -IncludeInvocationHeader | Out-Null
}

# ============================================================================
# CODEX + FORMAT LIBRARY + POLICY LOADING
# ============================================================================

function Load-CodexAndFormat {
    # Load CODEX validation (if exists)
    $codexPath = Join-Path $GITRoot "codex" "LAWS.ps1"
    if (Test-Path $codexPath) {
        . $codexPath
    }
    
    # Load format library for output control
    $formatPath = Join-Path $GITRoot "lib" "format.ps1"
    if (Test-Path $formatPath) {
        . $formatPath
        $env:_AGENCE_FMT = if ($env:_AGENCE_FMT) { $env:_AGENCE_FMT } else { "text" }
    }
    
    # Load agentic policy (if exists)
    $policyPath = Join-Path $GITRoot "bin" "aipolicy"
    if (Test-Path $policyPath) {
        . $policyPath
    }
}

# ============================================================================
# SANDBOX PATH ENFORCEMENT (chroot-like)
# ============================================================================

function Test-PathInSandbox {
    param([string]$Path)
    
    # Resolve to absolute path
    try {
        $absPath = (Resolve-Path -Path $Path -ErrorAction Stop).Path
    }
    catch {
        Write-Host "[SANDBOX] ✗ Invalid directory: $Path" -ForegroundColor Red
        return $false
    }
    
    # Check if within GIT_ROOT
    if ($absPath.StartsWith($GITRoot)) {
        return $true
    }
    else {
        Write-Host "[SANDBOX] ✗ Access outside workspace denied: $Path" -ForegroundColor Red
        Write-Host "[SANDBOX]   Current root: $GITRoot" -ForegroundColor Red
        Write-Host "[SANDBOX]   Attempted:   $absPath" -ForegroundColor Red
        return $false
    }
}

# Override Set-Location for sandbox enforcement
function Set-LocationSafe {
    param([string]$Path)
    
    if (Test-PathInSandbox -Path $Path) {
        Set-Location -Path $Path
    }
    else {
        Write-Host "[SANDBOX] ✗ Path access denied by sandbox" -ForegroundColor Red
        return 1
    }
}

# Alias for convenience (allows 'cd' to work safely)
Set-Alias -Name cd -Value Set-LocationSafe -Force

# ============================================================================
# SESSION HEADER
# ============================================================================

function Show-SessionHeader {
    $headerColor = "Cyan"
    Write-Host ""
    Write-Host "╔════════════════════════════════════════════════════════════════╗" -ForegroundColor $headerColor
    Write-Host "║  AGENCE HYBRID INTERACTIVE SHELL (ishell@human)               ║" -ForegroundColor $headerColor
    Write-Host "╠════════════════════════════════════════════════════════════════╣" -ForegroundColor $headerColor
    Write-Host "║  Mode:       Hybrid (agent + human collaborative)             ║" -ForegroundColor $headerColor
    Write-Host "║  Role:       $AIRole" -ForegroundColor $headerColor
    Write-Host "║  Session:    $AISession" -ForegroundColor $headerColor
    Write-Host "║  Agent:      $AIAgent" -ForegroundColor $headerColor
    Write-Host "║  Shell:      PowerShell $($PSVersionTable.PSVersion.Major)" -ForegroundColor $headerColor
    Write-Host "║  Root:       $GITRoot" -ForegroundColor $headerColor
    Write-Host "║  Log:        $sessionLog" -ForegroundColor $headerColor
    Write-Host "╚════════════════════════════════════════════════════════════════╝" -ForegroundColor $headerColor
    Write-Host ""
}

# ============================================================================
# PROMPT CUSTOMIZATION (Color-coded for hybrid mode)
# ============================================================================

function prompt {
    $sessionShort = $AISession.Substring(0, [Math]::Min(8, $AISession.Length))
    $promptColor = "Green"  # Human interactive color
    Write-Host "[$AIRole@$sessionShort] " -ForegroundColor $promptColor -NoNewline
    Write-Host "$($executionContext.SessionState.Path.CurrentLocation)> " -ForegroundColor Gray -NoNewline
    return " "
}

# ============================================================================
# MAIN INITIALIZATION
# ============================================================================

function Main {
    try {
        # Initialize session logging
        Initialize-SessionLogging
        
        # Load CODEX + format library + policy
        Load-CodexAndFormat
        
        # Show session header
        Show-SessionHeader
        
        # Change to repo root (chroot-like)
        Set-Location -Path $GITRoot | Out-Null
        
        Write-Host "Hybrid interactive shell ready." -ForegroundColor Gray
        Write-Host "Both human and agent can interact in this session." -ForegroundColor Gray
        Write-Host "Commands are logged to: $sessionLog" -ForegroundColor Gray
        Write-Host ""
    }
    catch {
        Write-Host "[ISHELL] ✗ Initialization failed: $_" -ForegroundColor Red
        Write-Host $_.ScriptStackTrace -ForegroundColor Red
        exit 1
    }
}

# Execute main initialization
Main

# Keep shell interactive (exits when user types 'exit' or closes terminal)
