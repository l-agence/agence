#!/usr/bin/env bash

################################################################################
# Agence: Agentic Engineering Collaboration Environment
# Entry point for all command routing
#
# Author: Stephane Korning 2026
# License: MIT License with Commons Clause
# 
# Modes:
#   agence help                    → Show help
#   agence <query>                 → Chat mode (query to LLM)
#   agence +<routing_request>      → AI-routed mode (LLM determines action)
#   agence /<command>              → External command (validated)
#   agence !<system_cmd>           → System command
################################################################################

set -u  # Exit on undefined variable

# ============================================================================
# SHELL ENVIRONMENT DETECTION
# ============================================================================
# Detect which shell environment we're running in (git-bash, cygwin, WSL, etc)
# Set environment variables so everything works universally
# This must happen FIRST before any path operations

detect_shell_environment() {
  # Default values
  export AGENCE_SHELL_ENV="unknown"
  export AGENCE_PATH_STYLE="posix"  # Default: posix paths
  export AGENCE_OS_WINDOWS=0
  export AGENCE_OS_LINUX=0
  export AGENCE_OS_MACOS=0
  
  # Detect OS layer
  case "${OSTYPE:-}" in
    msys|mingw*)
      # Git-bash (MinGW/MSYS2)
      export AGENCE_SHELL_ENV="git-bash"
      export AGENCE_OS_WINDOWS=1
      export AGENCE_PATH_STYLE="mingw"
      ;;
    cygwin*)
      # Cygwin
      export AGENCE_SHELL_ENV="cygwin"
      export AGENCE_OS_WINDOWS=1
      export AGENCE_PATH_STYLE="cygwin"
      ;;
    linux*)
      # Check if WSL
      if [[ -f /proc/version ]] && grep -qi microsoft /proc/version 2>/dev/null; then
        export AGENCE_SHELL_ENV="wsl"
        export AGENCE_PATH_STYLE="posix"
      else
        export AGENCE_SHELL_ENV="linux"
        export AGENCE_PATH_STYLE="posix"
      fi
      export AGENCE_OS_LINUX=1
      ;;
    darwin*)
      export AGENCE_SHELL_ENV="macos"
      export AGENCE_OS_MACOS=1
      export AGENCE_PATH_STYLE="posix"
      ;;
  esac
  
  # Additional detection for git-bash (MSYSTEM variable)
  if [[ -n "${MSYSTEM:-}" ]]; then
    export AGENCE_SHELL_ENV="git-bash"
    export AGENCE_OS_WINDOWS=1
    export AGENCE_PATH_STYLE="mingw"
  fi
  
  # Additional detection for PowerShell
  if [[ -n "${PSVersionTable+x}" ]] || [[ "$SHELL" == *"powershell"* ]]; then
    export AGENCE_SHELL_ENV="powershell"
    export AGENCE_PATH_STYLE="windows"
  fi
  
  [[ "${AGENCE_DEBUG:-0}" == "1" ]] && \
    echo "[DEBUG] Shell: $AGENCE_SHELL_ENV, Path style: $AGENCE_PATH_STYLE, OS: W=$AGENCE_OS_WINDOWS L=$AGENCE_OS_LINUX" >&2
}

detect_shell_environment

# ============================================================================
# CONFIGURATION & PATHS
# ============================================================================

# Normalize paths to current shell environment
# Handles conversion between path styles based on detected environment
normalize_path() {
  local path="$1"
  
  # If cygwin, convert /cygdrive/c/ to /c/ (mingw style)
  if [[ "$AGENCE_PATH_STYLE" == "mingw" ]] && [[ "$path" == /cygdrive/* ]]; then
    path="${path/\/cygdrive\//\/}"
  fi
  
  # If Windows (for PowerShell), convert to Windows style (C:\...)
  if [[ "$AGENCE_PATH_STYLE" == "windows" ]]; then
    # Convert unix paths to Windows paths
    if [[ "$path" == /* ]]; then
      # /c/users/... → C:\Users\...
      local drive="${path:1:1}"
      local rest="${path:2}"
      path="${drive}:${rest//\//\\}"
    fi
  fi
  
  echo "$path"
}

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPT_DIR="$(normalize_path "$SCRIPT_DIR")"

AGENCE_ROOT="$(dirname "$SCRIPT_DIR")"
AGENCE_ROOT="$(normalize_path "$AGENCE_ROOT")"

AGENCE_BIN="$SCRIPT_DIR"
AGENCE_LIB="$AGENCE_ROOT/lib"
AGENCE_MODULES="$AGENCE_ROOT/modules"
AGENCE_CONFIG="${HOME}/.agence/config.yaml"

# Source utility functions (to be created)
source_if_exists() {
  [[ -f "$1" ]] && source "$1"
}

source_if_exists "$AGENCE_LIB/utils.sh"
source_if_exists "$AGENCE_LIB/logging.sh"
source_if_exists "$AGENCE_LIB/safeguards.sh"
source_if_exists "$AGENCE_LIB/router.sh"
source_if_exists "$AGENCE_LIB/format.sh"

# ============================================================================
# EXECUTION CONTEXT: Git Repo vs Agence Repo
# ============================================================================
# Critical: Prevent collisions when user and LLM share a shell window
# Both must be set and validated before any command execution

init_execution_context() {
  # Initialize GIT_REPO and AGENCE_REPO environment variables
  # These track which repos we're working in and prevent context collisions
  
  export AGENCE_REPO="${AGENCE_REPO:-$(normalize_path "$AGENCE_ROOT")}"
  export GIT_REPO="${GIT_REPO:-}"
  
  # Try to detect GIT_REPO by walking up directory tree from current pwd
  if [[ -z "$GIT_REPO" ]]; then
    local current_dir="$(normalize_path "$(pwd)")"
    local check_dir="$current_dir"
    
    while [[ "$check_dir" != "/" ]]; do
      if [[ -d "$check_dir/.git" ]]; then
        export GIT_REPO="$check_dir"
        break
      fi
      check_dir="$(dirname "$check_dir")"
    done
  else
    # Normalize GIT_REPO if it was manually set
    export GIT_REPO="$(normalize_path "$GIT_REPO")"
  fi
  
  # Special case: If both are same, we're in standalone mode (not yet a submodule)
  if [[ "$GIT_REPO" == "$AGENCE_REPO" ]]; then
    if [[ "$DEBUG" == "1" ]]; then
      echo "[DEBUG] Standalone mode (GIT_REPO == AGENCE_REPO)" >&2
    fi
  fi
  
  if [[ "$DEBUG" == "1" ]]; then
    echo "[DEBUG] AGENCE_REPO=$AGENCE_REPO" >&2
    echo "[DEBUG] GIT_REPO=$GIT_REPO" >&2
  fi
}

validate_execution_context() {
  # Pre-flight check: Ensure pwd matches expected repo context (CODEX LAW 2)
  # Handles both normal case (submodule in parent repo) and standalone case (same repo)
  
  local current_pwd="$(normalize_path "$(pwd)")"
  local in_agence=0
  local in_git=0
  
  # Check if we're in AGENCE_REPO
  if [[ "$current_pwd" == "$AGENCE_REPO"* ]]; then
    in_agence=1
  fi
  
  # Check if we're in GIT_REPO (if set and different from AGENCE_REPO)
  if [[ -n "$GIT_REPO" ]] && [[ "$GIT_REPO" != "$AGENCE_REPO" ]] && [[ "$current_pwd" == "$GIT_REPO"* ]]; then
    in_git=1
  fi
  
  # Special case: if they're the same, being in one is sufficient
  if [[ "$GIT_REPO" == "$AGENCE_REPO" ]] && [[ $in_agence -eq 1 ]]; then
    in_git=1
  fi
  
  # Validation: Must be in either GIT_REPO or AGENCE_REPO
  if [[ $in_agence -eq 0 && $in_git -eq 0 ]]; then
    echo "[ERROR] Execution context mismatch (CODEX LAW 2 violation)!" >&2
    echo "  pwd: $current_pwd" >&2
    echo "  AGENCE_REPO: $AGENCE_REPO" >&2
    if [[ -n "$GIT_REPO" ]] && [[ "$GIT_REPO" != "$AGENCE_REPO" ]]; then
      echo "  GIT_REPO: $GIT_REPO" >&2
    fi
    echo "" >&2
    echo "  You must be in one of:" >&2
    echo "    - $AGENCE_REPO/* (Agence system)" >&2
    if [[ -n "$GIT_REPO" ]] && [[ "$GIT_REPO" != "$AGENCE_REPO" ]]; then
      echo "    - $GIT_REPO/* (Parent project)" >&2
    fi
    echo "" >&2
    echo "  Recovery: cd to $AGENCE_REPO or your project root" >&2
    return 1
  fi
  
  return 0
}

# ============================================================================
# DEFAULTS
# ============================================================================

DEBUG="${AGENCE_DEBUG:-0}"
QUIET="${AGENCE_QUIET:-0}"

# Initialize and validate execution context before anything else
init_execution_context
if ! validate_execution_context; then
  exit 1
fi

# ============================================================================
# HELP / VERSION
# ============================================================================

show_help() {
  cat << 'EOF'
Agence: Agentic Engineering Collaboration Environment

USAGE:
  agence [COMMAND] [OPTIONS]

EXECUTION CONTEXT:
  Agence enforces strict execution context to prevent collisions when user 
  and LLM share a shell window. The following must be true:
  
  - GIT_REPO (parent repo, auto-detected or set manually)
  - AGENCE_REPO (always ~/.agence submodule)
  - pwd must be within one of these repos
  
  If context mismatch detected: Agence aborts with error.
  Set manually if needed: export GIT_REPO=/path/to/repo

MODES:
  help                         Show this help message
  version                      Show Agence version

COMMAND MODES:
  agence "<query>"             Chat with the LLM about your task
  agence +<request>            Ask LLM to route/plan action (autonomous mode)
  agence /<cmd>                Execute validated external command
  agence !<sys_cmd>            System command (bash/powershell utilities)
  agence ^<init_cmd>           Special initialization commands

EXAMPLES:
  agence "How do I deploy this to AWS?"
  agence +plan-vpc-infrastructure
  agence /terraform-plan
  agence !help
  agence ^init
  agence ^install
  agence ^learn
  agence ^status
  agence ^stash
  agence ^fetch
  agence ^rebase
  agence ^push
  agence ^sync

ENVIRONMENT VARIABLES:
  GIT_REPO=/path/to/repo       Parent repository (auto-detected if not set)
  AGENCE_REPO                  Agence submodule root (auto-set to ~/.agence)
  AGENCE_DEBUG=1               Enable debug output (shows GIT_REPO, AGENCE_REPO)
  AGENCE_QUIET=1               Suppress non-essential output
  AGENCE_LLM_PROVIDER=claude   LLM provider (anthropic, openai, ollama)
  ANTHROPIC_API_KEY            API key for Claude

CONFIG:
  ~/.agence/config.yaml        Global Agence configuration
  .agence/config.yaml          Project-specific configuration (if in repo)

SEE ALSO:
  agence config                Show current configuration
  agence status                Show Agence status
  agence logs                  Show recent logs

For more info: https://github.com/l-agence/agence
EOF
}

show_version() {
  echo "Agence version 0.1.0 (alpha)"
}

# ============================================================================
# AGENT PREFIX PARSING
# ============================================================================
# Parses @agent prefix from input and sets AGENCE_AGENT_PARAM env var
# Format: @agent !command or @ !command (for Copilot default)
# If no prefix, defaults to "@" (Copilot autoselect)

parse_agent_prefix() {
  local input="$1"
  
  # Check if input starts with @
  if [[ "$input" =~ ^@([A-Za-z0-9_-]*)[[:space:]]+(.*) ]]; then
    # Extract agent name and remaining command
    local agent_name="${BASH_REMATCH[1]}"
    local remaining_cmd="${BASH_REMATCH[2]}"
    
    # If agent name is empty, it's just "@" (Copilot default)
    if [[ -z "$agent_name" ]]; then
      export AGENCE_AGENT_PARAM="@"
    else
      export AGENCE_AGENT_PARAM="$agent_name"
    fi
    
    # Return remaining command
    echo "$remaining_cmd"
  else
    # No @agent prefix found, use default "@"
    export AGENCE_AGENT_PARAM="@"
    # Return original input
    echo "$input"
  fi
}

# ============================================================================
# MAIN ENTRY POINT
# ============================================================================

main() {
  local input="$*"

  # Argument validation
  if [[ -z "$input" ]]; then
    show_help
    exit 0
  fi

  # Parse @agent prefix (sets AGENCE_AGENT_PARAM env var)
  input=$(parse_agent_prefix "$input")

  local first_char="${input:0:1}"

  # Mode detection and routing
  case "$first_char" in
    "")
      # Empty input
      show_help
      exit 0
      ;;
    "+")
      # AI-routed mode: LLM decides what to do
      mode_ai_routed "${input:1}"
      ;;
    "/")
      # External command: validated execution
      mode_external "${input:1}"
      ;;
    "!")
      # System command: shell utilities
      mode_system "${input:1}"
      ;;
    "^")
      # Special initialization commands
      mode_init "${input:1}"
      ;;
    *)
      # Default: chat mode
      mode_chat "$input"
      ;;
  esac

  exit $?
}

# ============================================================================
# MODE: CHAT
# ============================================================================
# Normal conversation with LLM
# Example: agence "How do I create a VPC in Terraform?"

mode_chat() {
  local query="$1"

  [[ "$DEBUG" == "1" ]] && echo "[DEBUG] Chat mode: $query" >&2

  # Load router
  router_load_config

  # Call LLM with context
  local response
  response=$(router_chat "$query") || {
    echo "Error: Failed to contact LLM" >&2
    return 1
  }

  echo "$response"
  return 0
}

# ============================================================================
# MODE: AI-ROUTED
# ============================================================================
# LLM analyzes request and decides action (autonomous)
# Example: agence +plan-terraform-module-for-vpc

mode_ai_routed() {
  local request="$1"

  [[ "$DEBUG" == "1" ]] && echo "[DEBUG] AI-routed mode: $request" >&2

  # Validate request for dangerous operators
  if ! validate_command "$request"; then
    return 1
  fi

  # Load router
  router_load_config

  # Call LLM in planning mode
  local plan
  plan=$(router_plan_action "$request") || {
    echo "Error: Failed to plan action" >&2
    return 1
  }

  # Parse plan (should contain: ACTION, CONFIDENCE, STEPS)
  local action confidence
  action=$(echo "$plan" | grep '^ACTION:' | awk '{print $2}')
  confidence=$(echo "$plan" | grep '^CONFIDENCE:' | awk '{print $2}')

  # Safety check: require human confirmation if confidence low
  if (( $(echo "$confidence < 0.65" | bc -l 2>/dev/null || echo 1) )); then
    echo "[WARN] Low confidence ($confidence). Showing plan:"
    echo "$plan"
    echo ""
    read -p "Proceed? [y/n] " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
      return 1
    fi
  fi

  # Route and execute
  case "$action" in
    git)
      router_execute git "$plan"
      ;;
    terraform)
      router_execute terraform "$plan"
      ;;
    cloud)
      router_execute cloud "$plan"
      ;;
    *)
      echo "Error: Unknown action type: $action" >&2
      return 1
      ;;
  esac

  return $?
}

# ============================================================================
# MODE: EXTERNAL COMMAND
# ============================================================================
# Execute pre-approved external commands
# Example: agence /terraform-plan

mode_external() {
  local cmd_request="$1"

  [[ "$DEBUG" == "1" ]] && echo "[DEBUG] External mode: $cmd_request" >&2

  # Validate command for dangerous operators
  if ! validate_command "$cmd_request"; then
    return 1
  fi

  # =========================================================================
  # REPO COMMANDS (act on $GIT_REPO)
  # =========================================================================
  case "$cmd_request" in
    ghauth)
      # GitHub CLI auth status
      bash "$AGENCE_ROOT/bin/aido" gh auth status
      return $?
      ;;
    ghlogin)
      # GitHub CLI login (interactive)
      echo "[INFO] Starting GitHub CLI login..." >&2
      gh auth login
      return $?
      ;;
    gitstatus)
      # Git status in $GIT_REPO (read-only, safe)
      bash "$AGENCE_ROOT/bin/aido" git status
      return $?
      ;;
    commit)
      # Commit all tracked changes in $GIT_REPO
      echo "[WARN] This will commit all staged changes to $GIT_REPO" >&2
      read -p "Enter commit message: " commit_msg
      if [[ -z "$commit_msg" ]]; then
        echo "Error: Commit message required" >&2
        return 1
      fi
      git -C "$GIT_REPO" commit -m "$commit_msg"
      return $?
      ;;
    push)
      # Push changes to origin (sets upstream on first push)
      echo "[WARN] This will push changes from $GIT_REPO to origin" >&2
      read -p "Confirm push to origin? [y/N] " confirm
      if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
        echo "[CANCELLED] Push aborted" >&2
        return 1
      fi
      git -C "$GIT_REPO" push -u origin
      return $?
      ;;
    ghstatus)
      # GitHub CLI: show repo and PR status
      echo "[INFO] Repository status:" >&2
      bash "$AGENCE_ROOT/bin/aido" gh repo view
      echo && echo "[INFO] Pull requests:" >&2
      bash "$AGENCE_ROOT/bin/aido" gh pr list --limit 5
      return $?
      ;;
    ghcommit)
      # GitHub CLI: Commit changes (similar to /commit but with gh auth)
      echo "[WARN] This will commit all staged changes using gh auth" >&2
      read -p "Enter commit message: " commit_msg
      if [[ -z "$commit_msg" ]]; then
        echo "Error: Commit message required" >&2
        return 1
      fi
      # Verify gh is authenticated
      if ! bash "$AGENCE_ROOT/bin/aido" gh auth status &>/dev/null; then
        echo "Error: Not authenticated with gh. Run: agence /ghlogin" >&2
        return 1
      fi
      git -C "$GIT_REPO" commit -m "$commit_msg"
      return $?
      ;;
    ghpush)
      # GitHub CLI: Push changes (uses gh's authentication)
      echo "[WARN] This will push changes using GitHub CLI auth" >&2
      read -p "Confirm push to origin? [y/N] " confirm
      if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
        echo "[CANCELLED] Push aborted" >&2
        return 1
      fi
      # Verify gh is authenticated
      if ! bash "$AGENCE_ROOT/bin/aido" gh auth status &>/dev/null; then
        echo "Error: Not authenticated with gh. Run: agence /ghlogin" >&2
        return 1
      fi
      git -C "$GIT_REPO" push -u origin
      return $?
      ;;
    gitpost)
      # Git post-hook: handle post-checkout repairs and other git post-op tasks
      # This is called both by .git/hooks/post-checkout and manually
      "$AGENCE_ROOT/bin/gitpost" "${2:-checkout}"
      return $?
      ;;
  esac

  # Load permitted commands from config/commands.json
  local commands_file="$AGENCE_ROOT/bin/commands.json"
  
  if [[ ! -f "$commands_file" ]]; then
    echo "Error: No commands.json found" >&2
    return 1
  fi

  # Check if command is allowed
  local command_allowed
  if command -v jq &>/dev/null; then
    command_allowed=$(jq -r ".\"$cmd_request\" // false" "$commands_file")
  else
    # Fallback if jq not available: simple grep
    command_allowed=$(grep -q "\"$cmd_request\"" "$commands_file" && echo "true" || echo "false")
  fi

  if [[ "$command_allowed" != "true" ]]; then
    echo "Error: Command not allowed: $cmd_request" >&2
    return 1
  fi

  # Log the execution
  echo "[INFO] Executing: $cmd_request" >&2

  # Route to appropriate module
  case "$cmd_request" in
    terraform-*)
      "$AGENCE_MODULES/iac/iac.sh" terraform "${cmd_request#terraform-}"
      ;;
    git-*)
      "$AGENCE_MODULES/git/git.sh" "${cmd_request#git-}"
      ;;
    aws-*)
      "$AGENCE_MODULES/cloud/aws.sh" "${cmd_request#aws-}"
      ;;
    *)
      echo "Error: Unknown command category: $cmd_request" >&2
      return 1
      ;;
  esac

  return $?
}

# ============================================================================
# MODE: SPECIAL INITIALIZATION
# ============================================================================
# Initialize Agence environment and create required symlinks
# Example: agence ^init

mode_init() {
  local full_input="$1"
  local init_cmd="${full_input%% *}"   # first word
  local init_args="${full_input#* }"   # rest after first word
  # If no space found, args = cmd (no args)
  [[ "$init_args" == "$full_input" ]] && init_args=""

  # Parse -j flag from args (sets _AGENCE_FMT=json globally)
  if [[ "$init_args" == *"-j"* ]]; then
    _AGENCE_FMT="json"
    init_args=$(echo "$init_args" | sed 's/ *-j */ /g;s/^ *//;s/ *$//')
  fi
  # Auto-detect format if not set by -j
  agence_detect_format

  [[ "$DEBUG" == "1" ]] && echo "[DEBUG] Init mode: cmd=$init_cmd args=$init_args fmt=$_AGENCE_FMT" >&2

  case "$init_cmd" in
    "init"|"")
      init_agence_environment
      ;;
    "reload")
      reload_agence_context
      ;;
    "install")
      install_agence_packages
      ;;
    "reindex")
      reindex_knowledge_bases
      ;;
    "learn")
      learn_from_sessions
      ;;
    "commit")
      commit_knowledge_changes
      ;;
    "push")
      push_knowledge_upstream
      ;;
    "save")
      save_session_context
      ;;
    "handoff")
      handoff_to_agent $init_args
      ;;
    "pickup")
      pickup_handoff $init_args
      ;;
    "pause")
      pause_session $init_args
      ;;
    "resume")
      resume_session $init_args
      ;;
    *)
      echo "Error: Unknown init command: $init_cmd" >&2
      return 1
      ;;
  esac

  return $?
}

init_agence_environment() {
  [[ "$DEBUG" == "1" ]] && echo "[DEBUG] Initializing Agence environment..." >&2
  
  echo ""
  echo "=============================================="
  echo "  AGENCE INITIALIZATION (^init)"
  echo "=============================================="
  echo ""
  
  # ========================================================================
  # Step 1: Source .agencerc to set up environment
  # ========================================================================
  echo "Step 1/3: Loading Agence profile (.agencerc)..."
  
  local agencerc_path="$AGENCE_REPO/bin/.agencerc"
  if [[ -f "$agencerc_path" ]]; then
    source "$agencerc_path" 2>/dev/null
    if [[ $? -eq 0 ]]; then
      echo "✓ Profile loaded (Shell: $CURRENT_SHELL, REPO_ROOT: $REPO_ROOT)"
    else
      echo "⚠ Profile loaded but with warnings"
    fi
  else
    echo "[WARN] .agencerc not found at $agencerc_path"
  fi
  echo ""
  
  # ========================================================================
  # Step 2: Create directory symlinks (globalcache/@, objectcode/@, synthesis/@)
  # ========================================================================
  echo "Step 2/3: Creating organization symlinks..."
  
  local org_dirs=("globalcache" "objectcode" "synthesis")
  local org_created=0
  
  for dir in "${org_dirs[@]}"; do
    local org_link="$REPO_ROOT/$dir/@"
    local org_target="l-agence.org"
    
    # Only create if doesn't exist
    if [[ ! -e "$org_link" ]]; then
      mkdir -p "$(dirname "$org_link")" 2>/dev/null
      ln -sf "$org_target" "$org_link" 2>/dev/null
      
      if [[ -L "$org_link" || -d "$org_link" ]]; then
        echo "  ✓ $dir/@ → $org_target"
        ((org_created++))
      else
        echo "  ⚠ $dir/@: symlink creation failed (may try mklink on next checkout)"
      fi
    else
      echo "  ⏭ $dir/@: already exists (user customization preserved)"
    fi
  done
  
  if [[ $org_created -gt 0 ]]; then
    echo ""
    echo "✓ Created $org_created organization symlink(s)"
  fi
  echo ""
  
  # ========================================================================
  # Step 3: Create skeleton symlinks (.github/*, CLAUDE.md, etc)
  # ========================================================================
  echo "Step 3/3: Creating skeleton symlinks..."
  
  local AGENCE_GITHUB="$AGENCE_REPO/.github"
  local TARGET_GITHUB="$REPO_ROOT/.github"
  
  # Ensure .github directory exists
  mkdir -p "$TARGET_GITHUB" 2>/dev/null
  
  # Symlink 3a: copilot-instructions.md
  local source_copilot="$AGENCE_GITHUB/copilot.md"
  local target_copilot="$TARGET_GITHUB/copilot-instructions.md"
  
  if [[ ! -e "$target_copilot" ]]; then
    if [[ -f "$source_copilot" ]]; then
      ln -sf "../.agence/.github/copilot.md" "$target_copilot" 2>/dev/null || \
      ln -sf "$source_copilot" "$target_copilot" 2>/dev/null
      if [[ -L "$target_copilot" ]]; then
        echo "  ✓ .github/copilot-instructions.md → copilot.md"
      else
        echo "  ⚠ .github/copilot-instructions.md: creation deferred (post-checkout hook will create)"
      fi
    fi
  else
    echo "  ⏭ .github/copilot-instructions.md: already exists"
  fi
  
  # Symlink 3b: CLAUDE.md (in repo root)
  local source_claude="$AGENCE_GITHUB/CLAUDE.md"
  local target_claude="$REPO_ROOT/CLAUDE.md"
  
  if [[ ! -e "$target_claude" ]]; then
    if [[ -f "$source_claude" ]]; then
      ln -sf ".github/CLAUDE.md" "$target_claude" 2>/dev/null
      if [[ -L "$target_claude" ]]; then
        echo "  ✓ CLAUDE.md → .github/CLAUDE.md"
      else
        echo "  ⚠ CLAUDE.md: creation deferred (post-checkout hook will create)"
      fi
    fi
  else
    echo "  ⏭ CLAUDE.md: already exists"
  fi
  
  echo ""
  echo "=============================================="
  echo "✓ Agence initialization complete!"
  echo "  Environment: $CURRENT_SHELL"
  echo "  AGENCE_ROOT=$AGENCE_REPO"
  echo "  REPO_ROOT=$REPO_ROOT"
  echo "=============================================="
  echo ""
  
  return 0
}

reload_agence_context() {
  # Load and acknowledge the entire Agence knowledge hierarchy
  # This reloads all context files in proper order and summarizes what was loaded
  
  [[ "$DEBUG" == "1" ]] && echo "[DEBUG] Reloading Agence context..." >&2
  
  local AGENCE_GITHUB="$AGENCE_REPO/.github"
  local context_files=(
    "$AGENCE_GITHUB/CLAUDE.md:Claude Integration"
    "$GIT_REPO/.github/copilot-instructions.md:Copilot Instructions"
    "$AGENCE_ROOT/codex/PRINCIPLES.md:Principles (Maxims)"
    "$AGENCE_ROOT/codex/LAWS.md:Laws (Hard Constraints)"
    "$AGENCE_ROOT/codex/RULES.md:Rules (Best Practices)"
    "$AGENCE_BIN/COMMANDS.md:Commands Reference"
    "$AGENCE_ROOT/nexus/faults/INDEX.md:Faults Index"
    "$AGENCE_ROOT/shared/lessons/INDEX.md:Lessons Learned"
  )
  
  echo "[RELOAD] Agence Context Loading"
  echo "=========================================="
  echo ""
  
  local loaded_count=0
  local failed_files=""
  
  for file_info in "${context_files[@]}"; do
    local file="${file_info%%:*}"
    local label="${file_info##*:}"
    
    if [[ -f "$file" ]]; then
      # Get file size and line count
      local size=$(stat -f%z "$file" 2>/dev/null || stat -c%s "$file" 2>/dev/null || echo "?")
      local lines=$(wc -l < "$file" 2>/dev/null || echo "?")
      
      printf "✓ %-35s | %6s bytes | %4s lines\n" "$label" "$size" "$lines"
      ((loaded_count++))
    else
      printf "✗ %-35s | [NOT FOUND]\n" "$label"
      failed_files="$failed_files\n  - $file"
    fi
  done
  
  echo ""
  echo "=========================================="
  echo ""
  echo "Context Summary:"
  echo "  Total files loaded: $loaded_count / ${#context_files[@]}"
  
  if [[ -n "$failed_files" ]]; then
    echo ""
    echo "⚠ Missing files:$failed_files"
  fi
  
  # Load and count some key metrics
  local principles_count=$(grep -c "^## Maxim" "$AGENCE_ROOT/codex/PRINCIPLES.md" 2>/dev/null || echo 0)
  local laws_count=$(grep -c "^## Law" "$AGENCE_ROOT/codex/LAWS.md" 2>/dev/null || echo 0)
  local rules_count=$(grep -c "^## Rule" "$AGENCE_ROOT/codex/RULES.md" 2>/dev/null || echo 0)
  local lessons_count=$(jq -r '.total_lessons' "$AGENCE_ROOT/shared/lessons/INDEX.json" 2>/dev/null || echo 0)
  
  echo ""
  echo "Active Knowledge:"
  echo "  Principles/Maxims: $principles_count"
  echo "  Laws (Constraints): $laws_count"
  echo "  Rules (Practices): $rules_count"
  echo "  Lessons Learned: $lessons_count"
  
  echo ""
  echo "Status: ✓ Agence context fully loaded and acknowledged"
  echo ""
  
  return 0
}

create_windows_symlink() {
  local source="$1"
  local target="$2"
  
  # Determine if source is a file or directory
  local link_type="file"
  if [[ -d "$source" ]]; then
    link_type="dir"
  fi
  
  [[ "$DEBUG" == "1" ]] && echo "[DEBUG] Creating symlink: $target → $source ($link_type)" >&2
  
  if [[ "$AGENCE_OS_WINDOWS" == "1" ]]; then
    # Windows: Use mklink command (requires admin on some systems)
    # Type 12019 is for file symlinks, type 12000 is for directory symlinks
    if [[ "$link_type" == "dir" ]]; then
      cmd /c mklink /D "$(cygpath -w "$target")" "$(cygpath -w "$source")" 2>/dev/null
    else
      cmd /c mklink /H "$(cygpath -w "$target")" "$(cygpath -w "$source")" 2>/dev/null || \
      cmd /c mklink "$(cygpath -w "$target")" "$(cygpath -w "$source")" 2>/dev/null
    fi
    
    if [[ $? -eq 0 ]]; then
      return 0
    else
      echo "[ERROR] mklink failed. Trying PowerShell method..." >&2
      # Fallback to PowerShell
      powershell -Command "New-Item -ItemType SymbolicLink -Path '$(cygpath -w "$target")' -Target '$(cygpath -w "$source")' -Force" 2>/dev/null
      return $?
    fi
  else
    # Unix/Linux/macOS: Use ln -s
    ln -s "$source" "$target" 2>/dev/null
    return $?
  fi
}

# ============================================================================
# MODE: SYSTEM COMMAND
# ============================================================================
# Built-in system utilities
# Example: agence !help
# Example: agence !bash (open new shell)

mode_system() {
  local sys_cmd="$1"

  [[ "$DEBUG" == "1" ]] && echo "[DEBUG] System mode: $sys_cmd" >&2

  case "$sys_cmd" in
    help)
      show_help
      return 0
      ;;
    version)
      show_version
      return 0
      ;;
    config)
      cat "$AGENCE_CONFIG" 2>/dev/null || echo "No config found: $AGENCE_CONFIG"
      return 0
      ;;
    status)
      echo "Agence Status:"
      echo "  Root: $AGENCE_ROOT"
      echo "  Config: $AGENCE_CONFIG"
      echo "  LLM Provider: $(grep 'provider:' "$AGENCE_CONFIG" 2>/dev/null | awk '{print $2}')"
      return 0
      ;;
    bash)
      shell_bash_session
      ;;
    shell)
      shell_powershell_session
      ;;
    *)
      echo "Unknown system command: $sys_cmd" >&2
      return 1
      ;;
  esac
}

# ============================================================================
# SHELL SESSIONS: Bash and PowerShell with Session/Agent Pinning
# ============================================================================

generate_shell_session_id() {
  # Format: bash-YYYYMMDD_HHMMSS-PID-HEXID or ps-YYYYMMDD_HHMMSS-PID-HEXID
  local shell_type="$1"
  local timestamp=$(date +%Y%m%d_%H%M%S)
  local pid=$$
  local hexid=$(printf '%x' $((RANDOM * RANDOM)))
  
  echo "${shell_type}-${timestamp}-${pid}-${hexid}"
}

get_agent_id() {
  # Get current agent (default to 'ai-agent' if not set)
  echo "${AIDO_AGENT:-ai-agent}"
}

set_vscode_terminal_title() {
  local title="$1"
  # VSCode escape sequence for setting terminal title in integrated terminal
  printf '\033]0;%s\007' "$title"
}

shell_bash_session() {
  [[ "$DEBUG" == "1" ]] && echo "[DEBUG] Launching bash session with session tracking..." >&2
  
  # Read agent from environment variable
  # Default to "@" (Copilot autoselect) if not set
  local agent_id="${AGENCE_AGENT_PARAM:-@}"
  
  # Generate session identification
  local session_id=$(generate_shell_session_id "bash")
  local vscode_title="bash:${session_id}@${agent_id}"
  
  # Create session metadata directory
  local sessions_dir="${AGENCE_ROOT}/nexus/.aisessions"
  mkdir -p "$sessions_dir" 2>/dev/null
  
  # Store session metadata
  local session_meta="${sessions_dir}/${session_id}.meta.json"
  cat > "$session_meta" << EOF
{
  "session_id": "$session_id",
  "session_type": "bash",
  "agent_id": "$agent_id",
  "shell": "bash",
  "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "pid": $$,
  "user": "$(whoami)",
  "cwd": "$(pwd)"
}
EOF
  
  echo ""
  echo "=============================================="
  echo "  BASH SESSION"
  echo "=============================================="
  echo ""
  echo "Session ID:  $session_id"
  echo "Agent:       $agent_id"
  echo "Shell:       bash"
  echo "Working Dir: $(pwd)"
  echo "Metadata:    $session_meta"
  echo ""
  echo "Title:       $vscode_title"
  echo ""
  echo "=============================================="
  echo ""
  
  # Set VSCode terminal title
  set_vscode_terminal_title "$vscode_title"
  
  # Export environment variables that .agencerc will read
  export AGENT="$agent_id"
  export SHELL="bash"
  export SESSION="$session_id"
  export AGENCE_SESSION_ID="$session_id"
  export AGENCE_AGENT_ID="$agent_id"
  export AGENCE_SESSION_TYPE="bash"
  
  # Launch bash with common Agence profile
  exec bash --rcfile "$AGENCE_BIN/.agencerc" -i
}

shell_powershell_session() {
  [[ "$DEBUG" == "1" ]] && echo "[DEBUG] Launching PowerShell session with session tracking..." >&2
  
  # Read agent from environment variable
  # Default to "@" (Copilot autoselect) if not set
  local agent_id="${AGENCE_AGENT_PARAM:-@}"
  
  # Generate session identification
  local session_id=$(generate_shell_session_id "ps")
  local vscode_title="powershell:${session_id}@${agent_id}"
  
  # Create session metadata directory
  local sessions_dir="${AI_ROOT}/nexus/.aisessions"
  mkdir -p "$sessions_dir" 2>/dev/null
  
  # Store session metadata
  local session_meta="${sessions_dir}/${session_id}.meta.json"
  cat > "$session_meta" << EOF
{
  "session_id": "$session_id",
  "session_type": "powershell",
  "agent_id": "$agent_id",
  "shell": "powershell",
  "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "pid": $$,
  "user": "$(whoami)",
  "cwd": "$(pwd)"
}
EOF
  
  echo ""
  echo "=============================================="
  echo "  POWERSHELL SESSION"
  echo "=============================================="
  echo ""
  echo "Session ID:  $session_id"
  echo "Agent:       $agent_id"
  echo "Shell:       powershell"
  echo "Working Dir: $(pwd)"
  echo "Metadata:    $session_meta"
  echo ""
  echo "Title:       $vscode_title"
  echo ""
  echo "=============================================="
  echo ""
  
  # Set VSCode terminal title
  set_vscode_terminal_title "$vscode_title"
  
  # Create PowerShell profile snippet for custom prompt
  local pwsh_profile_snippet="
\$env:AGENCE_SESSION_ID = '$session_id'
\$env:AGENCE_AGENT_ID = '$agent_id'
\$env:AGENCE_SESSION_TYPE = 'powershell'

function prompt {
  return 'powershell:${session_id}@${agent_id}: '
}
"
  
  # Create temporary profile
  local temp_profile=$(mktemp)
  echo "$pwsh_profile_snippet" > "$temp_profile"
  
  # Launch PowerShell with custom profile and title
  # On Windows, this uses the native PowerShell executable
  # On WSL/Linux, this attempts powershell.exe if available
  if command -v powershell.exe &>/dev/null; then
    # Windows native PowerShell
    exec powershell.exe -NoExit -Command "
      `$env:AGENCE_SESSION_ID = '$session_id'
      `$env:AGENCE_AGENT_ID = '$agent_id'
      `$env:AGENCE_SESSION_TYPE = 'powershell'
      `$env:AGENT = '$agent_id'
      `$env:SHELL = 'powershell'
      `$env:SESSION = '$session_id'
      
      function prompt {
        return 'powershell:${session_id}@${agent_id}: '
      }
    "
  elif command -v pwsh &>/dev/null; then
    # PowerShell Core (cross-platform)
    export AGENCE_SESSION_ID="$session_id"
    export AGENCE_AGENT_ID="$agent_id"
    export AGENCE_SESSION_TYPE="powershell"
    export AGENT="$agent_id"
    export SHELL="powershell"
    export SESSION="$session_id"
    
    exec pwsh -NoExit -Command "
      \$env:AGENCE_SESSION_ID = '$session_id'
      \$env:AGENCE_AGENT_ID = '$agent_id'
      \$env:AGENCE_SESSION_TYPE = 'powershell'
      \$env:AGENT = '$agent_id'
      \$env:SHELL = 'powershell'
      \$env:SESSION = '$session_id'
      
      function prompt {
        return 'powershell:${session_id}@${agent_id}: '
      }
    "
  else
    echo "✗ PowerShell not found (tried powershell.exe and pwsh)"
    return 1
  fi
}

# ============================================================================
# SYMLINK REPAIR (Windows git-bash compatibility)
# ============================================================================
# Delegated to: bin/gitpost
# Called by: .git/hooks/post-checkout
# Invoked via: agence /gitpost

# ============================================================================
# REINDEX: Knowledge Base Indexing & Cache Management
# ============================================================================

reindex_knowledge_bases() {
  [[ "$DEBUG" == "1" ]] && echo "[DEBUG] Reindexing knowledge bases..." >&2
  
  echo ""
  echo "=============================================="
  echo "  AGENCE KNOWLEDGE BASE REINDEX (^reindex)"
  echo "=============================================="
  echo ""
  
  local kb_root="${AGENCE_REPO}/globalcache"
  local indexer_script="${AGENCE_REPO}/bin/indexer"
  local reindex_count=0
  local cache_expired=0
  local tags_updated=0
  
  # Verify indexer exists
  if [[ ! -f "$indexer_script" ]]; then
    echo "✗ Indexer script not found: $indexer_script"
    return 1
  fi
  
  if [[ ! -x "$indexer_script" ]]; then
    echo "Fixing indexer permissions..."
    chmod +x "$indexer_script" 2>/dev/null || {
      echo "⚠ Warning: Could not make indexer executable"
    }
  fi
  
  echo "Knowledge Base Root: $kb_root"
  echo ""
  
  # Check if knowledge bases directory exists
  if [[ ! -d "$kb_root" ]]; then
    echo "⚠ No knowledge bases found at: $kb_root"
    return 0
  fi
  
  echo "Step 1/3: Scanning knowledge bases..."
  
  # Find all knowledge base directories
  local kb_dirs
  mapfile -t kb_dirs < <(find "$kb_root" -maxdepth 1 -mindepth 1 -type d | sort)
  
  if [[ ${#kb_dirs[@]} -eq 0 ]]; then
    echo "⚠ No knowledge base directories found"
    return 0
  fi
  
  for kb_dir in "${kb_dirs[@]}"; do
    local kb_name=$(basename "$kb_dir")
    echo "  Found: $kb_name"
  done
  echo ""
  
  echo "Step 2/3: Expiring cached metadata..."
  
  # Clear or refresh cache files (timestamps, checksums, formtags)
  for kb_dir in "${kb_dirs[@]}"; do
    local kb_name=$(basename "$kb_dir")
    local cache_dir="$kb_dir/.index_cache"
    
    if [[ -d "$cache_dir" ]]; then
      echo "  Expiring cache: $kb_name"
      find "$cache_dir" -name "*.json" -o -name "*.cache" | while read -r cache_file; do
        rm -f "$cache_file" 2>/dev/null && ((cache_expired++))
      done
      echo "    ✓ Expired"
    fi
  done
  echo ""
  
  echo "Step 3/3: Reindexing knowledge bases..."
  
  # Run indexer on each knowledge base
  for kb_dir in "${kb_dirs[@]}"; do
    local kb_name=$(basename "$kb_dir")
    echo "  Indexing: $kb_name"
    
    # Check for INDEX.md or index sources
    if [[ -f "$kb_dir/INDEX.md" ]]; then
      "$indexer_script" --source kb --format markdown \
        --input "$kb_dir/INDEX.md" \
        --output "$kb_dir/.index_cache/index.json" 2>/dev/null
      
      if [[ $? -eq 0 ]]; then
        echo "    ✓ Indexed (formtags generated)"
        ((tags_updated++))
      else
        echo "    ⚠ Index generation had issues"
      fi
    else
      # Index markdown files in directory
      local md_count=$(find "$kb_dir" -name "*.md" -type f | wc -l)
      if [[ $md_count -gt 0 ]]; then
        "$indexer_script" --source kb --format markdown \
          --input "$kb_dir" \
          --output "$kb_dir/.index_cache/index.json" 2>/dev/null
        
        if [[ $? -eq 0 ]]; then
          echo "    ✓ Indexed ($md_count files, formtags generated)"
          ((tags_updated++))
        fi
      else
        echo "    ⚠ No markdown files found"
      fi
    fi
    
    ((reindex_count++))
  done
  
  echo ""
  echo "=============================================="
  echo "  REINDEX COMPLETE"
  echo "=============================================="
  echo ""
  echo "Summary:"
  echo "  Knowledge bases processed: $reindex_count"
  echo "  Cache entries expired: $cache_expired"
  echo "  Formtags updated: $tags_updated"
  echo ""
  
  return 0
}

# ============================================================================
# LEARN: Extract Knowledge from Sessions and Faults
# ============================================================================

learn_from_sessions() {
  [[ "$DEBUG" == "1" ]] && echo "[DEBUG] Learning from sessions..." >&2
  
  echo ""
  echo "=============================================="
  echo "  AGENCE LEARNING (^learn)"
  echo "=============================================="
  echo ""
  
  local sessions_dir="${AGENCE_REPO}/nexus/.aisessions"
  local faults_dir="${AGENCE_REPO}/nexus/faults"
  local lessons_dir="${AGENCE_REPO}/synthesis/l-agence.org/lessons"
  
  local session_count=0
  local fault_count=0
  local lesson_count=0
  
  mkdir -p "$lessons_dir" 2>/dev/null
  
  echo "Step 1/3: Scanning session history..."
  
  if [[ -d "$sessions_dir" ]]; then
    session_count=$(find "$sessions_dir" -name "*.meta.json" -type f | wc -l)
    echo "  Found $session_count sessions"
  else
    echo "  No sessions directory found"
  fi
  echo ""
  
  echo "Step 2/3: Reviewing recorded faults..."
  
  if [[ -d "$faults_dir" ]]; then
    fault_count=$(find "$faults_dir" -name "*.md" -type f | wc -l)
    echo "  Found $fault_count fault records"
    
    # Extract key insights from fault records
    if [[ $fault_count -gt 0 ]]; then
      echo "  Processing fault insights..."
      find "$faults_dir" -name "*.md" -type f | while read -r fault_file; do
        local fault_name=$(basename "$fault_file" .md)
        echo "    - Reviewed: $fault_name"
      done
    fi
  else
    echo "  No faults directory found"
  fi
  echo ""
  
  echo "Step 3/3: Synthesizing lessons learned..."
  
  # Update lessons index
  local lessons_count=$(find "$lessons_dir" -name "*.md" -type f 2>/dev/null | wc -l)
  
  echo "  Active lessons: $lessons_count"
  echo "  Synthesis destination: $lessons_dir"
  echo ""
  
  echo "=============================================="
  echo "  LEARNING COMPLETE"
  echo "=============================================="
  echo ""
  echo "Summary:"
  echo "  Sessions reviewed: $session_count"
  echo "  Faults analyzed: $fault_count"
  echo "  Lessons in synthesis: $lessons_count"
  echo ""
  echo "Next: Use ^commit to save knowledge changes"
  echo ""
  
  return 0
}

# ============================================================================
# COMMIT: Save Knowledge Base Changes
# ============================================================================

commit_knowledge_changes() {
  [[ "$DEBUG" == "1" ]] && echo "[DEBUG] Committing knowledge changes..." >&2
  
  echo ""
  echo "=============================================="
  echo "  AGENCE KNOWLEDGE COMMIT (^commit)"
  echo "=============================================="
  echo ""
  
  # Check if we're in a git repository
  if ! git rev-parse --git-dir >/dev/null 2>&1; then
    echo "✗ Not in a git repository"
    echo "  Knowledge changes must be committed via git"
    return 1
  fi
  
  echo "Step 1/2: Staging knowledge changes..."
  
  # Stage all synthetic knowledge changes
  local kb_root="${AGENCE_REPO}/globalcache"
  local synthesis="${AGENCE_REPO}/synthesis"
  local nexus_faults="${AGENCE_REPO}/nexus/faults"
  
  git add "$kb_root" 2>/dev/null
  git add "$synthesis" 2>/dev/null
  git add "$nexus_faults" 2>/dev/null
  
  # Count staged changes
  local staged_count=$(git diff --cached --name-only | wc -l)
  
  if [[ $staged_count -gt 0 ]]; then
    echo "  ✓ Staged $staged_count files"
  else
    echo "  ⚠ No changes to commit"
    return 0
  fi
  echo ""
  
  echo "Step 2/2: Creating commit..."
  
  local commit_msg="[KNOWLEDGE] Synthetic learning update

- Updated knowledge bases (globalcache/)
- Recorded lessons learned (synthesis/)
- Fault analysis and insights (nexus/faults/)

Automated knowledge synthesis and consolidation."
  
  git commit -m "$commit_msg" 2>/dev/null
  
  if [[ $? -eq 0 ]]; then
    local commit_sha=$(git rev-parse --short HEAD)
    echo "  ✓ Committed: $commit_sha"
    echo ""
    echo "=============================================="
    echo "  KNOWLEDGE COMMIT COMPLETE"
    echo "=============================================="
    echo ""
    echo "Commit: $commit_sha"
    echo "Files changed: $staged_count"
    echo ""
    echo "Next: Use ^push to sync with upstream"
    echo ""
  else
    echo "  ⚠ Commit creation had issues (no changes?)"
  fi
  
  return 0
}

# ============================================================================
# PUSH: Sync Knowledge Base to Upstream
# ============================================================================

push_knowledge_upstream() {
  [[ "$DEBUG" == "1" ]] && echo "[DEBUG] Pushing knowledge upstream..." >&2
  
  echo ""
  echo "=============================================="
  echo "  AGENCE KNOWLEDGE PUSH (^push)"
  echo "=============================================="
  echo ""
  
  # Check if we're in a git repository
  if ! git rev-parse --git-dir >/dev/null 2>&1; then
    echo "✗ Not in a git repository"
    return 1
  fi
  
  # Check if we have unpushed commits
  local branch=$(git rev-parse --abbrev-ref HEAD)
  local ahead=$(git rev-list --count "@{u}..HEAD" 2>/dev/null || echo "0")
  
  if [[ "$ahead" == "0" ]] || [[ -z "$ahead" ]]; then
    echo "✓ No unpushed commits on '$branch'"
    echo "  Knowledge base is up to date with upstream"
    echo ""
    return 0
  fi
  
  echo "Preparing to push knowledge updates..."
  echo "  Branch: $branch"
  echo "  Unpushed commits: $ahead"
  echo ""
  
  # Show commits to be pushed
  echo "Commits to push:"
  git log -n "$ahead" --oneline | sed 's/^/  - /'
  echo ""
  
  echo "Pushing to upstream..."
  
  git push origin "$branch" 2>&1
  
  if [[ $? -eq 0 ]]; then
    echo ""
    echo "=============================================="
    echo "  KNOWLEDGE PUSH COMPLETE"
    echo "=============================================="
    echo ""
    echo "✓ Knowledge synchronized to upstream"
    echo "  Remote: origin"
    echo "  Branch: $branch"
    echo "  Commits pushed: $ahead"
    echo ""
  else
    echo ""
    echo "⚠ Push encountered issues (network, auth, conflicts?)"
    return 1
  fi
  
  return 0
}

# ============================================================================
# SAVE: Persist Agent Session Context, Lessons & Work Log
# ============================================================================
# Creates a save point that clearly identifies:
#   - Agent ID (who was working)
#   - Session ID (which session)
#   - Log ID (unique save identifier for this checkpoint)
#
# Outputs: nexus/.aisessions/SAVE-{log_id}.json
# Contains: session state, recent lessons, work log summary, git diff stats

save_session_context() {
  [[ "$DEBUG" == "1" ]] && echo "[DEBUG] Saving session context..." >&2

  local agent_id="${AGENCE_AGENT_PARAM:-${AGENCE_AGENT_ID:-@}}"
  local session_id="${AGENCE_SESSION_ID:-$(generate_shell_session_id save)}"
  local log_id="save-$(date +%Y%m%d_%H%M%S)-$(printf '%x' $((RANDOM * RANDOM)))"

  local sessions_dir="${AGENCE_ROOT}/nexus/.aisessions"
  local saves_dir="${AGENCE_ROOT}/nexus/.aisaves"
  local lessons_dir="${AGENCE_ROOT}/synthesis/l-agence.org/lessons"
  mkdir -p "$saves_dir" 2>/dev/null

  agence_format_header "AGENCE SAVE (^save) — checkpoint"
  agence_format_kv "Agent" "$agent_id"
  agence_format_kv "Session" "$session_id"
  agence_format_kv "Log ID" "$log_id"
  echo ""

  # Gather git state
  local branch=$(git -C "$AGENCE_ROOT" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
  local commit=$(git -C "$AGENCE_ROOT" rev-parse --short HEAD 2>/dev/null || echo "unknown")
  local dirty_count=$(git -C "$AGENCE_ROOT" status --short 2>/dev/null | wc -l | tr -d ' ')
  local staged_count=$(git -C "$AGENCE_ROOT" diff --cached --name-only 2>/dev/null | wc -l | tr -d ' ')

  # Count lessons
  local lesson_count=0
  if [[ -d "$lessons_dir" ]]; then
    lesson_count=$(find "$lessons_dir" -name "*.json" -not -name "INDEX.json" -type f 2>/dev/null | wc -l | tr -d ' ')
  fi

  # Count sessions
  local session_count=0
  if [[ -d "$sessions_dir" ]]; then
    session_count=$(find "$sessions_dir" -name "*.meta.json" -type f 2>/dev/null | wc -l | tr -d ' ')
  fi

  # Recent git log (last 5 commits)
  local recent_commits=$(git -C "$AGENCE_ROOT" log --oneline -5 2>/dev/null | sed 's/"/\\"/g' | awk '{printf "    \"%s\",\n", $0}' | sed '$ s/,$//')

  # Dirty files list
  local dirty_files=$(git -C "$AGENCE_ROOT" status --short 2>/dev/null | sed 's/"/\\"/g' | awk '{printf "    \"%s\",\n", $0}' | sed '$ s/,$//')

  # Write save file
  local save_file="${saves_dir}/${log_id}.json"
  cat > "$save_file" <<EOF
{
  "log_id": "$log_id",
  "agent_id": "$agent_id",
  "session_id": "$session_id",
  "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "user": "$(whoami)",
  "cwd": "$(pwd)",
  "git": {
    "branch": "$branch",
    "commit": "$commit",
    "dirty_files": $dirty_count,
    "staged_files": $staged_count
  },
  "knowledge": {
    "lessons_count": $lesson_count,
    "sessions_count": $session_count
  },
  "recent_commits": [
$recent_commits
  ],
  "dirty_files": [
$dirty_files
  ]
}
EOF

  if [[ "$_AGENCE_FMT" == "json" ]]; then
    agence_format_json "$(cat "$save_file")"
  else
    agence_format_step "1/2" "Session context captured"
    agence_format_detail "Git: $branch @ $commit ($dirty_count dirty, $staged_count staged)"
    agence_format_detail "Knowledge: $lesson_count lessons, $session_count sessions"
    echo ""

    agence_format_step "2/2" "Save file written"
    agence_format_detail "$save_file"
    echo ""

    agence_format_footer "SAVE COMPLETE"
    echo ""
    agence_format_kv "Log ID" "$log_id"
    agence_format_kv "Agent" "$agent_id"
    agence_format_kv "Session" "$session_id"
    echo ""
    agence_format_detail "Use ^handoff to transfer to another agent"
    agence_format_detail "Use ^commit to persist knowledge changes"
    echo ""
  fi

  return 0
}

# ============================================================================
# HANDOFF: Transfer Session Context Between Agents or to User
# ============================================================================
# Creates a handoff record from the current agent to a target agent or user.
# The handoff includes:
#   - Source agent + session (who is handing off)
#   - Target agent or "user" (who receives)
#   - Context summary (what was being worked on)
#   - Open items (what still needs to be done)
#
# Usage: agence ^handoff <target_agent> [context message]
#   agence @claudia ^handoff @peers "solve the bash issue"
#   agence @peers ^handoff user "analysis complete, review results"

handoff_to_agent() {
  [[ "$DEBUG" == "1" ]] && echo "[DEBUG] Handoff initiated..." >&2

  local target="$1"
  shift
  local context_msg="$*"

  local source_agent="${AGENCE_AGENT_PARAM:-${AGENCE_AGENT_ID:-@}}"
  local session_id="${AGENCE_SESSION_ID:-$(generate_shell_session_id handoff)}"
  local handoff_id="handoff-$(date +%Y%m%d_%H%M%S)-$(printf '%x' $((RANDOM * RANDOM)))"

  # Validate target
  if [[ -z "$target" ]]; then
    echo ""
    echo "Usage: agence ^handoff <target_agent> [context message]"
    echo ""
    echo "Examples:"
    echo "  agence @claudia ^handoff @peers \"solve the bash issue\""
    echo "  agence @peers ^handoff user \"analysis complete\""
    echo "  agence ^handoff @ralph \"auto-iterate on this fix\""
    echo ""
    echo "Available agents:"
    ls "$AGENCE_ROOT/codex/agents/" 2>/dev/null | grep -v '\.md$' | sed 's/^/  @/'
    return 1
  fi

  # Strip @ prefix if present for directory lookup, keep for display
  local target_display="$target"
  local target_name="${target#@}"

  # Validate target agent exists (unless it's "user")
  if [[ "$target_name" != "user" ]] && [[ ! -d "$AGENCE_ROOT/codex/agents/$target_name" ]]; then
    echo "Error: Unknown agent: $target" >&2
    echo "Available agents:" >&2
    ls "$AGENCE_ROOT/codex/agents/" 2>/dev/null | grep -v '\.md$' | sed 's/^/  @/' >&2
    return 1
  fi

  local handoffs_dir="${AGENCE_ROOT}/nexus/.aihandoffs"
  mkdir -p "$handoffs_dir" 2>/dev/null

  agence_format_header "AGENCE HANDOFF (^handoff)"
  agence_format_kv "From" "$source_agent"
  agence_format_kv "To" "$target_display"
  agence_format_kv "Session" "$session_id"
  agence_format_kv "Handoff ID" "$handoff_id"
  echo ""

  # Auto-save before handoff
  agence_format_step "1/3" "Auto-saving session context..."

  # Gather git state for the handoff record
  local branch=$(git -C "$AGENCE_ROOT" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
  local commit=$(git -C "$AGENCE_ROOT" rev-parse --short HEAD 2>/dev/null || echo "unknown")
  local dirty_count=$(git -C "$AGENCE_ROOT" status --short 2>/dev/null | wc -l | tr -d ' ')

  agence_format_detail "Git: $branch @ $commit ($dirty_count dirty)"
  echo ""

  agence_format_step "2/3" "Creating handoff record..."

  # Recent work (last 5 commits)
  local recent_commits=$(git -C "$AGENCE_ROOT" log --oneline -5 2>/dev/null | sed 's/"/\\"/g' | awk '{printf "    \"%s\",\n", $0}' | sed '$ s/,$//')

  # Dirty files
  local dirty_files=$(git -C "$AGENCE_ROOT" status --short 2>/dev/null | sed 's/"/\\"/g' | awk '{printf "    \"%s\",\n", $0}' | sed '$ s/,$//')

  # Escape context message for JSON
  local context_escaped=$(echo "$context_msg" | sed 's/"/\\"/g')

  local handoff_file="${handoffs_dir}/${handoff_id}.json"
  cat > "$handoff_file" <<EOF
{
  "handoff_id": "$handoff_id",
  "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "source": {
    "agent": "$source_agent",
    "session_id": "$session_id"
  },
  "target": {
    "agent": "$target_display",
    "agent_dir": "$target_name"
  },
  "context": "$context_escaped",
  "git": {
    "branch": "$branch",
    "commit": "$commit",
    "dirty_files": $dirty_count
  },
  "recent_commits": [
$recent_commits
  ],
  "pending_files": [
$dirty_files
  ],
  "status": "pending"
}
EOF

  agence_format_detail "Handoff record: $handoff_file"
  echo ""

  agence_format_step "3/3" "Handoff ready"
  echo ""

  if [[ "$_AGENCE_FMT" == "json" ]]; then
    agence_format_json "$(cat "$handoff_file")"
  else
    agence_format_footer "HANDOFF COMPLETE"
    echo ""
    agence_format_kv "Transfer" "$source_agent → $target_display"
    agence_format_kv "ID" "$handoff_id"
    if [[ -n "$context_msg" ]]; then
      agence_format_kv "Context" "$context_msg"
    fi
    echo ""
    agence_format_detail "Next: Switch to $target_display to pick up this handoff"
    if [[ "$target_name" != "user" ]]; then
      agence_format_detail "Command: agence $target_display ^pickup"
    fi
    echo ""
  fi

  return 0
}

# ============================================================================
# PICKUP: Accept a Pending Handoff (like unix 'fg')
# ============================================================================
# Lists pending handoffs for the current agent, or accepts a specific one.
# Loads the handoff context into the current session — brings work to foreground.
#
# Usage:
#   agence ^pickup                     — list pending handoffs for this agent
#   agence ^pickup <handoff_id>        — accept a specific handoff
#   agence @peers ^pickup              — list handoffs targeted at @peers

pickup_handoff() {
  [[ "$DEBUG" == "1" ]] && echo "[DEBUG] Pickup initiated..." >&2

  local pickup_arg="${1:-}"
  local current_agent="${AGENCE_AGENT_PARAM:-${AGENCE_AGENT_ID:-@}}"
  local current_name="${current_agent#@}"
  local handoffs_dir="${AGENCE_ROOT}/nexus/.aihandoffs"

  if [[ ! -d "$handoffs_dir" ]]; then
    echo ""
    echo "No handoffs directory found. Nothing to pick up."
    return 0
  fi

  # If no argument, list pending handoffs for this agent
  if [[ -z "$pickup_arg" ]]; then
    agence_format_header "AGENCE PICKUP (^pickup) — pending handoffs"
    agence_format_kv "Agent" "$current_agent"
    echo ""

    local found=0
    local json_items=""

    # Find pending handoffs targeted at this agent (or at @/any if current is @)
    while IFS= read -r f; do
      [[ -z "$f" ]] && continue
      local target_agent=$(grep -o '"agent": *"[^"]*"' "$f" | tail -1 | sed 's/.*"agent": *"//;s/"//')
      local status=$(grep -o '"status": *"[^"]*"' "$f" | sed 's/.*"status": *"//;s/"//')
      local target_clean="${target_agent#@}"

      if [[ "$status" == "pending" ]] && { [[ "$target_clean" == "$current_name" ]] || [[ "$current_agent" == "@" ]]; }; then
        local hid=$(grep -o '"handoff_id": *"[^"]*"' "$f" | sed 's/.*"handoff_id": *"//;s/"//')
        local source=$(grep -o '"agent": *"[^"]*"' "$f" | head -1 | sed 's/.*"agent": *"//;s/"//')
        local ctx=$(grep -o '"context": *"[^"]*"' "$f" | sed 's/.*"context": *"//;s/"//')
        local ts=$(grep -o '"timestamp": *"[^"]*"' "$f" | sed 's/.*"timestamp": *"//;s/"//')

        found=$((found + 1))

        if [[ "$_AGENCE_FMT" == "json" ]]; then
          [[ -n "$json_items" ]] && json_items+=","
          json_items+="{\"id\":\"$hid\",\"from\":\"$source\",\"context\":\"$ctx\",\"timestamp\":\"$ts\"}"
        else
          agence_format_list_item "$found" "$hid" "From=$source|At=$ts|Context=${ctx:-<none>}"
        fi
      fi
    done < <(find "$handoffs_dir" -name "handoff-*.json" -type f 2>/dev/null | sort -r)

    if [[ "$_AGENCE_FMT" == "json" ]]; then
      agence_format_json "{\"command\":\"pickup\",\"agent\":\"$current_agent\",\"pending\":[$json_items],\"count\":$found}"
    elif [[ $found -eq 0 ]]; then
      agence_format_detail "No pending handoffs for $current_agent"
    else
      echo "  Total: $found pending handoff(s)"
      echo ""
      echo "  Accept with: agence ^pickup <handoff_id>"
    fi
    echo ""
    return 0
  fi

  # Accept a specific handoff
  local handoff_file=""

  # Try exact match first
  if [[ -f "${handoffs_dir}/${pickup_arg}.json" ]]; then
    handoff_file="${handoffs_dir}/${pickup_arg}.json"
  else
    # Try partial match (e.g., user passes just the hex suffix)
    handoff_file=$(find "$handoffs_dir" -name "*${pickup_arg}*.json" -type f 2>/dev/null | head -1)
  fi

  if [[ -z "$handoff_file" ]] || [[ ! -f "$handoff_file" ]]; then
    echo "Error: Handoff not found: $pickup_arg" >&2
    echo "Use: agence ^pickup   (to list pending handoffs)" >&2
    return 1
  fi

  # Verify it's still pending
  local status=$(grep -o '"status": *"[^"]*"' "$handoff_file" | sed 's/.*"status": *"//;s/"//')
  if [[ "$status" != "pending" ]]; then
    echo "Error: Handoff already $status: $pickup_arg" >&2
    return 1
  fi

  # Extract handoff info
  local hid=$(grep -o '"handoff_id": *"[^"]*"' "$handoff_file" | sed 's/.*"handoff_id": *"//;s/"//')
  local source=$(grep -o '"agent": *"[^"]*"' "$handoff_file" | head -1 | sed 's/.*"agent": *"//;s/"//')
  local target=$(grep -o '"agent": *"[^"]*"' "$handoff_file" | tail -1 | sed 's/.*"agent": *"//;s/"//')
  local ctx=$(grep -o '"context": *"[^"]*"' "$handoff_file" | sed 's/.*"context": *"//;s/"//')
  local hbranch=$(grep -o '"branch": *"[^"]*"' "$handoff_file" | sed 's/.*"branch": *"//;s/"//')
  local hcommit=$(grep -o '"commit": *"[^"]*"' "$handoff_file" | sed 's/.*"commit": *"//;s/"//')

  agence_format_header "AGENCE PICKUP (^pickup) — accepting handoff"
  agence_format_kv "Handoff" "$hid"
  agence_format_kv "From" "$source"
  agence_format_kv "To" "$current_agent (you)"
  agence_format_kv "Context" "${ctx:-<none>}"
  agence_format_kv "Git state" "$hbranch @ $hcommit"
  echo ""

  agence_format_step "1/2" "Marking handoff as accepted..."

  # Update status in handoff file: pending → accepted
  sed -i 's/"status": *"pending"/"status": "accepted"/' "$handoff_file"

  # Add pickup metadata
  local pickup_ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  sed -i "s/\"status\": \"accepted\"/\"status\": \"accepted\",\n  \"picked_up_by\": \"$current_agent\",\n  \"picked_up_at\": \"$pickup_ts\"/" "$handoff_file"

  agence_format_detail "Status: pending → accepted"
  echo ""

  agence_format_step "2/2" "Context loaded"
  echo ""

  # Show recent commits and pending files from the handoff
  if [[ "$_AGENCE_FMT" != "json" ]]; then
    agence_format_detail "Recent work from $source:"
    sed -n '/"recent_commits"/,/\]/p' "$handoff_file" | grep -v 'recent_commits\|\[\|\]' | sed 's/^[[:space:]]*"//;s/"[,]*$//' | head -5 | sed 's/^/    /'
    echo ""

    local pending_count=$(grep -c '"pending_files"' "$handoff_file" 2>/dev/null)
    if [[ $pending_count -gt 0 ]]; then
      local pfiles=$(grep -A 50 '"pending_files"' "$handoff_file" | grep '"' | grep -v 'pending_files' | head -10 | sed 's/.*"//;s/".*//' | wc -l | tr -d ' ')
      agence_format_detail "Pending files: $pfiles"
    fi
    echo ""
  fi

  if [[ "$_AGENCE_FMT" == "json" ]]; then
    agence_format_json "{\"command\":\"pickup\",\"handoff_id\":\"$hid\",\"from\":\"$source\",\"to\":\"$current_agent\",\"context\":\"${ctx:-}\",\"git\":{\"branch\":\"$hbranch\",\"commit\":\"$hcommit\"},\"status\":\"accepted\",\"picked_up_at\":\"$pickup_ts\"}"
  else
    agence_format_footer "PICKUP COMPLETE — you have the ball"
    echo ""
    agence_format_kv "Transfer" "$source → $current_agent [ACCEPTED]"
    agence_format_kv "Context" "${ctx:-<none>}"
    echo ""
    agence_format_detail "Use ^save to checkpoint your progress"
    agence_format_detail "Use ^handoff to pass to another agent"
    echo ""
  fi

  return 0
}

# ============================================================================
# PAUSE: Suspend Session with Auto-Save (like unix Ctrl+Z)
# ============================================================================
# Saves current session state and marks it as paused.
# Unlike ^save (checkpoint while working), ^pause signals intentional stop.
#
# Usage:
#   agence ^pause                      — pause current session
#   agence ^pause <session_id>         — pause a specific session by ID

pause_session() {
  [[ "$DEBUG" == "1" ]] && echo "[DEBUG] Pause initiated..." >&2

  local pause_arg="${1:-}"
  local agent_id="${AGENCE_AGENT_PARAM:-${AGENCE_AGENT_ID:-@}}"
  local session_id="${AGENCE_SESSION_ID:-$(generate_shell_session_id pause)}"
  local pause_id="pause-$(date +%Y%m%d_%H%M%S)-$(printf '%x' $((RANDOM * RANDOM)))"

  local saves_dir="${AGENCE_ROOT}/nexus/.aisaves"
  local lessons_dir="${AGENCE_ROOT}/synthesis/l-agence.org/lessons"
  local sessions_dir="${AGENCE_ROOT}/nexus/.aisessions"
  mkdir -p "$saves_dir" 2>/dev/null

  # Gather git state
  local branch=$(git -C "$AGENCE_ROOT" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
  local commit=$(git -C "$AGENCE_ROOT" rev-parse --short HEAD 2>/dev/null || echo "unknown")
  local dirty_count=$(git -C "$AGENCE_ROOT" status --short 2>/dev/null | wc -l | tr -d ' ')
  local staged_count=$(git -C "$AGENCE_ROOT" diff --cached --name-only 2>/dev/null | wc -l | tr -d ' ')

  # Count lessons
  local lesson_count=0
  if [[ -d "$lessons_dir" ]]; then
    lesson_count=$(find "$lessons_dir" -name "*.json" -not -name "INDEX.json" -type f 2>/dev/null | wc -l | tr -d ' ')
  fi

  # Count sessions
  local session_count=0
  if [[ -d "$sessions_dir" ]]; then
    session_count=$(find "$sessions_dir" -name "*.meta.json" -type f 2>/dev/null | wc -l | tr -d ' ')
  fi

  # Recent git log
  local recent_commits=$(git -C "$AGENCE_ROOT" log --oneline -5 2>/dev/null | sed 's/"/\\"/g' | awk '{printf "    \"%s\",\n", $0}' | sed '$ s/,$//')

  # Dirty files
  local dirty_files=$(git -C "$AGENCE_ROOT" status --short 2>/dev/null | sed 's/"/\\"/g' | awk '{printf "    \"%s\",\n", $0}' | sed '$ s/,$//')

  # Write pause file (same structure as save, but with status=paused)
  local pause_file="${saves_dir}/${pause_id}.json"
  cat > "$pause_file" <<EOF
{
  "log_id": "$pause_id",
  "type": "pause",
  "agent_id": "$agent_id",
  "session_id": "$session_id",
  "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "status": "paused",
  "user": "$(whoami)",
  "cwd": "$(pwd)",
  "git": {
    "branch": "$branch",
    "commit": "$commit",
    "dirty_files": $dirty_count,
    "staged_files": $staged_count
  },
  "knowledge": {
    "lessons_count": $lesson_count,
    "sessions_count": $session_count
  },
  "recent_commits": [
$recent_commits
  ],
  "dirty_files": [
$dirty_files
  ]
}
EOF

  if [[ "$_AGENCE_FMT" == "json" ]]; then
    agence_format_json "$(cat "$pause_file")"
  else
    agence_format_header "AGENCE PAUSE (^pause) — suspending session"
    agence_format_kv "Agent" "$agent_id"
    agence_format_kv "Session" "$session_id"
    agence_format_kv "Pause ID" "$pause_id"
    echo ""

    agence_format_step "1/2" "Session state saved"
    agence_format_detail "Git: $branch @ $commit ($dirty_count dirty, $staged_count staged)"
    agence_format_detail "Knowledge: $lesson_count lessons, $session_count sessions"
    echo ""

    agence_format_step "2/2" "Session paused"
    agence_format_detail "$pause_file"
    echo ""

    agence_format_footer "SESSION PAUSED"
    echo ""
    agence_format_kv "Pause ID" "$pause_id"
    agence_format_kv "Agent" "$agent_id"
    agence_format_kv "Session" "$session_id"
    echo ""
    agence_format_detail "Resume with: agence ^resume $pause_id"
    agence_format_detail "List paused: agence ^resume"
    echo ""
  fi

  return 0
}

# ============================================================================
# RESUME: Resume a Paused Session (like unix 'bg'/'fg')
# ============================================================================
# Lists paused sessions or resumes a specific one.
# Loads the paused session context back into the current agent.
#
# Usage:
#   agence ^resume                     — list paused sessions
#   agence ^resume <pause_id>          — resume a specific paused session

resume_session() {
  [[ "$DEBUG" == "1" ]] && echo "[DEBUG] Resume initiated..." >&2

  local resume_arg="${1:-}"
  local current_agent="${AGENCE_AGENT_PARAM:-${AGENCE_AGENT_ID:-@}}"
  local saves_dir="${AGENCE_ROOT}/nexus/.aisaves"

  if [[ ! -d "$saves_dir" ]]; then
    echo ""
    echo "No saves directory found. Nothing to resume."
    return 0
  fi

  # If no argument, list paused sessions
  if [[ -z "$resume_arg" ]]; then
    agence_format_header "AGENCE RESUME (^resume) — paused sessions"
    agence_format_kv "Agent" "$current_agent"
    echo ""

    local found=0
    local json_items=""

    while IFS= read -r f; do
      [[ -z "$f" ]] && continue
      local ftype=$(grep -o '"type": *"[^"]*"' "$f" 2>/dev/null | sed 's/.*"type": *"//;s/"//')
      local fstatus=$(grep -o '"status": *"[^"]*"' "$f" 2>/dev/null | sed 's/.*"status": *"//;s/"//')
      local fagent=$(grep -o '"agent_id": *"[^"]*"' "$f" 2>/dev/null | sed 's/.*"agent_id": *"//;s/"//')

      if [[ "$ftype" == "pause" ]] && [[ "$fstatus" == "paused" ]]; then
        # Show all if current agent is @, otherwise filter by agent
        if [[ "$current_agent" == "@" ]] || [[ "$fagent" == "$current_agent" ]]; then
          local pid=$(grep -o '"log_id": *"[^"]*"' "$f" | sed 's/.*"log_id": *"//;s/"//')
          local pbranch=$(grep -o '"branch": *"[^"]*"' "$f" | sed 's/.*"branch": *"//;s/"//')
          local pcommit=$(grep -o '"commit": *"[^"]*"' "$f" | sed 's/.*"commit": *"//;s/"//')
          local pts=$(grep -o '"timestamp": *"[^"]*"' "$f" | sed 's/.*"timestamp": *"//;s/"//')
          local pdirty=$(grep -o '"dirty_files": *[0-9]*' "$f" | head -1 | sed 's/.*: *//')

          found=$((found + 1))

          if [[ "$_AGENCE_FMT" == "json" ]]; then
            [[ -n "$json_items" ]] && json_items+=","
            json_items+="{\"id\":\"$pid\",\"agent\":\"$fagent\",\"branch\":\"$pbranch\",\"commit\":\"$pcommit\",\"dirty\":$pdirty,\"paused_at\":\"$pts\"}"
          else
            agence_format_list_item "$found" "$pid" "Agent=$fagent|Git=$pbranch @ $pcommit ($pdirty dirty)|Paused=$pts"
          fi
        fi
      fi
    done < <(find "$saves_dir" -name "pause-*.json" -type f 2>/dev/null | sort -r)

    if [[ "$_AGENCE_FMT" == "json" ]]; then
      agence_format_json "{\"command\":\"resume\",\"agent\":\"$current_agent\",\"paused\":[$json_items],\"count\":$found}"
    elif [[ $found -eq 0 ]]; then
      agence_format_detail "No paused sessions"
    else
      echo "  Total: $found paused session(s)"
      echo ""
      echo "  Resume with: agence ^resume <pause_id>"
    fi
    echo ""
    return 0
  fi

  # Resume a specific paused session
  local pause_file=""

  # Try exact match
  if [[ -f "${saves_dir}/${resume_arg}.json" ]]; then
    pause_file="${saves_dir}/${resume_arg}.json"
  else
    # Partial match
    pause_file=$(find "$saves_dir" -name "*${resume_arg}*.json" -type f 2>/dev/null | head -1)
  fi

  if [[ -z "$pause_file" ]] || [[ ! -f "$pause_file" ]]; then
    echo "Error: Paused session not found: $resume_arg" >&2
    echo "Use: agence ^resume   (to list paused sessions)" >&2
    return 1
  fi

  # Verify it's paused
  local fstatus=$(grep -o '"status": *"[^"]*"' "$pause_file" | sed 's/.*"status": *"//;s/"//')
  if [[ "$fstatus" != "paused" ]]; then
    echo "Error: Session is not paused (status: $fstatus): $resume_arg" >&2
    return 1
  fi

  # Extract info
  local pid=$(grep -o '"log_id": *"[^"]*"' "$pause_file" | sed 's/.*"log_id": *"//;s/"//')
  local pagent=$(grep -o '"agent_id": *"[^"]*"' "$pause_file" | sed 's/.*"agent_id": *"//;s/"//')
  local psession=$(grep -o '"session_id": *"[^"]*"' "$pause_file" | sed 's/.*"session_id": *"//;s/"//')
  local pbranch=$(grep -o '"branch": *"[^"]*"' "$pause_file" | sed 's/.*"branch": *"//;s/"//')
  local pcommit=$(grep -o '"commit": *"[^"]*"' "$pause_file" | sed 's/.*"commit": *"//;s/"//')
  local pdirty=$(grep -o '"dirty_files": *[0-9]*' "$pause_file" | head -1 | sed 's/.*: *//')
  local pts=$(grep -o '"timestamp": *"[^"]*"' "$pause_file" | sed 's/.*"timestamp": *"//;s/"//')

  agence_format_header "AGENCE RESUME (^resume) — restoring session"
  agence_format_kv "Pause ID" "$pid"
  agence_format_kv "Agent" "$pagent"
  agence_format_kv "Session" "$psession"
  agence_format_kv "Paused at" "$pts"
  agence_format_kv "Git state" "$pbranch @ $pcommit ($pdirty dirty)"
  echo ""

  agence_format_step "1/2" "Restoring context..."

  # Show recent commits from paused state
  if [[ "$_AGENCE_FMT" != "json" ]]; then
    agence_format_detail "Work at time of pause:"
    sed -n '/"recent_commits"/,/\]/p' "$pause_file" | grep -v 'recent_commits\|\[\|\]' | sed 's/^[[:space:]]*"//;s/"[,]*$//' | head -5 | sed 's/^/    /'
    echo ""
  fi

  agence_format_step "2/2" "Marking session as resumed..."

  # Update status: paused → resumed
  sed -i 's/"status": *"paused"/"status": "resumed"/' "$pause_file"

  # Add resume metadata
  local resume_ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  sed -i "s/\"status\": \"resumed\"/\"status\": \"resumed\",\n  \"resumed_by\": \"$current_agent\",\n  \"resumed_at\": \"$resume_ts\"/" "$pause_file"

  agence_format_detail "Status: paused → resumed"
  echo ""

  if [[ "$_AGENCE_FMT" == "json" ]]; then
    agence_format_json "{\"command\":\"resume\",\"pause_id\":\"$pid\",\"agent\":\"$pagent\",\"session\":\"$psession\",\"git\":{\"branch\":\"$pbranch\",\"commit\":\"$pcommit\",\"dirty\":$pdirty},\"status\":\"resumed\",\"resumed_by\":\"$current_agent\",\"resumed_at\":\"$resume_ts\"}"
  else
    agence_format_footer "SESSION RESUMED"
    echo ""
    agence_format_kv "Restored" "$pagent session by $current_agent"
    agence_format_kv "Pause ID" "$pid"
    echo ""
    agence_format_detail "Use ^save to checkpoint progress"
    agence_format_detail "Use ^pause to suspend again"
    echo ""
  fi

  return 0
}

# ============================================================================
# INSTALL: Package Manager Integration
# ============================================================================

install_agence_packages() {
  [[ "$DEBUG" == "1" ]] && echo "[DEBUG] Installing Agence packages..." >&2
  
  echo ""
  echo "=============================================="
  echo "  AGENCE PACKAGE INSTALLATION (^install)"
  echo "=============================================="
  echo ""
  
  # Detect OS
  local os_type="unknown"
  if [[ "$OSTYPE" == "msys" || "$OSTYPE" == "mingw"* ]]; then
    os_type="windows"
  elif [[ "$OSTYPE" == "darwin"* ]]; then
    os_type="macos"
  elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
    os_type="linux"
  fi
  
  echo "Detected OS: $os_type"
  echo ""
  
  case "$os_type" in
    windows)
      install_windows_packages
      ;;
    macos)
      install_macos_packages
      ;;
    linux)
      install_linux_packages
      ;;
    *)
      echo "[ERROR] Unsupported OS: $OSTYPE" >&2
      return 1
      ;;
  esac
  
  return $?
}

install_windows_packages() {
  echo "Installing packages via winget..."
  echo ""
  
  # Define Windows packages (winget IDs)
  local -a windows_packages=(
    "GitHub.cli"
    "jqlang.jq"
    "aider"
    "jfrog"
    "Hashicorp.Terraform"
    "terrafromLinters.tflint"
    "Amazon.AWSCli"
    "Microsoft.AzureCLI"
    "Google.CloudSDK"
  )
  
  local installed=0
  local skipped=0
  local failed=0
  
  for pkg in "${windows_packages[@]}"; do
    echo -n "[$pkg] "
    
    # Check if installed || install
    # winget list returns 0 if found, 1 if not found
    if winget list --id "$pkg" &>/dev/null 2>&1; then
      echo "✓ (already installed)"
      ((skipped++))
    elif winget install -e --id "$pkg" --accept-package-agreements --accept-source-agreements &>/dev/null 2>&1; then
      echo "✓ (installed)"
      ((installed++))
    else
      echo "✗ (failed)"
      ((failed++))
    fi
  done
  
  echo ""
  echo "=============================================="
  echo "Installation summary:"
  echo "  ✓ Installed: $installed"
  echo "  ⏭ Already present: $skipped"
  echo "  ✗ Failed: $failed"
  echo "=============================================="
  
  if [[ $failed -gt 0 ]]; then
    echo ""
    echo "Note: Some packages failed. This may be expected if:"
    echo "  - Package requires manual user interaction"
    echo "  - Package requires admin elevation"
    echo "  - Package name/ID changed in winget registry"
    return 1
  fi
  return 0
}

install_macos_packages() {
  echo "Installing packages via Homebrew..."
  echo ""
  
  # Check if Homebrew is installed
  if ! command -v brew &>/dev/null; then
    echo "[ERROR] Homebrew not found. Install from: https://brew.sh"
    return 1
  fi
  
  # Define macOS packages (Homebrew formulae)
  local -a macos_packages=(
    "gh"
    "aider"
    "jfrog-cli"
    "terraform"
    "tflint"
    "awscli"
    "azure-cli"
    "google-cloud-sdk"
  )
  
  local installed=0
  local skipped=0
  local failed=0
  
  for pkg in "${macos_packages[@]}"; do
    echo -n "[$pkg] "
    
    # Check if installed || install
    if brew list "$pkg" &>/dev/null 2>&1; then
      echo "✓ (already installed)"
      ((skipped++))
    elif brew install "$pkg" &>/dev/null 2>&1; then
      echo "✓ (installed)"
      ((installed++))
    else
      echo "✗ (failed)"
      ((failed++))
    fi
  done
  
  echo ""
  echo "=============================================="
  echo "Installation summary:"
  echo "  ✓ Installed: $installed"
  echo "  ⏭ Already present: $skipped"
  echo "  ✗ Failed: $failed"
  echo "=============================================="
  
  if [[ $failed -gt 0 ]]; then
    return 1
  fi
  return 0
}

install_linux_packages() {
  echo "Installing packages via system package manager..."
  echo ""
  
  # Detect package manager
  local pkg_manager="apt-get"
  local pkg_check_cmd="dpkg -l"
  
  if command -v dnf &>/dev/null; then
    pkg_manager="dnf"
    pkg_check_cmd="dnf list installed"
  elif command -v pacman &>/dev/null; then
    pkg_manager="pacman"
    pkg_check_cmd="pacman -Q"
  fi
  
  echo "Using package manager: $pkg_manager"
  echo ""
  
  # Define Linux packages
  local -a linux_packages=(
    "gh"
    "aider"
    "jfrog-cli"
    "terraform"
    "tflint"
    "awscli"
    "azure-cli"
    "google-cloud-sdk"
  )
  
  local installed=0
  local skipped=0
  local failed=0
  
  for pkg in "${linux_packages[@]}"; do
    echo -n "[$pkg] "
    
    # Check if installed || install
    if $pkg_check_cmd | grep -q "$pkg" &>/dev/null 2>&1; then
      echo "✓ (already installed)"
      ((skipped++))
    elif sudo $pkg_manager install -y "$pkg" &>/dev/null 2>&1; then
      echo "✓ (installed)"
      ((installed++))
    else
      echo "✗ (failed)"
      ((failed++))
    fi
  done
  
  echo ""
  echo "=============================================="
  echo "Installation summary:"
  echo "  ✓ Installed: $installed"
  echo "  ⏭ Already present: $skipped"
  echo "  ✗ Failed: $failed"
  echo "=============================================="
  
  if [[ $failed -gt 0 ]]; then
    return 1
  fi
  return 0
}

# ============================================================================
# ENTRY POINT
# ============================================================================

main "$@"
