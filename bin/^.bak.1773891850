#

# Shell environment detection function
detect_shell_environment() {
  # Default to POSIX if not detected
  export AGENCE_PATH_STYLE="${AGENCE_PATH_STYLE:-posix}"
  export AGENCE_OS_WINDOWS="${AGENCE_OS_WINDOWS:-0}"
  export AGENCE_OS_LINUX="${AGENCE_OS_LINUX:-0}"

  # Detect WSL (Windows Subsystem for Linux) — paths are /mnt/c/...
  if [[ -f /proc/version ]] && grep -qi "microsoft\|wsl" /proc/version 2>/dev/null; then
    export AGENCE_SHELL_ENV="wsl"
    export AGENCE_PATH_STYLE="wsl"
    export AGENCE_OS_LINUX=1
  fi

  # Detect git-bash / MSYS2 (MSYSTEM variable set) — paths are /c/...
  if [[ -n "${MSYSTEM:-}" ]]; then
    export AGENCE_SHELL_ENV="git-bash"
    export AGENCE_OS_WINDOWS=1
    export AGENCE_PATH_STYLE="mingw"
  fi

  # Detect PowerShell
  if [[ -n "${PSVersionTable+x}" ]] || [[ "$SHELL" == *"powershell"* ]]; then
    export AGENCE_SHELL_ENV="powershell"
    export AGENCE_PATH_STYLE="windows"
  fi

  [[ "${AGENCE_DEBUG:-0}" == "1" ]] && \
    echo "[DEBUG] Shell: ${AGENCE_SHELL_ENV:-posix}, Path style: $AGENCE_PATH_STYLE, OS: W=$AGENCE_OS_WINDOWS L=$AGENCE_OS_LINUX" >&2
}

# NOTE: This script is also copied as '^' for a quick shortcut and unified interface.
#       Any modifications to this file should be mirrored to '^' to ensure consistency.

detect_shell_environment

# ============================================================================
# CONFIGURATION & PATHS
# ============================================================================

# ^ToDo: Test the routing "@" directory symlinks. These may not work correctly on all OS shells.
# ^ToDo: Remove symlink creations and workarounds in ^init.

# Normalize paths to current shell environment
# Handles conversion between path styles based on detected environment
normalize_path() {
  local path="$1"

  # If cygwin, convert /cygdrive/c/ to /c/ (mingw style)
  if [[ "$AGENCE_PATH_STYLE" == "mingw" ]]; then
    if [[ "$path" == /* && "$path" != //*/ ]]; then
      path="/${path}"
    fi
    if [[ "$path" == /cygdrive/* ]]; then
      path="${path/\/cygdrive\//\/}"
    fi
  fi

  # If Windows (for PowerShell), convert to Windows style (C:\...)
  if [[ "$AGENCE_PATH_STYLE" == "windows" ]]; then
    if [[ "$path" == /* ]]; then
      local drive="${path:1:1}"
      local rest="${path:2}"
      path="${drive}:${rest//\//\\}"
    fi
  fi

  echo "$path"
}

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPT_DIR="$(normalize_path "$SCRIPT_DIR")"

AGENCE_ROOT="$(dirname "$SCRIPT_DIR")"
AGENCE_ROOT="$(normalize_path "$AGENCE_ROOT")"

AGENCE_BIN="$SCRIPT_DIR"
AGENCE_LIB="$AGENCE_ROOT/lib"
AGENCE_MODULES="$AGENCE_ROOT/modules"
AGENCE_CONFIG="${HOME}/.agence/config.yaml"

# Source utility functions (to be created)
source_if_exists() {
  [[ -f "$1" ]] && source "$1" || true
}

source_if_exists "$AGENCE_LIB/utils.sh"
source_if_exists "$AGENCE_LIB/logging.sh"
source_if_exists "$AGENCE_LIB/safeguards.sh"
source_if_exists "$AGENCE_LIB/router.sh"

# ============================================================================
# EXECUTION CONTEXT: Git Repo vs Agence Repo
# ============================================================================
# Critical: Prevent collisions when user and LLM share a shell window.
# Primary vars: AI_ROOT (agence repo), GIT_ROOT (parent project or same as AI_ROOT)
# Legacy aliases: AGENCE_ROOT, AGENCE_REPO, GIT_REPO kept for backwards compat.

init_execution_context() {
  # ── AI_ROOT ─────────────────────────────────────────────────────────────
  # Derived from SCRIPT_DIR (set via BASH_SOURCE above) — always correct
  # regardless of the caller's pwd or test sandbox directory.
  export AI_ROOT="${AI_ROOT:-$(normalize_path "$AGENCE_ROOT")}"
  export AI_BIN="${AI_BIN:-$SCRIPT_DIR}"

  # ── GIT_ROOT ─────────────────────────────────────────────────────────────
  # Detect from SCRIPT_DIR (not pwd) so sandbox/temp-dir invocations work.
  # Pattern: GIT_ROOT = git rev-parse --show-toplevel | sed -e 's/.://'
  if [[ -z "${GIT_ROOT:-}" ]]; then
    local detected_root
    detected_root=$(git -C "$SCRIPT_DIR" rev-parse --show-toplevel 2>/dev/null \
                    | sed -e 's/.://')
    if [[ -n "$detected_root" ]]; then
      export GIT_ROOT="$(normalize_path "$detected_root")"
    else
      # Fallback: standalone — use AI_ROOT as GIT_ROOT
      export GIT_ROOT="$AI_ROOT"
    fi
  else
    export GIT_ROOT="$(normalize_path "$GIT_ROOT")"
  fi

  # ── Backward-compat aliases ───────────────────────────────────────────────
  export AGENCE_ROOT="${AGENCE_ROOT:-$AI_ROOT}"
  export GIT_REPO="${GIT_REPO:-$GIT_ROOT}"
  export AGENCE_REPO="${AGENCE_REPO:-$AI_ROOT}"

  [[ "${DEBUG:-0}" == "1" ]] && echo "[DEBUG] AI_ROOT=$AI_ROOT  GIT_ROOT=$GIT_ROOT" >&2
}

source_if_exists "$AGENCE_LIB/utils.sh"
source_if_exists "$AGENCE_LIB/logging.sh"
source_if_exists "$AGENCE_LIB/safeguards.sh"
source_if_exists "$AGENCE_LIB/router.sh"

validate_execution_context() {
  # Validate that AI_ROOT and GIT_ROOT are initialised (CODEX LAW 2)
  # Note: pwd is intentionally NOT checked — that check was too strict for
  # CI/test sandboxes and subshell invocations. Var presence is sufficient.
  if [[ -z "${AI_ROOT:-}" ]]; then
    echo "[ERROR] AI_ROOT not set — execution context initialisation failed" >&2
    return 1
  fi
  if [[ -z "${GIT_ROOT:-}" ]]; then
    echo "[ERROR] GIT_ROOT not set — git detection failed" >&2
    return 1
  fi
  [[ "${DEBUG:-0}" == "1" ]] && echo "[DEBUG] Context OK: AI_ROOT=$AI_ROOT  GIT_ROOT=$GIT_ROOT" >&2
  return 0
}

# ============================================================================
# DEFAULTS
# ============================================================================

DEBUG="${AGENCE_DEBUG:-0}"
QUIET="${AGENCE_QUIET:-0}"

# Initialize and validate execution context before anything else
init_execution_context
if ! validate_execution_context; then
  exit 1
fi

# ============================================================================
# HELP / VERSION
# ============================================================================

show_version() {
  echo "Agence version 0.3.0"
}

show_help() {
  cat << 'EOF'
Agence: Agentic Engineering Collaboration Environment

USAGE:
  agence [COMMAND] [OPTIONS]

EXECUTION CONTEXT:
  Agence enforces strict execution context to prevent collisions when user 
  and LLM share a shell window. The following must be true:
  
  - GIT_REPO (parent repo, auto-detected or set manually)
  - AGENCE_REPO (always ~/.agence submodule)
  - pwd must be within one of these repos
  
  If context mismatch detected: Agence aborts with error.
  Set manually if needed: export GIT_REPO=/path/to/repo

MODES:
  help                         Show this help message
  version                      Show Agence version

COMMAND MODES:
  agence "<query>"             Chat with the LLM about your task
  agence +<request>            Ask LLM to route/plan action (autonomous mode)
  agence /<cmd>                Execute validated external command
  agence !<sys_cmd>            System command (bash/powershell utilities)
  agence ^<init_cmd>           Special initialization commands

EXAMPLES:
  agence "How do I deploy this to AWS?"
  agence +plan-vpc-infrastructure
  agence !status
  agence ^init
  agence ^session-list
  agence /terraform-plan
  agence /gitstatus

ENVIRONMENT VARIABLES:
  AGENCE_QUIET=1               Suppress non-essential output
  AGENCE_LLM_PROVIDER=claude   LLM provider (anthropic, openai, ollama)
  ANTHROPIC_API_KEY            API key for Claude

EOF
}

# ============================================================================
# MODE: CHAT
# ============================================================================
# Normal conversation with LLM
# Example: agence "How do I create a VPC in Terraform?"

mode_chat() {
  local query="$1"

  [[ "$DEBUG" == "1" ]] && echo "[DEBUG] Chat mode: $query" >&2

  # Load router
  router_load_config

  # Call LLM with context
  local response
  response=$(router_chat "$query") || {
    echo "Error: Failed to contact LLM" >&2
    return 1
  }

  echo "$response"
  return 0
}

# ============================================================================
# MODE: AI-ROUTED
# ============================================================================
# LLM analyzes request and decides action (autonomous)
# Example: agence +plan-terraform-module-for-vpc

mode_ai_routed() {
  local request="$1"

  [[ "$DEBUG" == "1" ]] && echo "[DEBUG] AI-routed mode: $request" >&2

  # Validate request for dangerous operators
  if ! validate_command "$request"; then
    return 1
  fi

  # Load router
  router_load_config

  # Call LLM in planning mode
  local plan
  plan=$(router_plan_action "$request") || {
    echo "Error: Failed to plan action" >&2
    return 1
  }

  # Parse plan (should contain: ACTION, CONFIDENCE, STEPS)
  local action confidence
  action=$(echo "$plan" | grep '^ACTION:' | awk '{print $2}')
  confidence=$(echo "$plan" | grep '^CONFIDENCE:' | awk '{print $2}')

  # Safety check: require human confirmation if confidence low
  if (( $(echo "$confidence < 0.65" | bc -l 2>/dev/null || echo 1) )); then
    echo "[WARN] Low confidence ($confidence). Showing plan:"
    echo "$plan"
    echo ""
    read -p "Proceed? [y/n] " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
      return 1
    fi
  fi

  # Route and execute
  case "$action" in
    git)
      router_execute git "$plan"
      ;;
    terraform)
      router_execute terraform "$plan"
      ;;
    cloud)
      router_execute cloud "$plan"
      ;;
    *)
      echo "Error: Unknown action type: $action" >&2
      return 1
      ;;
  esac

  return $?
}

# NOTE: router_chat / router_load_config / router_plan_action / router_list_providers
# are implemented in lib/router.sh (sourced above via source_if_exists).
# Do NOT add stubs here - they would shadow the real implementations.

# STUB: validate_command (placeholder — real validation in lib/safeguards.sh)
# ============================================================================
validate_command() {
  # Stub: always permit. Real implementation loaded from lib/safeguards.sh.
  return 0
}

# ============================================================================
# MODE: EXTERNAL COMMAND
# ============================================================================
# ==============================================================================
# GIT COMMAND ROUTER — AIPOLICY Tier Model
# Classifies git subcommands per codex/AIPOLICY.yaml whitelist/blacklist:
#   T0  auto-execute : whitelist (read-only, non-mutating)
#   T1  light-confirm: unclassified/unknown subcommands
#   T2  warn+confirm : blacklist (local/remote mutation)
#   T3  blocked      : dangerous/history-rewriting (require manual run)
# ==============================================================================
route_git_command() {
  local subcmd="${1:-}"
  shift || true
  local args=("$@")
  local repo_dir="${GIT_ROOT:-${GIT_REPO:-$(pwd)}}"

  if [[ -z "$subcmd" ]]; then
    cat >&2 <<'GITUSAGE'
Usage: agence /git <subcommand> [args...]

Git subcommand tiers (codex/AIPOLICY.yaml):
  T0 auto     : status log diff show branch tag describe reflog shortlog
                remote rev-parse symbolic-ref ls-files ls-tree blame grep
                cat-file ls-remote name-rev show-ref annotate
  T2 confirm  : commit push pull fetch merge rebase reset add checkout
                switch stash clean cherry-pick revert clone init
  T3 blocked  : filter-branch filter-repo gc bisect (run directly)

Examples:
  agence /git status
  agence /git log --oneline -10
  agence /git diff HEAD~1
  agence /git push --force-with-lease
GITUSAGE
    return 1
  fi

  local tier
  case "$subcmd" in
    # T0 — AIPOLICY.yaml whitelist: read-only, auto-execute
    status|log|diff|show|branch|tag|describe|reflog|shortlog|\
    remote|rev-parse|symbolic-ref|name-rev|show-ref|\
    ls-files|ls-tree|blame|grep|cat-file|ls-remote|\
    annotate|archive|format-patch|diff-tree|diff-index)
      tier="T0" ;;
    # T2 — AIPOLICY.yaml blacklist: mutation, warn + confirm
    commit|push|pull|fetch|merge|rebase|reset|checkout|switch|\
    add|stash|clean|cherry-pick|revert|clone|init|apply|am)
      tier="T2" ;;
    # T3 — Dangerous / history-rewriting: block, require manual run
    filter-branch|filter-repo|gc|bisect|worktree|submodule|\
    reflog-expire|prune|fsck|replace|notes)
      tier="T3" ;;
    # T1 — Unclassified: light confirm
    *)
      tier="T1" ;;
  esac

  case "$tier" in
    T0)
      [[ "${DEBUG:-0}" == "1" ]] && echo "[AIPOLICY T0] git $subcmd${args[*]:+ ${args[*]}}" >&2
      git -C "$repo_dir" "$subcmd" "${args[@]}"
      return $?
      ;;
    T1)
      echo "[AIPOLICY T1] Unclassified: git $subcmd${args[*]:+ ${args[*]}}" >&2
      read -p "Execute in $(basename "$repo_dir")? [y/N] " -r _gc; echo
      [[ $_gc =~ ^[Yy]$ ]] || { echo "[CANCELLED]" >&2; return 1; }
      git -C "$repo_dir" "$subcmd" "${args[@]}"
      return $?
      ;;
    T2)
      echo "[AIPOLICY T2] Mutation: git $subcmd${args[*]:+ ${args[*]}}" >&2
      echo "[WARN] This operation mutates local/remote state." >&2
      read -p "Confirm git $subcmd in $(basename "$repo_dir")? [y/N] " -r _gc; echo
      [[ $_gc =~ ^[Yy]$ ]] || { echo "[CANCELLED]" >&2; return 1; }
      git -C "$repo_dir" "$subcmd" "${args[@]}"
      return $?
      ;;
    T3)
      echo "[AIPOLICY T3] BLOCKED: 'git $subcmd' is a privileged operation." >&2
      echo "[ESCALATION REQUIRED] Run directly if certain:" >&2
      printf "  git -C %q %s%s\n" "$repo_dir" "$subcmd" "${args[*]:+ ${args[*]}}" >&2
      return 1
      ;;
  esac
}

# ==============================================================================
# GITHUB CLI COMMAND ROUTER — AIPOLICY Tier Model
# Classifies gh subcommands per codex/AIPOLICY.yaml whitelist/blacklist.
# All args passed intact to 'gh', including --help (always bypasses tier).
#   T0  auto-execute : whitelist (read-only, non-mutating)
#   T1  light-confirm: unclassified/unknown subcommands
#   T2  warn+confirm : blacklist (remote GitHub state mutation)
# ==============================================================================
route_gh_command() {
  # route_gh_command <gh-subcmd> [<action>] [<args...>]
  # $@ is passed intact to 'gh' for the final call.
  local subcmd="${1:-}"
  local action="${2:-}"   # peek for tier; not shifted — $@ stays intact

  if [[ -z "$subcmd" ]]; then
    gh --help
    return $?
  fi

  # --help / -h always passes through regardless of tier
  local _arg
  for _arg in "$@"; do
    if [[ "$_arg" == "--help" || "$_arg" == "-h" ]]; then
      gh "$@"; return $?
    fi
  done

  local tier
  case "$subcmd" in
    repo)
      case "$action" in
        view|list|search|clone|sync|"")              tier="T0" ;;
        create|delete|rename|edit|archive|fork)      tier="T2" ;;
        *)                                           tier="T1" ;;
      esac ;;
    pr)
      case "$action" in
        list|view|status|checks|diff|comment|"")     tier="T0" ;;
        merge|close|edit|ready|reopen|review|create) tier="T2" ;;
        *)                                           tier="T1" ;;
      esac ;;
    issue)
      case "$action" in
        list|view|comment|"")                        tier="T0" ;;
        close|create|edit|delete|reopen|pin|lock)    tier="T2" ;;
        *)                                           tier="T1" ;;
      esac ;;
    run)
      case "$action" in
        list|view|download|watch|"")                 tier="T0" ;;
        cancel|rerun|delete)                         tier="T2" ;;
        *)                                           tier="T1" ;;
      esac ;;
    workflow)
      case "$action" in
        list|view|"")                                tier="T0" ;;
        run|enable|disable)                          tier="T2" ;;
        *)                                           tier="T1" ;;
      esac ;;
    auth)
      case "$action" in
        status|token|"")                             tier="T0" ;;
        login|logout|refresh|setup-git)              tier="T2" ;;
        *)                                           tier="T1" ;;
      esac ;;
    api)
      # Default HTTP method is GET (T0); --method POST/PUT/PATCH/DELETE → T2
      local _meth="GET" _want_meth=false
      for _arg in "$@"; do
        if [[ "$_want_meth" == true ]]; then _meth="$_arg"; break; fi
        [[ "$_arg" == "--method" ]] && _want_meth=true
      done
      case "$_meth" in
        GET)                   tier="T0" ;;
        POST|PUT|PATCH|DELETE) tier="T2" ;;
        *)                     tier="T1" ;;
      esac ;;
    release)
      case "$action" in
        list|view|download|"")                       tier="T0" ;;
        create|delete|edit|upload)                   tier="T2" ;;
        *)                                           tier="T1" ;;
      esac ;;
    org|gist|browse|search|codespace)                tier="T0" ;;
    secret|variable)                                 tier="T2" ;;  # always — CI/CD secrets
    *)                                               tier="T1" ;;
  esac

  case "$tier" in
    T0)
      [[ "${DEBUG:-0}" == "1" ]] && echo "[AIPOLICY T0] gh $*" >&2
      gh "$@"
      return $?
      ;;
    T1)
      echo "[AIPOLICY T1] Unclassified: gh $subcmd ${action:+$action ...}" >&2
      read -p "Execute gh $subcmd? [y/N] " -r _gc; echo
      [[ $_gc =~ ^[Yy]$ ]] || { echo "[CANCELLED]" >&2; return 1; }
      gh "$@"
      return $?
      ;;
    T2)
      echo "[AIPOLICY T2] Mutation: gh $subcmd ${action:+$action ...}" >&2
      echo "[WARN] This operation mutates remote GitHub state." >&2
      read -p "Confirm gh $subcmd ${action:+$action}? [y/N] " -r _gc; echo
      [[ $_gc =~ ^[Yy]$ ]] || { echo "[CANCELLED]" >&2; return 1; }
      gh "$@"
      return $?
      ;;
  esac
}

# ==============================================================================
# TERRAFORM COMMAND ROUTER — AIPOLICY Tier Model
# Classifies terraform subcommands per codex/AIPOLICY.yaml:
#   T0  auto-execute : whitelist (read-only / non-destructive: validate, fmt,
#                      version, providers, show, graph, output, login, plan,
#                      init [no --upgrade], state list/show/pull)
#   T1  light-confirm: unclassified/unknown subcommands
#   T2  warn+confirm : restricted (state mutation: apply, init --upgrade,
#                      import, taint, workspace changes, state mv/rm)
#   T3  blocked      : HIGHEST ESCALATION — destroy operations only
#                      (apply --destroy, destroy) — run manually after review
# ==============================================================================
route_tf_command() {
  local subcmd="${1:-}"
  shift || true
  local args=("$@")
  local work_dir="${GIT_ROOT:-$(pwd)}"

  if [[ -z "$subcmd" ]]; then
    cat >&2 <<'TFUSAGE'
Usage: agence /tf <subcommand> [args...]

Terraform subcommand tiers (codex/AIPOLICY.yaml):
  T0 auto     : validate fmt version providers show graph output
                login plan state(list/show/pull) init[no --upgrade]
  T1 confirm  : (unclassified subcommands)
  T2 confirm  : apply  init --upgrade  import  taint  untaint
                refresh  workspace  state(mv/rm/push/replace-provider)
  T3 blocked  : destroy  apply --destroy  (HIGHEST ESCALATION — run manually)

Shortcuts:
  agence /tfvalidate             terraform validate
  agence /tfauth                 terraform login
  agence /tflogin                terraform login
  agence /tfplan [args]          terraform plan [args]
  agence /tfinit [args]          terraform init (no --upgrade)
  agence /tfupgrade              terraform init --upgrade   [T2]
  agence /tfapply [args]         terraform apply [args]     [T2]
  agence /tfdestroy              terraform apply --destroy  [T3 BLOCKED]
  agence /tflint [args]          tflint [args]
  agence /precommit [args]       pre-commit run [args]
TFUSAGE
    return 1
  fi

  # Scan args for escalating flags
  local has_upgrade=false has_destroy=false
  for _a in "${args[@]}"; do
    [[ "$_a" == "--upgrade"  || "$_a" == "-upgrade"  ]] && has_upgrade=true
    [[ "$_a" == "--destroy"  || "$_a" == "-destroy"  ]] && has_destroy=true
  done

  local tier
  case "$subcmd" in
    # T0 — read-only / non-destructive
    validate|fmt|version|providers|show|graph|output|login|console)
      tier="T0" ;;
    plan)
      tier="T0" ;;
    init)
      [[ "$has_upgrade" == "true" ]] && tier="T2" || tier="T0" ;;
    state)
      case "${args[0]:-}" in
        list|show|pull|"")              tier="T0" ;;
        mv|rm|push|replace-provider|\
        force-unlock)                   tier="T2" ;;
        *)                              tier="T1" ;;
      esac ;;
    # T2 — infrastructure mutation
    apply)
      [[ "$has_destroy" == "true" ]] && tier="T3" || tier="T2" ;;
    import|taint|untaint|refresh|workspace)
      tier="T2" ;;
    # T3 — HIGHEST ESCALATION: destroy
    destroy)
      tier="T3" ;;
    # T1 — unclassified
    *)
      tier="T1" ;;
  esac

  # Verify terraform is available (all tiers)
  if ! command -v terraform &>/dev/null; then
    echo "Error: terraform not found. Install: agence ^install" >&2
    return 1
  fi

  case "$tier" in
    T0)
      [[ "${DEBUG:-0}" == "1" ]] && \
        echo "[AIPOLICY T0] terraform $subcmd${args[*]:+ ${args[*]}}" >&2
      terraform "$subcmd" "${args[@]}"
      return $?
      ;;
    T1)
      echo "[AIPOLICY T1] Unclassified: terraform $subcmd${args[*]:+ ${args[*]}}" >&2
      read -p "Execute? [y/N] " -r _tc; echo
      [[ $_tc =~ ^[Yy]$ ]] || { echo "[CANCELLED]" >&2; return 1; }
      terraform "$subcmd" "${args[@]}"
      return $?
      ;;
    T2)
      echo "[AIPOLICY T2] Restricted: terraform $subcmd${args[*]:+ ${args[*]}}" >&2
      echo "[WARN] This operation mutates infrastructure state." >&2
      read -p "Confirm terraform $subcmd${args[*]:+ ${args[*]}}? [y/N] " -r _tc; echo
      [[ $_tc =~ ^[Yy]$ ]] || { echo "[CANCELLED]" >&2; return 1; }
      terraform "$subcmd" "${args[@]}"
      return $?
      ;;
    T3)
      echo "[AIPOLICY T3] BLOCKED: HIGHEST ESCALATION — destroy operation." >&2
      echo "[DESTROY] 'terraform $subcmd${args[*]:+ ${args[*]}}' will permanently destroy infrastructure." >&2
      echo "[ESCALATION REQUIRED] Review 'agence /tfplan' output, then run manually if certain:" >&2
      if [[ "$has_destroy" == "true" || "$subcmd" == "destroy" ]]; then
        printf "  terraform -chdir=%q apply --destroy\n" "$work_dir" >&2
      else
        printf "  terraform -chdir=%q %s%s\n" "$work_dir" "$subcmd" "${args[*]:+ ${args[*]}}" >&2
      fi
      return 1
      ;;
  esac
}

# Execute pre-approved external commands
# Example: agence /terraform-plan

mode_external() {
  local cmd_request="$1"

  [[ "$DEBUG" == "1" ]] && echo "[DEBUG] External mode: $cmd_request" >&2

  # Validate command for dangerous operators
  if ! validate_command "$cmd_request"; then
    return 1
  fi

  # =========================================================================
  # REPO COMMANDS (act on $GIT_REPO)
  # =========================================================================
  case "$cmd_request" in
    ghauth)
      # GitHub CLI auth status
      bash "$AGENCE_ROOT/bin/aido" gh auth status
      return $?
      ;;
    ghlogin)
      # GitHub CLI login (interactive)
      echo "[INFO] Starting GitHub CLI login..." >&2
      gh auth login
      return $?
      ;;
    gitstatus)
      # Git status in $GIT_REPO (read-only, safe)
      bash "$AGENCE_ROOT/bin/aido" git status
      return $?
      ;;
    commit)
      # Commit all tracked changes in $GIT_REPO
      echo "[WARN] This will commit all staged changes to $GIT_REPO" >&2
      read -p "Enter commit message: " commit_msg
      if [[ -z "$commit_msg" ]]; then
        echo "Error: Commit message required" >&2
        return 1
      fi
      git -C "$GIT_REPO" commit -m "$commit_msg"
      return $?
      ;;
    push)
      # Push changes to origin (sets upstream on first push)
      echo "[WARN] This will push changes from $GIT_REPO to origin" >&2
      read -p "Confirm push to origin? [y/N] " confirm
      if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
        echo "[CANCELLED] Push aborted" >&2
        return 1
      fi
      git -C "$GIT_REPO" push -u origin
      return $?
      ;;
    ghstatus)
      # GitHub CLI: show repo and PR status
      echo "[INFO] Repository status:" >&2
      bash "$AGENCE_ROOT/bin/aido" gh repo view
      echo && echo "[INFO] Pull requests:" >&2
      bash "$AGENCE_ROOT/bin/aido" gh pr list --limit 5
      return $?
      ;;
    ghcommit)
      # GitHub CLI: Commit changes (similar to /commit but with gh auth)
      echo "[WARN] This will commit all staged changes using gh auth" >&2
      read -p "Enter commit message: " commit_msg
      if [[ -z "$commit_msg" ]]; then
        echo "Error: Commit message required" >&2
        return 1
      fi
      # Verify gh is authenticated
      if ! bash "$AGENCE_ROOT/bin/aido" gh auth status &>/dev/null; then
        echo "Error: Not authenticated with gh. Run: agence /ghlogin" >&2
        return 1
      fi
      git -C "$GIT_REPO" commit -m "$commit_msg"
      return $?
      ;;
    ghpush)
      # GitHub CLI: Push changes (uses gh's authentication)
      echo "[WARN] This will push changes using GitHub CLI auth" >&2
      read -p "Confirm push to origin? [y/N] " confirm
      if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
        echo "[CANCELLED] Push aborted" >&2
        return 1
      fi
      # Verify gh is authenticated
      if ! bash "$AGENCE_ROOT/bin/aido" gh auth status &>/dev/null; then
        echo "Error: Not authenticated with gh. Run: agence /ghlogin" >&2
        return 1
      fi
      git -C "$GIT_REPO" push -u origin
      return $?
      ;;

    # -------------------------------------------------------------------------
    # GITHUB CLI SHORTCUTS — routed through route_gh_command (AIPOLICY tiers)
    # -------------------------------------------------------------------------
    # /gh          → generic /gh <subcmd> [args...] with full tier routing
    # /ghremote    → T0  gh repo view (show current repo info)
    # /ghrepo      → T0/T2 gh repo <subcmd> [args...]
    # /ghpull      → T0  gh pr list (default) | T2 gh pr <subcmd> [args...]
    # /ghlog       → T0  gh run list (GitOps run history)
    # /ghmerge     → T2  gh pr merge [args...] (confirmation required)
    # /ghrun       → T0  gh run list (default) | T0/T2 gh run <subcmd> [args...]
    # /ghflow      → T0  gh workflow list (default) | T0/T2 gh workflow <subcmd>
    # /ghissue     → T0  gh issue list (default) | T0/T2 gh issue <subcmd> [args...]
    # /ghorg       → T0  gh org list
    # All pass args intact to 'gh', including --help.
    # NOTE: ghauth/ghlogin/ghstatus/ghcommit/ghpush handled above (legacy).
    # -------------------------------------------------------------------------
    gh)
      # Generic: agence /gh <subcmd> [args...]
      route_gh_command "${@:2}"
      return $?
      ;;
    ghremote)
      # gh repo view — show current/named repo info (T0)
      route_gh_command "repo" "view" "${@:2}"
      return $?
      ;;
    ghrepo)
      # gh repo <subcmd> [args...] — full repo management
      route_gh_command "repo" "${@:2}"
      return $?
      ;;
    ghpull)
      # gh pr list (default) or gh pr <action> [args...]
      # /ghpull           → T0 gh pr list
      # /ghpull view 42   → T0 gh pr view 42
      # /ghpull merge 42  → T2 gh pr merge 42 (warn+confirm)
      if [[ -z "${2:-}" ]]; then
        route_gh_command "pr" "list"
      else
        route_gh_command "pr" "${@:2}"
      fi
      return $?
      ;;
    ghlog)
      # gh run list — GitOps actions run history (T0)
      route_gh_command "run" "list" "${@:2}"
      return $?
      ;;
    ghmerge)
      # gh pr merge [args...] — T2 confirmation required
      route_gh_command "pr" "merge" "${@:2}"
      return $?
      ;;
    ghrun)
      # gh run list (default) or gh run <subcmd> [args...]
      if [[ -z "${2:-}" ]]; then
        route_gh_command "run" "list"
      else
        route_gh_command "run" "${@:2}"
      fi
      return $?
      ;;
    ghflow)
      # gh workflow list (default) or gh workflow <subcmd> [args...]
      if [[ -z "${2:-}" ]]; then
        route_gh_command "workflow" "list"
      else
        route_gh_command "workflow" "${@:2}"
      fi
      return $?
      ;;
    ghissue)
      # gh issue list (default) or gh issue <subcmd> [args...]
      if [[ -z "${2:-}" ]]; then
        route_gh_command "issue" "list"
      else
        route_gh_command "issue" "${@:2}"
      fi
      return $?
      ;;
    ghorg)
      # gh org list — T0 read-only
      route_gh_command "org" "list" "${@:2}"
      return $?
      ;;

    # -------------------------------------------------------------------------
    # GIT SHORTCUTS — routed through route_git_command (AIPOLICY tier model)
    # -------------------------------------------------------------------------
    # /status  → T0 auto-execute  (AIPOLICY whitelist, pure read-only)
    # /log     → T0 auto-execute  (AIPOLICY whitelist, pure read-only)
    # /remote  → T0 auto-execute  (AIPOLICY whitelist, pure read-only)
    # /fetch   → T2 warn+confirm  (AIPOLICY blacklist, mutates .git/refs)
    # /pull    → T2 warn+confirm  (AIPOLICY blacklist, merges remote state)
    # /push    → handled above    (existing handler with interactive prompt)
    # /commit  → handled above    (existing handler with message prompt)
    # /git     → generic: /git <subcmd> [args...] with full tier routing
    # NOTE: aider also uses /git and /commit in its own REPL — different
    #       tool context, no runtime collision with agence shortcuts.
    # -------------------------------------------------------------------------
    git)
      # Generic: agence /git <subcmd> [args...]
      # Passes all remaining args to route_git_command for tier-based dispatch
      route_git_command "${@:2}"
      return $?
      ;;
    status|log|remote|fetch|pull)
      # Shortcuts: delegate to route_git_command with cmd_request as subcmd
      route_git_command "$cmd_request" "${@:2}"
      return $?
      ;;

    # -------------------------------------------------------------------------
    # TERRAFORM SHORTCUTS — routed through route_tf_command (AIPOLICY tiers)
    # -------------------------------------------------------------------------
    # /tf           → generic /tf <subcmd> [args...] with full AIPOLICY routing
    # /tfvalidate   → T0  terraform validate
    # /tfauth       → T0  terraform login  (auth check / registry login)
    # /tflogin      → T0  terraform login  (alias for tfauth)
    # /tfplan       → T0  terraform plan [args...]
    # /tfinit       → T0  terraform init   (without --upgrade)
    # /tflint       → T0  tflint [args...]
    # /tfupgrade    → T2  terraform init --upgrade   (warn+confirm)
    # /tfapply      → T2  terraform apply [args...]  (warn+confirm)
    # /tfdestroy    → T3  terraform apply --destroy  (HIGHEST ESCALATION — BLOCKED)
    # /precommit    → T0  pre-commit run [args...]   (code quality hooks)
    # -------------------------------------------------------------------------
    tf)
      # Generic: agence /tf <subcmd> [args...]
      route_tf_command "${@:2}"
      return $?
      ;;
    tfvalidate)
      # T0: terraform validate
      route_tf_command "validate" "${@:2}"
      return $?
      ;;
    tfauth|tflogin)
      # T0: terraform login — auth check / Terraform Cloud/registry login
      route_tf_command "login" "${@:2}"
      return $?
      ;;
    tfplan)
      # T0: terraform plan (non-destructive, shows change set only)
      route_tf_command "plan" "${@:2}"
      return $?
      ;;
    tfinit)
      # T0: terraform init (no --upgrade flag)
      route_tf_command "init" "${@:2}"
      return $?
      ;;
    tfupgrade)
      # T2: terraform init --upgrade (restricted — confirm required)
      route_tf_command "init" "--upgrade" "${@:2}"
      return $?
      ;;
    tfapply)
      # T2: terraform apply (restricted — warn+confirm required)
      route_tf_command "apply" "${@:2}"
      return $?
      ;;
    tfdestroy)
      # T3: terraform apply --destroy (HIGHEST ESCALATION — BLOCKED, run manually)
      route_tf_command "apply" "--destroy" "${@:2}"
      return $?
      ;;
    tflint)
      # T0: tflint — Terraform linter
      if ! command -v tflint &>/dev/null; then
        echo "Error: tflint not found. Install: agence ^install" >&2
        return 1
      fi
      tflint "${@:2}"
      return $?
      ;;
    precommit)
      # T0: pre-commit — code quality hooks (pre-commit run [--all-files])
      if command -v pre-commit &>/dev/null; then
        pre-commit run "${@:2}"
      else
        # Fallback: run .git/hooks/pre-commit directly if present
        local hook="${GIT_ROOT:-$(pwd)}/.git/hooks/pre-commit"
        if [[ -x "$hook" ]]; then
          "$hook" "${@:2}"
        else
          echo "Error: pre-commit not found. Install: pip install pre-commit" >&2
          return 1
        fi
      fi
      return $?
      ;;
    # -------------------------------------------------------------------------
    # LLM ROUTER SHORTCUTS
    # -------------------------------------------------------------------------
    providers)
      # List all configured/available LLM providers and active model
      router_list_providers
      return $?
      ;;
  esac

  # Load permitted commands from config/commands.json
  local commands_file="$AGENCE_ROOT/bin/commands.json"
  
  if [[ ! -f "$commands_file" ]]; then
    echo "Error: No commands.json found" >&2
    return 1
  fi

  # Check if command is allowed
  local command_allowed
  if command -v jq &>/dev/null; then
    command_allowed=$(jq -r ".\"$cmd_request\" // false" "$commands_file")
  else
    # Fallback if jq not available: simple grep
    command_allowed=$(grep -q "\"$cmd_request\"" "$commands_file" && echo "true" || echo "false")
  fi

  if [[ "$command_allowed" != "true" ]]; then
    echo "Error: Command not allowed: $cmd_request" >&2
    return 1
  fi

  # Log the execution
  echo "[INFO] Executing: $cmd_request" >&2

  # Route to appropriate module
  case "$cmd_request" in
    terraform-*)
      "$AGENCE_MODULES/iac/iac.sh" terraform "${cmd_request#terraform-}"
      ;;
    git-*)
      "$AGENCE_MODULES/git/git.sh" "${cmd_request#git-}"
      ;;
    aws-*)
      "$AGENCE_MODULES/cloud/aws.sh" "${cmd_request#aws-}"
      ;;
    *)
      echo "Error: Unknown command category: $cmd_request" >&2
      return 1
      ;;
  esac

  return $?
}

# ============================================================================
# MODE: SPECIAL INITIALIZATION
# ============================================================================
# Initialize Agence environment and create required symlinks
# Example: agence ^init

mode_init() {
  local init_cmd="$1"

  [[ "$DEBUG" == "1" ]] && echo "[DEBUG] Init mode: $init_cmd" >&2

  case "$init_cmd" in
    "init"|"")
      init_agence_environment
      ;;
    "reload")
      reload_agence_context
      ;;
    "install")
      install_agence_packages
      ;;
    "session-list")
      # Advanced session list feature
      local sessions_dir="$GIT_REPO/.agence-sessions"
      mkdir -p "$sessions_dir"
      echo "[SESSION LIST] Active sessions:"
      local count=0
      for meta in "$sessions_dir"/*.meta.json; do
        [[ ! -f "$meta" ]] && continue
        local sid=$(jq -r '.session_id // .sessionID' "$meta" 2>/dev/null)
        local agent=$(jq -r '.agent_id // .agentID' "$meta" 2>/dev/null)
        local role=$(jq -r '.role' "$meta" 2>/dev/null)
        local ts=$(jq -r '.timestamp' "$meta" 2>/dev/null)
        local owner=$(jq -r '.owner // empty' "$meta" 2>/dev/null)
        local assigned=$(jq -r '.assigned // empty' "$meta" 2>/dev/null)
        echo "  - $sid  agent=$agent  role=$role  started=$ts  owner=${owner:-n/a}  assigned=${assigned:-n/a}"
        ((count++))
      done
      [[ $count -eq 0 ]] && echo "  (no sessions found)"
      ;;
    "session-attach")
      # Attach to a session by session_id
      local sid="$2"
      local sessions_dir="$GIT_REPO/.agence-sessions"
      local meta="$sessions_dir/$sid.meta.json"
      if [[ -z "$sid" ]]; then
        echo "Usage: ^session-attach <session_id>"
        return 1
      fi
      if [[ -f "$meta" ]]; then
        echo "Attaching to session $sid..."
        export AGENCE_SESSION_ID="$sid"
        export AGENCE_AGENT_ID=$(jq -r '.agent_id // .agentID' "$meta" 2>/dev/null)
        export AGENCE_SESSION_TYPE=$(jq -r '.role' "$meta" 2>/dev/null)
        echo "[INFO] Environment variables set for session $sid."
      else
        echo "Session $sid not found."
      fi
      ;;
    "session-detach")
      # Detach from current session
      unset AGENCE_SESSION_ID AGENCE_AGENT_ID AGENCE_SESSION_TYPE
      echo "[INFO] Detached from session."
      ;;
    "session-handoff"|"session-assign")
      # Assign or handoff a session to another agent/user
      local sid="$2"
      local new_owner="$3"
      local sessions_dir="$GIT_REPO/.agence-sessions"
      local meta="$sessions_dir/$sid.meta.json"
      if [[ -z "$sid" || -z "$new_owner" ]]; then
        echo "Usage: ^session-handoff <session_id> <new_owner>"
        return 1
      fi
      if [[ -f "$meta" ]]; then
        tmpfile=$(mktemp)
        jq --arg owner "$new_owner" '.owner = $owner' "$meta" > "$tmpfile" && mv "$tmpfile" "$meta"
        echo "Session $sid assigned to $new_owner."
      else
        echo "Session $sid not found."
      fi
      ;;
    "session-pause")
      # Pause a session by marking its state
      local sid="$2"
      local sessions_dir="$GIT_REPO/.agence-sessions"
      local meta="$sessions_dir/$sid.meta.json"
      if [[ -z "$sid" ]]; then
        echo "Usage: ^session-pause <session_id>"
        return 1
      fi
      if [[ -f "$meta" ]]; then
        tmpfile=$(mktemp)
        jq '.state = "paused"' "$meta" > "$tmpfile" && mv "$tmpfile" "$meta"
        echo "Session $sid paused."
      else
        echo "Session $sid not found."
      fi
      ;;
    "session-resume")
      # Resume a paused session
      local sid="$2"
      local sessions_dir="$GIT_REPO/.agence-sessions"
      local meta="$sessions_dir/$sid.meta.json"
      if [[ -z "$sid" ]]; then
        echo "Usage: ^session-resume <session_id>"
        return 1
      fi
      if [[ -f "$meta" ]]; then
        tmpfile=$(mktemp)
        jq '.state = "active"' "$meta" > "$tmpfile" && mv "$tmpfile" "$meta"
        echo "Session $sid resumed."
      else
        echo "Session $sid not found."
      fi
      ;;
    "session-export")
      # Export session state to a file
      local sid="$2"
      local outfile="$3"
      local sessions_dir="$GIT_REPO/.agence-sessions"
      local meta="$sessions_dir/$sid.meta.json"
      if [[ -z "$sid" || -z "$outfile" ]]; then
        echo "Usage: ^session-export <session_id> <output_file>"
        return 1
      fi
      if [[ -f "$meta" ]]; then
        cp "$meta" "$outfile"
        echo "Session $sid exported to $outfile."
      else
        echo "Session $sid not found."
      fi
      ;;
    "session-import")
      # Import session state from a file
      local infile="$2"
      local sid="$3"
      local sessions_dir="$GIT_REPO/.agence-sessions"
      if [[ -z "$infile" || -z "$sid" ]]; then
        echo "Usage: ^session-import <input_file> <session_id>"
        return 1
      fi
      if [[ -f "$infile" ]]; then
        cp "$infile" "$sessions_dir/$sid.meta.json"
        echo "Session $sid imported from $infile."
      else
        echo "Input file $infile not found."
      fi
      ;;
    "session-replay")
      # Replay session history (show chronological log if available)
      local sid="$2"
      local sessions_dir="$GIT_REPO/.agence-sessions"
      local log="$sessions_dir/$sid.log"
      if [[ -z "$sid" ]]; then
        echo "Usage: ^session-replay <session_id>"
        return 1
      fi
      if [[ -f "$log" ]]; then
        echo "=== Session $sid Replay ==="
        cat "$log"
        echo "=== End of Replay ==="
      else
        echo "No replay log found for session $sid."
      fi
      ;;
    "session-kill")
      # Kill (terminate) a session by deleting its metadata and log
      local sid="$2"
      local sessions_dir="$GIT_REPO/.agence-sessions"
      local meta="$sessions_dir/$sid.meta.json"
      local log="$sessions_dir/$sid.log"
      if [[ -z "$sid" ]]; then
        echo "Usage: ^session-kill <session_id>"
        return 1
      fi
      local deleted=0
      if [[ -f "$meta" ]]; then
        rm -f "$meta"
        ((deleted++))
      fi
      if [[ -f "$log" ]]; then
        rm -f "$log"
        ((deleted++))
      fi
      if [[ $deleted -gt 0 ]]; then
        echo "Session $sid killed and files removed."
      else
        echo "Session $sid not found."
      fi
      ;;
    "session-delete")
      # Alias for session-kill
      local sid="$2"
      "$0" ^session-kill "$sid"
      ;;
    "session-prune")
      # Prune old sessions (delete meta/log files older than 30 days)
      local sessions_dir="$GIT_REPO/.agence-sessions"
      find "$sessions_dir" -name '*.meta.json' -mtime +30 -exec rm {} \;
      find "$sessions_dir" -name '*.log' -mtime +30 -exec rm {} \;
      echo "Pruned sessions older than 30 days."
      ;;
    "session-status"|"session-inspect")
      # Show detailed session info
      local sid="$2"
      local sessions_dir="$GIT_REPO/.agence-sessions"
      local meta="$sessions_dir/$sid.meta.json"
      local log="$sessions_dir/$sid.log"
      if [[ -z "$sid" ]]; then
        echo "Usage: ^session-status <session_id>"
        return 1
      fi
      if [[ -f "$meta" ]]; then
        echo "=== Session $sid Metadata ==="
        cat "$meta"
        echo "=== Session $sid Log ==="
        [[ -f "$log" ]] && cat "$log" || echo "(no log found)"
        echo "=== End of Session Info ==="
      else
        echo "Session $sid not found."
      fi
      ;;
    "session-audit"|"session-log")
      # Show session audit log (actions/events)
      local sid="$2"
      local sessions_dir="$GIT_REPO/.agence-sessions"
      local audit="$sessions_dir/$sid.audit.log"
      if [[ -z "$sid" ]]; then
        echo "Usage: ^session-audit <session_id>"
        return 1
      fi
      if [[ -f "$audit" ]]; then
        echo "=== Session $sid Audit Log ==="
        cat "$audit"
        echo "=== End of Audit Log ==="
      else
        echo "No audit log found for session $sid."
      fi
      ;;
    "session-migrate")
      # Migrate session to another environment (copy meta/log/audit to target dir)
      local sid="$2"
      local target_dir="$3"
      local sessions_dir="$GIT_REPO/.agence-sessions"
      if [[ -z "$sid" || -z "$target_dir" ]]; then
        echo "Usage: ^session-migrate <session_id> <target_dir>"
        return 1
      fi
      mkdir -p "$target_dir"
      local files=("$sessions_dir/$sid.meta.json" "$sessions_dir/$sid.log" "$sessions_dir/$sid.audit.log")
      local copied=0
      for f in "${files[@]}"; do
        if [[ -f "$f" ]]; then
          cp "$f" "$target_dir/"
          ((copied++))
        fi
      done
      if [[ $copied -gt 0 ]]; then
        echo "Session $sid migrated to $target_dir."
      else
        echo "No session files found for $sid."
      fi
      ;;
    "session-snapshot")
      # Create a snapshot (backup) of session files
      local sid="$2"
      local snapshot_dir="$3"
      local sessions_dir="$GIT_REPO/.agence-sessions"
      if [[ -z "$sid" || -z "$snapshot_dir" ]]; then
        echo "Usage: ^session-snapshot <session_id> <snapshot_dir>"
        return 1
      fi
      mkdir -p "$snapshot_dir"
      local files=("$sessions_dir/$sid.meta.json" "$sessions_dir/$sid.log" "$sessions_dir/$sid.audit.log")
      local snap_count=0
      for f in "${files[@]}"; do
        if [[ -f "$f" ]]; then
          cp "$f" "$snapshot_dir/"
          ((snap_count++))
        fi
      done
      if [[ $snap_count -gt 0 ]]; then
        echo "Session $sid snapshot saved to $snapshot_dir."
      else
        echo "No session files found for $sid."
      fi
      ;;
    "session-restore")
      # Restore session files from a snapshot
      local sid="$2"
      local snapshot_dir="$3"
      local sessions_dir="$GIT_REPO/.agence-sessions"
      if [[ -z "$sid" || -z "$snapshot_dir" ]]; then
        echo "Usage: ^session-restore <session_id> <snapshot_dir>"
        return 1
      fi
      local files=("$sid.meta.json" "$sid.log" "$sid.audit.log")
      local restored=0
      for f in "${files[@]}"; do
        if [[ -f "$snapshot_dir/$f" ]]; then
          cp "$snapshot_dir/$f" "$sessions_dir/"
          ((restored++))
        fi
      done
      if [[ $restored -gt 0 ]]; then
        echo "Session $sid restored from $snapshot_dir."
      else
        echo "No snapshot files found for $sid in $snapshot_dir."
      fi
      ;;
    *)
      echo "Error: Unknown init command: $init_cmd" >&2
      return 1
      ;;
  esac

  return $?
}

init_agence_environment() {
  [[ "$DEBUG" == "1" ]] && echo "[DEBUG] Initializing Agence environment..." >&2

  echo ""
  echo "=============================================="
  echo "  AGENCE INITIALIZATION (^init)"
  echo "=============================================="
  echo ""

  # Step 1: Source .agencerc to set up environment
  echo "Step 1: Loading Agence profile (.agencerc)..."

  local agencerc_path="$AGENCE_REPO/bin/.agencerc"
  if [[ -f "$agencerc_path" ]]; then
    source "$agencerc_path" 2>/dev/null
    if [[ $? -eq 0 ]]; then
      echo "✓ Profile loaded (Shell: $CURRENT_SHELL, REPO_ROOT: $REPO_ROOT)"
    else
      echo "⚠ Profile loaded but with warnings"
    fi
  else
    echo "[WARN] .agencerc not found at $agencerc_path"
  fi

  # Optionally source ~/.agence/.agencrc and ~/.agence/config.yaml if they exist
  if [ -r "$HOME/.agence/.agencrc" ]; then
    source "$HOME/.agence/.agencrc"
    echo "✓ Sourced ~/.agence/.agencrc"
  fi
  if [ -r "$HOME/.agence/config.yaml" ]; then
    export AGENCE_CONFIG="$HOME/.agence/config.yaml"
    echo "✓ Loaded ~/.agence/config.yaml"
  fi

  echo ""

  # Step 2: Copy skeleton files to final locations (no symlinks)
  echo "Step 2: Copying skeleton files to final locations..."

  local AGENCE_GITHUB="$AGENCE_REPO/.github"
  local TARGET_GITHUB="$REPO_ROOT/.github"
  mkdir -p "$TARGET_GITHUB" 2>/dev/null

  # Copy copilot-instructions.md if present
  if [[ -f "$AGENCE_GITHUB/copilot.md" ]]; then
    cp -f "$AGENCE_GITHUB/copilot.md" "$TARGET_GITHUB/copilot-instructions.md"
    echo "✓ .github/copilot-instructions.md copied"
  fi

  # Copy CLAUDE.md if present
  if [[ -f "$AGENCE_GITHUB/CLAUDE.md" ]]; then
    cp -f "$AGENCE_GITHUB/CLAUDE.md" "$REPO_ROOT/CLAUDE.md"
    echo "✓ CLAUDE.md copied"
  fi

  echo ""
  echo "=============================================="
  echo "✓ Agence initialization complete!"
  echo "  Environment: $CURRENT_SHELL"
  echo "  AGENCE_ROOT=$AGENCE_REPO"
  echo "  REPO_ROOT=$REPO_ROOT"
  echo "=============================================="
  echo ""

  return 0
}

reload_agence_context() {
  # Load and acknowledge the entire Agence knowledge hierarchy
  # This reloads all context files in proper order and summarizes what was loaded
  
  [[ "$DEBUG" == "1" ]] && echo "[DEBUG] Reloading Agence context..." >&2
  
  local AGENCE_GITHUB="$AGENCE_REPO/.github"
  local context_files=(
    "$AGENCE_GITHUB/CLAUDE.md:Claude Integration"
    "$GIT_REPO/.github/copilot-instructions.md:Copilot Instructions"
    "$AGENCE_ROOT/codex/PRINCIPLES.md:Principles (Maxims)"
    "$AGENCE_ROOT/codex/LAWS.md:Laws (Hard Constraints)"
    "$AGENCE_ROOT/codex/RULES.md:Rules (Best Practices)"
    "$AGENCE_BIN/COMMANDS.md:Commands Reference"
    "$AGENCE_ROOT/nexus/faults/INDEX.md:Faults Index"
    "$AGENCE_ROOT/shared/lessons/INDEX.md:Lessons Learned"
  )
  
  echo "[RELOAD] Agence Context Loading"
  echo "=========================================="
  echo ""
  
  local loaded_count=0
  local failed_files=""
  
  for file_info in "${context_files[@]}"; do
    local file="${file_info%%:*}"
    local label="${file_info##*:}"
    
    if [[ -f "$file" ]]; then
      # Get file size and line count
      local size=$(stat -f%z "$file" 2>/dev/null || stat -c%s "$file" 2>/dev/null || echo "?")
      local lines=$(wc -l < "$file" 2>/dev/null || echo "?")
      
      printf "✓ %-35s | %6s bytes | %4s lines\n" "$label" "$size" "$lines"
      ((loaded_count++))
    else
      printf "✗ %-35s | [NOT FOUND]\n" "$label"
      failed_files="$failed_files\n  - $file"
    fi
  done
  
  echo ""
  echo "=========================================="
  echo ""
  echo "Context Summary:"
  echo "  Total files loaded: $loaded_count / ${#context_files[@]}"
  
  if [[ -n "$failed_files" ]]; then
    echo ""
    echo "⚠ Missing files:$failed_files"
  fi
  
  # Load and count some key metrics
  local principles_count=$(grep -c "^## Maxim" "$AGENCE_ROOT/codex/PRINCIPLES.md" 2>/dev/null || echo 0)
  local laws_count=$(grep -c "^## Law" "$AGENCE_ROOT/codex/LAWS.md" 2>/dev/null || echo 0)
  local rules_count=$(grep -c "^## Rule" "$AGENCE_ROOT/codex/RULES.md" 2>/dev/null || echo 0)
  local lessons_count=$(jq -r '.total_lessons' "$AGENCE_ROOT/shared/lessons/INDEX.json" 2>/dev/null || echo 0)
  
  echo ""
  echo "Active Knowledge:"
  echo "  Principles/Maxims: $principles_count"
  echo "  Laws (Constraints): $laws_count"
  echo "  Rules (Practices): $rules_count"
  echo "  Lessons Learned: $lessons_count"
  
  echo ""
  echo "Status: ✓ Agence context fully loaded and acknowledged"
  echo ""
  
  return 0
}

create_windows_symlink() {
  local source="$1"
  local target="$2"
  
  # Determine if source is a file or directory
  local link_type="file"
  if [[ -d "$source" ]]; then
    link_type="dir"
  fi
  
  [[ "$DEBUG" == "1" ]] && echo "[DEBUG] Creating symlink: $target → $source ($link_type)" >&2
  
  if [[ "$AGENCE_OS_WINDOWS" == "1" ]]; then
    # Windows: Use mklink command (requires admin on some systems)
    # Type 12019 is for file symlinks, type 12000 is for directory symlinks
    if [[ "$link_type" == "dir" ]]; then
      cmd /c mklink /D "$(cygpath -w "$target")" "$(cygpath -w "$source")" 2>/dev/null
    else
      cmd /c mklink /H "$(cygpath -w "$target")" "$(cygpath -w "$source")" 2>/dev/null || \
      cmd /c mklink "$(cygpath -w "$target")" "$(cygpath -w "$source")" 2>/dev/null
    fi
    
    if [[ $? -eq 0 ]]; then
      return 0
    else
      echo "[ERROR] mklink failed. Trying PowerShell method..." >&2
      # Fallback to PowerShell
      powershell -Command "New-Item -ItemType SymbolicLink -Path '$(cygpath -w "$target")' -Target '$(cygpath -w "$source")' -Force" 2>/dev/null
      return $?
    fi
  else
    # Unix/Linux/macOS: Use ln -s
    ln -s "$source" "$target" 2>/dev/null
    return $?
  fi
}

# ============================================================================
# MODE: SYSTEM COMMAND
# ============================================================================
# Built-in system utilities
# Example: agence !help
# Example: agence !bash (open new shell)

mode_system() {
  local sys_cmd="$1"

  [[ "$DEBUG" == "1" ]] && echo "[DEBUG] System mode: $sys_cmd" >&2

  case "$sys_cmd" in
    help)
      show_help
      return 0
      ;;
    version)
      show_version
      return 0
      ;;
    config)
      cat "$AGENCE_CONFIG" 2>/dev/null || echo "No config found: $AGENCE_CONFIG"
      return 0
      ;;
    status)
      echo "Agence Status:"
      echo "  Root: $AGENCE_ROOT"
      echo "  Config: $AGENCE_CONFIG"
      echo "  LLM Provider: $(grep 'provider:' "$AGENCE_CONFIG" 2>/dev/null | awk '{print $2}')"
      return 0
      ;;
    bash)
      echo "Launching Git Bash..."
      exec bash --login
      ;;
    shell)
      echo "Launching PowerShell..."
      exec powershell -NoExit
      ;;
    *)
      echo "Unknown system command: $sys_cmd" >&2
      return 1
      ;;
  esac
}

# ============================================================================
# SYMLINK REPAIR (Windows git-bash compatibility)
# ============================================================================

repair_agence_symlinks() {
  [[ "$DEBUG" == "1" ]] && echo "[DEBUG] Checking for broken symlinks..." >&2
  
  # Get list of symlinks from git
  local symlinks=$(git -C "$AGENCE_ROOT" ls-files -s 2>/dev/null | grep "^120000" | awk '{print $NF}')
  
  if [[ -z "$symlinks" ]]; then
    [[ "$DEBUG" == "1" ]] && echo "[DEBUG] No symlinks tracked in git" >&2
    return 0
  fi
  
  local count=0
  while IFS= read -r filepath; do
    [[ -z "$filepath" ]] && continue
    
    if [[ -L "$AGENCE_ROOT/$filepath" ]]; then
      # Already a symlink, skip
      continue
    fi
    
    if [[ ! -e "$AGENCE_ROOT/$filepath" ]]; then
      # Symlink doesn't exist, try to recreate it
      # Git stores symlinks as: "<path to target>"
      local target=$(git -C "$AGENCE_ROOT" ls-files -s 2>/dev/null | grep "^120000.*$filepath" | awk '{for(i=1;i<=NF;i++) printf "%s ", $i}' | sed 's/.*\s//')
      
      if [[ -n "$target" ]]; then
        mkdir -p "$(dirname "$AGENCE_ROOT/$filepath")" 2>/dev/null
        ln -sf "$target" "$AGENCE_ROOT/$filepath" 2>/dev/null
        if [[ $? -eq 0 ]]; then
          echo "[REPAIR] Created symlink: $filepath -> $target"
          ((count++))
        fi
      fi
    fi
  done <<< "$symlinks"
  
  if [[ $count -gt 0 ]]; then
    echo ""
    echo "✓ Repaired $count broken symlink(s)"
  fi
  
  return 0
}

# ============================================================================
# INSTALL: Package Manager Integration
# ============================================================================

install_agence_packages() {
  [[ "$DEBUG" == "1" ]] && echo "[DEBUG] Installing Agence packages..." >&2
  
  echo ""
  echo "=============================================="
  echo "  AGENCE PACKAGE INSTALLATION (^install)"
  echo "=============================================="
  echo ""
  
  # Detect OS
  local os_type="unknown"
  if [[ "$OSTYPE" == "msys" || "$OSTYPE" == "mingw"* ]]; then
    os_type="windows"
  elif [[ "$OSTYPE" == "darwin"* ]]; then
    os_type="macos"
  elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
    os_type="linux"
  fi
  
  echo "Detected OS: $os_type"
  echo ""
  
  case "$os_type" in
    windows)
      install_windows_packages
      ;;
    macos)
      install_macos_packages
      ;;
    linux)
      install_linux_packages
      ;;
    *)
      echo "[ERROR] Unsupported OS: $OSTYPE" >&2
      return 1
      ;;
  esac
  
  return $?
}

install_windows_packages() {
  echo "Installing packages via winget..."
  echo ""
  
  # Define Windows packages (winget IDs)
  local -a windows_packages=(
    "GitHub.cli"
    "aider"
    "jfrog"
    "Hashicorp.Terraform"
    "terrafromLinters.tflint"
    "Amazon.AWSCli"
    "Microsoft.AzureCLI"
    "Google.CloudSDK"
  )
  
  local installed=0
  local skipped=0
  local failed=0
  
  for pkg in "${windows_packages[@]}"; do
    echo -n "[$pkg] "
    
    # Check if installed || install
    # winget list returns 0 if found, 1 if not found
    if winget list --id "$pkg" &>/dev/null 2>&1; then
      echo "✓ (already installed)"
      ((skipped++))
    elif winget install -e --id "$pkg" --accept-package-agreements --accept-source-agreements &>/dev/null 2>&1; then
      echo "✓ (installed)"
      ((installed++))
    else
      echo "✗ (failed)"
      ((failed++))
    fi
  done
  
  echo ""
  echo "=============================================="
  echo "Installation summary:"
  echo "  ✓ Installed: $installed"
  echo "  ⏭ Already present: $skipped"
  echo "  ✗ Failed: $failed"
  echo "=============================================="
  
  if [[ $failed -gt 0 ]]; then
    echo ""
    echo "Note: Some packages failed. This may be expected if:"
    echo "  - Package requires manual user interaction"
    echo "  - Package requires admin elevation"
    echo "  - Package name/ID changed in winget registry"
    return 1
  fi
  return 0
}

install_macos_packages() {
  echo "Installing packages via Homebrew..."
  echo ""
  
  # Check if Homebrew is installed
  if ! command -v brew &>/dev/null; then
    echo "[ERROR] Homebrew not found. Install from: https://brew.sh"
    return 1
  fi
  
  # Define macOS packages (Homebrew formulae)
  local -a macos_packages=(
    "gh"
    "aider"
    "jfrog-cli"
    "terraform"
    "tflint"
    "awscli"
    "azure-cli"
    "google-cloud-sdk"
  )
  
  local installed=0
  local skipped=0
  local failed=0
  
  for pkg in "${macos_packages[@]}"; do
    echo -n "[$pkg] "
    
    # Check if installed || install
    if brew list "$pkg" &>/dev/null 2>&1; then
      echo "✓ (already installed)"
      ((skipped++))
    elif brew install "$pkg" &>/dev/null 2>&1; then
      echo "✓ (installed)"
      ((installed++))
    else
      echo "✗ (failed)"
      ((failed++))
    fi
  done
  
  echo ""
  echo "=============================================="
  echo "Installation summary:"
  echo "  ✓ Installed: $installed"
  echo "  ⏭ Already present: $skipped"
  echo "  ✗ Failed: $failed"
  echo "=============================================="
  
  if [[ $failed -gt 0 ]]; then
    return 1
  fi
  return 0
}

install_linux_packages() {
  echo "Installing packages via system package manager..."
  echo ""
  
  # Detect package manager
  local pkg_manager="apt-get"
  local pkg_check_cmd="dpkg -l"
  
  if command -v dnf &>/dev/null; then
    pkg_manager="dnf"
    pkg_check_cmd="dnf list installed"
  elif command -v pacman &>/dev/null; then
    pkg_manager="pacman"
    pkg_check_cmd="pacman -Q"
  fi
  
  echo "Using package manager: $pkg_manager"
  echo ""
  
  # Define Linux packages
  local -a linux_packages=(
    "gh"
    "aider"
    "jfrog-cli"
    "terraform"
    "tflint"
    "awscli"
    "azure-cli"
    "google-cloud-sdk"
  )
  
  local installed=0
  local skipped=0
  local failed=0
  
  for pkg in "${linux_packages[@]}"; do
    echo -n "[$pkg] "
    
    # Check if installed || install
    if $pkg_check_cmd | grep -q "$pkg" &>/dev/null 2>&1; then
      echo "✓ (already installed)"
      ((skipped++))
    elif sudo $pkg_manager install -y "$pkg" &>/dev/null 2>&1; then
      echo "✓ (installed)"
      ((installed++))
    else
      echo "✗ (failed)"
      ((failed++))
    fi
  done
  
  echo ""
  echo "=============================================="
  echo "Installation summary:"
  echo "  ✓ Installed: $installed"
  echo "  ⏭ Already present: $skipped"
  echo "  ✗ Failed: $failed"
  echo "=============================================="
  
  if [[ $failed -gt 0 ]]; then
    return 1
  fi
  return 0
}

# ============================================================================
# ENTRY POINT
# ============================================================================

main() {
  local cmd="$1"
  shift || true

  case "$cmd" in
    help|"--help"|"-h")
      show_help
      ;;
    version|"--version"|"-v")
      show_version
      ;;
    +*)
      mode_ai_routed "${cmd#+}" "$@"
      ;;
    /*)
      mode_external "${cmd#/}" "$@"
      ;;
    !*)
      mode_system "${cmd#!}" "$@"
      ;;
    ^*)
      mode_init "${cmd#^}" "$@"
      ;;
    ""|chat)
      mode_chat "$@"
      ;;
    *)
      # Default: treat as chat
      mode_chat "$cmd" "$@"
      ;;
  esac
}

main "$@"
