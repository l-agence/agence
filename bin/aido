#!/usr/bin/env bash

################################################################################
# AIDO: Allow IDempotent Operations
# Whitelisted command executor (opposite of sudo)
# Allows only safe, read-only, or idempotent commands
#
# Usage: aido <command>
#
# Author: Stephane Korning 2026
# License: MIT License with Commons Clause
################################################################################

# ============================================================================
# GIT WHITELIST
# ============================================================================

GIT_SAFE_COMMANDS=(
    "status"
    "log"
    "diff"
    "branch"
    "tag"
    "reflog"
    "describe"
    "shortlog"
    "config.*--list"
    "remote"
    "rev-parse"
    "show"
    "ls-files"
    "ls-tree"
    "grep"
    "cat-file"
    "ls-remote"
)

# ============================================================================
# AWS WHITELIST
# ============================================================================

AWS_SAFE_PATTERNS=(
    "describe-.*"
    "get-.*"
    "list-.*"
    "head-.*"
    "auth.*status"
    "auth.*login"
    "sts.*get.*session.*token"
)

# ============================================================================
# GITHUB CLI WHITELIST
# ============================================================================

GH_SAFE_PATTERNS=(
    # Repository commands
    "repo view.*"
    "repo list.*"
    "repo search.*"
    "repo clone.*--dry-run.*"
    # Pull Request commands
    "pr list.*"
    "pr view.*"
    "pr status.*"
    "pr checks.*"
    # Issue commands
    "issue list.*"
    "issue view.*"
    # Actions commands
    "run list.*"
    "run view.*"
    "run download.*"
    "workflow list.*"
    "workflow view.*"
    # Auth commands
    "auth status.*"
    "org list.*"
    # API commands (only GET method allowed)
    "api GET.*"
)

# ============================================================================
# POWERSHELL WHITELIST
# ============================================================================

POWERSHELL_SAFE_VERBS=(
    "Get"
    "Test"
    "Measure"
    "Select"
    "Where"
    "Sort"
    "Group"
    "Compare"
)

# ============================================================================
# AIDO VALIDATION FUNCTIONS
# ============================================================================

validate_git_command() {
    local git_cmd="$1"
    
    # Extract the git subcommand (first argument after 'git')
    local subcommand="${git_cmd#git }"
    subcommand="${subcommand%% *}"
    
    # Check if subcommand is in whitelist
    for safe_cmd in "${GIT_SAFE_COMMANDS[@]}"; do
        if [[ "$subcommand" =~ ^${safe_cmd}$ ]]; then
            return 0
        fi
    done
    
    return 1
}

validate_aws_command() {
    local aws_cmd="$1"
    
    # Extract the operation (first argument after 'aws')
    local operation="${aws_cmd#aws }"
    
    # Check if operation matches a safe pattern
    for safe_pattern in "${AWS_SAFE_PATTERNS[@]}"; do
        if [[ "$operation" =~ ^${safe_pattern} ]]; then
            return 0
        fi
    done
    
    return 1
}

validate_gh_command() {
    local gh_cmd="$1"
    
    # Extract the operation (first argument after 'gh')
    local operation="${gh_cmd#gh }"
    
    # Check if operation matches a safe pattern
    for safe_pattern in "${GH_SAFE_PATTERNS[@]}"; do
        if [[ "$operation" =~ ^${safe_pattern} ]]; then
            return 0
        fi
    done
    
    return 1
}

validate_powershell_command() {
    local ps_cmd="$1"
    
    # Extract the verb (first word of command)
    local verb="${ps_cmd%% *}"
    
    # Check if verb is in whitelist
    for safe_verb in "${POWERSHELL_SAFE_VERBS[@]}"; do
        if [[ "$verb" == "$safe_verb" ]] || [[ "$verb" == "${safe_verb}${safe_verb}" ]]; then
            return 0
        fi
    done
    
    return 1
}

# ============================================================================
# MAIN AIDO ROUTER
# ============================================================================

main() {
    local full_command="$*"
    local first_word="${1,,}"  # Convert to lowercase for matching
    
    [[ -z "$full_command" ]] && {
        cat >&2 <<EOF
AIDO: Allow IDempotent Operations
Whitelisted command executor (opposite of sudo)

Usage: aido <command> [args...]

Examples:
  aido git status
  aido git log --oneline
  aido aws describe-instances
  aido aws sts get-session-token
  aido gh repo list
  aido gh pr view 42
  aido gh issue list

Whitelisted Git Commands:
  status, log, diff, branch, tag, reflog, describe, shortlog
  config --list, remote, rev-parse, show, ls-files, ls-tree
  grep, cat-file, ls-remote

Whitelisted AWS Patterns:
  describe-*, get-*, list-*, head-*
  auth status, auth login
  sts get-session-token

Whitelisted GitHub CLI Commands:
  Repository: repo view, repo list, repo search, repo clone --dry-run
  Pull Requests: pr list, pr view, pr status, pr checks
  Issues: issue list, issue view
  Actions: run list, run view, run download, workflow list, workflow view
  Auth: auth status, org list
  API: api GET ... (read-only)

PowerShell Verbs (in PowerShell context):
  Get, Test, Measure, Select, Where, Sort, Group, Compare

Environment Variables:
  AIDO_DEBUG=1  - Show execution trace

EOF
        return 1
    }
    
    case "$first_word" in
        git)
            if validate_git_command "git $2"; then
                [[ "${AIDO_DEBUG:-0}" == "1" ]] && echo "[AIDO] ✓ Executing: $full_command" >&2
                eval "$full_command"
                return $?
            else
                echo "[AIDO] ✗ BLOCKED: Git command not whitelisted: $2" >&2
                echo "" >&2
                echo "Allowed git commands:" >&2
                printf "  • %s\n" "${GIT_SAFE_COMMANDS[@]}" >&2
                return 1
            fi
            ;;
        aws)
            if validate_aws_command "aws $2"; then
                [[ "${AIDO_DEBUG:-0}" == "1" ]] && echo "[AIDO] ✓ Executing: $full_command" >&2
                eval "$full_command"
                return $?
            else
                echo "[AIDO] ✗ BLOCKED: AWS operation not whitelisted: $2" >&2
                echo "" >&2
                echo "Allowed AWS patterns:" >&2
                printf "  • %s\n" "${AWS_SAFE_PATTERNS[@]}" >&2
                return 1
            fi
            ;;
        gh)
            if validate_gh_command "gh $2 $3 $4 $5"; then
                [[ "${AIDO_DEBUG:-0}" == "1" ]] && echo "[AIDO] ✓ Executing: $full_command" >&2
                eval "$full_command"
                return $?
            else
                echo "[AIDO] ✗ BLOCKED: GitHub CLI command not whitelisted: $2" >&2
                echo "" >&2
                echo "Allowed GitHub CLI patterns:" >&2
                printf "  • %s\n" "${GH_SAFE_PATTERNS[@]}" >&2
                return 1
            fi
            ;;
        *)
            # Check if it's a PowerShell command (if in PowerShell session)
            if [[ -n "${PSVersionTable+x}" ]]; then
                if validate_powershell_command "$first_word"; then
                    [[ "${AIDO_DEBUG:-0}" == "1" ]] && echo "[AIDO] ✓ Executing: $full_command" >&2
                    eval "$full_command"
                    return $?
                fi
            fi
            
            echo "[AIDO] ✗ BLOCKED: Command not whitelisted: $1" >&2
            echo "Run 'aido' without arguments to see allowed commands" >&2
            return 1
            ;;
    esac
}

main "$@"
