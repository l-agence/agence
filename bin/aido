#!/usr/bin/env bash

################################################################################
# AIDO: Allow IDempotent Operations + Session Persistence
# Whitelisted command executor with local session capture
# Allows only safe, read-only, or idempotent commands
# Captures STDIN/STDOUT/STDERR via 'script' command to local session dir
#
# Usage: aido <command>
#
# Session Data Structure:
#   .aisessions/SESSION_ID.typescript  - Raw output from 'script' command
#   .aisessions/SESSION_ID.meta.json   - Metadata: cmd, exit, tails, sha256, etc.
#
# Author: Stephane Korning 2026
# License: MIT License with Commons Clause
################################################################################

# ============================================================================
# SESSION CONFIGURATION
# ============================================================================

# Source canonical environment (sets AI_ROOT, AI_BIN, AGENCE_LIB, etc.)
source "$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/lib/env.sh"

AIDO_SESSION_DIR="${AIDO_SESSION_DIR:-$AI_ROOT/nexus/.aisessions}"
AI_AGENT="${AI_AGENT:-${AIDO_AGENT:-ai-agent}}"  # AI_AGENT is canonical; AIDO_AGENT kept for compat
AIDO_DEBUG="${AIDO_DEBUG:-0}"

# Source format library
source_if_exists "$AGENCE_LIB/format.sh"
source_if_exists "$AGENCE_LIB/ailedger.sh"

# ============================================================================
# SESSION HELPER FUNCTIONS
# ============================================================================

session_init() {
    # Create session directory if it doesn't exist
    mkdir -p "$AIDO_SESSION_DIR" 2>/dev/null || {
        echo "[AIDO] ✗ Failed to create session directory: $AIDO_SESSION_DIR" >&2
        return 1
    }
}

generate_session_id() {
    # Format: agent-YYYYMMDD_HHMMSS-PID-HEXID
    local timestamp=$(date +%Y%m%d_%H%M%S)
    local pid=$$
    local hexid=$(printf '%x' $((RANDOM * 65536 + RANDOM)))
    echo "${AIDO_AGENT}-${timestamp}-${pid}-${hexid}"
}

run_with_session() {
    local full_command="$1"
    local session_id="$2"
    local typescript_file="$AIDO_SESSION_DIR/${session_id}.typescript"
    local meta_file="$AIDO_SESSION_DIR/${session_id}.meta.json"
    
    [[ "${AIDO_DEBUG}" == "1" ]] && echo "[AIDO] Session: $session_id" >&2
    [[ "${AIDO_DEBUG}" == "1" ]] && echo "[AIDO] Typescript: $typescript_file" >&2

    # Write initial metadata with exit_code=254 (verification pending — CODEX default)
    cat > "$meta_file" <<INIT_META
{
  "session_id": "$session_id",
  "agent": "$AIDO_AGENT",
  "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "command": "$full_command",
  "exit_code": 254,
  "actual_exit_code": null,
  "verification_status": "pending",
  "typescript_file": "$typescript_file"
}
INIT_META

    # Run command: pipe-pane captures if active, otherwise use script(1)
    if [[ "${AGENCE_PIPE_PANE:-0}" == "1" ]]; then
      # tmux pipe-pane already capturing — run directly, tee to typescript for metadata
      eval "$full_command" 2>&1 | tee "$typescript_file"
      local exit_code=${PIPESTATUS[0]:-$?}
    else
      # No pipe-pane — wrap in script(1) for PTY capture
      script --quiet --return --command "$full_command" "$typescript_file" 2>&1
      local exit_code=$?
    fi

    # Log execution to ailedger
    ailedger_append "execute" "aido-run" "$session_id" "$full_command" "$exit_code"

    # Append AI_EXIT_CODE marker to typescript so aisession can parse it
    printf '\n=== AI_EXIT_CODE: %d ===\n' "$exit_code" >> "$typescript_file"
    
    # Extract tail of stdout and head of stderr for metadata
    local stdout_tail=$(tail -c 500 "$typescript_file" 2>/dev/null | strings || echo "")
    local stderr_head=$(head -c 500 "$typescript_file" 2>/dev/null | strings | head -5 || echo "")
    
    # Calculate SHA256 of session file
    local sha256=""
    if command -v sha256sum &>/dev/null; then
        sha256=$(sha256sum "$typescript_file" 2>/dev/null | awk '{print $1}')
    elif command -v shasum &>/dev/null; then
        sha256=$(shasum -a 256 "$typescript_file" 2>/dev/null | awk '{print $1}')
    fi
    
    # Update metadata — keep exit_code=254 until aisession verifies
    cat > "$meta_file" <<EOF
{
  "session_id": "$session_id",
  "agent": "$AIDO_AGENT",
  "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "command": "$full_command",
  "exit_code": 254,
  "actual_exit_code": $exit_code,
  "verification_status": "pending",
  "typescript_file": "$typescript_file",
  "sha256": "$sha256",
  "stdout_tail": "$(echo "$stdout_tail" | jq -Rs .)",
  "stderr_head": "$(echo "$stderr_head" | jq -Rs .)"
}
EOF

    # Call mandatory verification via session management tool (aisession)
    # Skip verification in non-interactive mode (no TTY) or when AIDO_NO_VERIFY=1
    session_script="$AI_BIN/aisession"
    if [[ "${AIDO_NO_VERIFY:-0}" == "1" ]] || [[ -n "${SHELLSPEC_TMPDIR:-}" ]] || [[ ! -t 0 && ! -t 1 ]]; then
        # Non-interactive / CI mode — skip verification, trust the exit code
        [[ "${AIDO_DEBUG}" == "1" ]] && echo "[AIDO] Verification skipped (non-interactive)" >&2
    elif [[ -x "$session_script" ]]; then
        "$session_script" "$session_id"
        verify_exit=$?
        
        # If verification denied (254), block workflow and return immediately
        if [[ $verify_exit -eq 254 ]]; then
            echo ""
            echo "=== AI_EXIT_CODE: 254 (UNVERIFIED - WORKFLOW BLOCKED) ==="
            return 254
        fi
        
        # If verification error (1), report and return
        if [[ $verify_exit -eq 1 ]]; then
            echo ""
            echo "=== AI_EXIT_CODE: 1 (VERIFICATION ERROR) ==="
            return 1
        fi
    else
        echo "[AIDO] ⚠ Warning: session script not found or not executable" >&2
        echo "[AIDO]   Expected: $session_script" >&2
    fi
    
    # Verification passed (or skipped), output original command exit code
    echo ""
    echo "=== AI_EXIT_CODE: $exit_code ==="
    return $exit_code
}

# ============================================================================
# GUARD INTEGRATION — Write-Access Gate
# ============================================================================
# Instead of hardcoded whitelists, all commands flow through lib/guard.ts:
#   T0 = auto-execute (read-only, safe)
#   T1 = flag (unknown — allow but log)
#   T2 = escalate (write ops — require human approval via signal)
#   T3 = deny (destructive — blocked)
#
# The gate is WRITE ACCESS, not a --safe flag. Read ops pass instantly.
# Write ops get human-gated via ^prompt. Destructive ops are denied.

_guard_check() {
    local command="$1"
    local airun="$AI_BIN/airun"

    if [[ ! -x "$airun" ]]; then
        echo "[AIDO] ⚠ Guard unavailable (airun not found) — falling back to deny" >&2
        return 1
    fi

    # Get guard decision as shell exports
    local guard_output
    guard_output=$("$airun" guard check "$command" 2>/dev/null)
    local guard_exit=$?

    # SEC-010: If airun itself failed (e.g. bun runtime unavailable), fail-closed.
    # Previously fell back to T1 (allow + flag) which let commands through unguarded.
    if [[ $guard_exit -ne 0 ]]; then
        echo "[AIDO] ✗ Guard runtime unavailable — denying (fail-closed)" >&2
        return 1
    fi

    # Parse exports
    eval "$guard_output" 2>/dev/null

    local tier="${_GUARD_TIER:-T3}"
    local approved="${_GUARD_APPROVED:-0}"
    local reason="${_GUARD_REASON:-unknown}"

    [[ "${AIDO_DEBUG}" == "1" ]] && echo "[AIDO] Guard: tier=$tier approved=$approved reason=$reason" >&2

    case "$tier" in
        T0)
            # Auto-execute — read-only, no delay
            return 0
            ;;
        T1)
            # Flagged — allow but log
            echo "[AIDO] ⚡ T1 flagged: $reason" >&2
            return 0
            ;;
        T2)
            # Escalate — requires human approval
            echo "[AIDO] 🔒 T2 escalation: $reason" >&2
            _gate_escalate "$command"
            return $?
            ;;
        T3)
            # Deny — blocked
            echo "[AIDO] ✗ T3 DENIED: $reason" >&2
            return 1
            ;;
        *)
            echo "[AIDO] ✗ Unknown tier: $tier — denying" >&2
            return 1
            ;;
    esac
}

_gate_escalate() {
    local command="$1"
    local signal_tool="$AI_BIN/airun"

    # Try signal prompt for human approval (blocking, 60s timeout)
    if [[ -x "$signal_tool" ]] && [[ -n "${TMUX:-}" ]]; then
        local response
        response=$("$signal_tool" signal prompt "AIDO T2 gate: approve '$command'? [yes/no]" 2>/dev/null)
        if [[ "$response" == "yes" || "$response" == "y" ]]; then
            echo "[AIDO] ✓ Human approved T2 command" >&2
            return 0
        else
            echo "[AIDO] ✗ Human denied T2 command (response: ${response:-timeout})" >&2
            return 1
        fi
    fi

    # No tmux / no signal — check if non-interactive
    if [[ ! -t 0 && ! -t 1 ]]; then
        echo "[AIDO] ✗ T2 command requires human approval (non-interactive, cannot prompt)" >&2
        return 1
    fi

    # Fallback: direct TTY prompt
    echo "[AIDO] 🔒 T2 gate: $command" >&2
    echo -n "[AIDO] Approve? [y/N] " >&2
    local answer
    read -r -t 30 answer < /dev/tty 2>/dev/null || answer="n"
    if [[ "$answer" == "y" || "$answer" == "Y" || "$answer" == "yes" ]]; then
        echo "[AIDO] ✓ Approved" >&2
        return 0
    fi
    echo "[AIDO] ✗ Denied" >&2
    return 1
}

# ============================================================================
# MAIN AIDO ROUTER (Guard-Gated)
# ============================================================================

main() {
    local full_command="$*"
    
    [[ -z "$full_command" ]] && {
        cat >&2 <<EOF
AIDO: Allow IDempotent Operations + Session Persistence
Guard-gated command executor with local session capture

Usage: aido <command> [args...]

All commands are classified by lib/guard.ts:
  T0  Auto-execute (read-only, safe) — instant
  T1  Flagged (unknown cmd) — allowed, logged
  T2  Escalate (write ops) — requires human approval
  T3  Deny (destructive) — blocked

Examples:
  aido git status          # T0 — auto-execute
  aido git log --oneline   # T0 — auto-execute
  aido git push            # T2 — requires approval
  aido rm -rf /            # T3 — denied
  aido aws describe-*      # T0 — auto-execute
  aido gh pr create        # T2 — requires approval

Environment Variables:
  AIDO_DEBUG=1          Show execution trace + guard decisions
  AIDO_SESSION_DIR      Override session directory
  AI_AGENT              Agent identifier for session tracking
  AIDO_NO_VERIFY=1      Skip post-execution verification

Guard Policy:
  Loaded from: codex/AIPOLICY.yaml
  Check policy: airun guard policy
  Classify:     airun guard classify <command>

Session Data:
  Sessions stored in: \$AIDO_SESSION_DIR/
  Raw output:    SESSION_ID.typescript
  Metadata:      SESSION_ID.meta.json

EOF
        return 1
    }
    
    # Initialize session directory
    session_init || return 1
    
    # ── Guard gate: classify command tier ──
    if ! _guard_check "$full_command"; then
        # Guard denied or escalation failed
        ailedger_append "guard" "aido-denied" "" "$full_command" "1"
        return 1
    fi
    
    # ── Approved — execute with session capture ──
    local session_id=$(generate_session_id)
    
    [[ "${AIDO_DEBUG}" == "1" ]] && echo "[AIDO] ✓ Guard approved: $full_command" >&2
    run_with_session "$full_command" "$session_id"
    return $?
}

main "$@"

