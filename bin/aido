#!/usr/bin/env bash

################################################################################
# AIDO: Allow IDempotent Operations + Session Persistence
# Whitelisted command executor with local session capture
# Allows only safe, read-only, or idempotent commands
# Captures STDIN/STDOUT/STDERR via 'script' command to local session dir
#
# Usage: aido <command>
#
# Session Data Structure:
#   .aisessions/SESSION_ID.typescript  - Raw output from 'script' command
#   .aisessions/SESSION_ID.meta.json   - Metadata: cmd, exit, tails, sha256, etc.
#
# Author: Stephane Korning 2026
# License: MIT License with Commons Clause
################################################################################

# ============================================================================
# SESSION CONFIGURATION
# ============================================================================

# Use AI_ROOT and AI_BIN from environment (set by .agencerc)
# Fallback: compute from script location
if [[ -z "$AI_ROOT" || -z "$AI_BIN" ]]; then
    local script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    AI_ROOT="${AI_ROOT:-$(dirname "$script_dir")}"
    AI_BIN="${AI_BIN:-$script_dir}"
fi

AIDO_SESSION_DIR="${AIDO_SESSION_DIR:-$AI_ROOT/nexus/.aisessions}"
AIDO_AGENT="${AIDO_AGENT:-ai-agent}"
AIDO_DEBUG="${AIDO_DEBUG:-0}"

# Source format library
AIDO_LIB="${AI_ROOT}/lib"
[[ -f "$AIDO_LIB/format.sh" ]] && source "$AIDO_LIB/format.sh"

# ============================================================================
# SESSION HELPER FUNCTIONS
# ============================================================================

session_init() {
    # Create session directory if it doesn't exist
    mkdir -p "$AIDO_SESSION_DIR" 2>/dev/null || {
        echo "[AIDO] ✗ Failed to create session directory: $AIDO_SESSION_DIR" >&2
        return 1
    }
}

generate_session_id() {
    # Format: agent-YYYYMMDD_HHMMSS-PID-HEXID
    local timestamp=$(date +%Y%m%d_%H%M%S)
    local pid=$$
    local hexid=$(printf '%x' $((RANDOM * 65536 + RANDOM)))
    echo "${AIDO_AGENT}-${timestamp}-${pid}-${hexid}"
}

run_with_session() {
    local full_command="$1"
    local session_id="$2"
    local typescript_file="$AIDO_SESSION_DIR/${session_id}.typescript"
    local meta_file="$AIDO_SESSION_DIR/${session_id}.meta.json"
    
    [[ "${AIDO_DEBUG}" == "1" ]] && echo "[AIDO] Session: $session_id" >&2
    [[ "${AIDO_DEBUG}" == "1" ]] && echo "[AIDO] Typescript: $typescript_file" >&2

    # Write initial metadata with exit_code=254 (verification pending — CODEX default)
    cat > "$meta_file" <<INIT_META
{
  "session_id": "$session_id",
  "agent": "$AIDO_AGENT",
  "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "command": "$full_command",
  "exit_code": 254,
  "actual_exit_code": null,
  "verification_status": "pending",
  "typescript_file": "$typescript_file"
}
INIT_META

    # Run command inside PTY with 'script' capturing output
    script --quiet --return --command "$full_command" "$typescript_file" 2>&1
    local exit_code=$?

    # Append AI_EXIT_CODE marker to typescript so aisession can parse it
    printf '\n=== AI_EXIT_CODE: %d ===\n' "$exit_code" >> "$typescript_file"
    
    # Extract tail of stdout and head of stderr for metadata
    local stdout_tail=$(tail -c 500 "$typescript_file" 2>/dev/null | strings || echo "")
    local stderr_head=$(head -c 500 "$typescript_file" 2>/dev/null | strings | head -5 || echo "")
    
    # Calculate SHA256 of session file
    local sha256=""
    if command -v sha256sum &>/dev/null; then
        sha256=$(sha256sum "$typescript_file" 2>/dev/null | awk '{print $1}')
    elif command -v shasum &>/dev/null; then
        sha256=$(shasum -a 256 "$typescript_file" 2>/dev/null | awk '{print $1}')
    fi
    
    # Update metadata — keep exit_code=254 until aisession verifies
    cat > "$meta_file" <<EOF
{
  "session_id": "$session_id",
  "agent": "$AIDO_AGENT",
  "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "command": "$full_command",
  "exit_code": 254,
  "actual_exit_code": $exit_code,
  "verification_status": "pending",
  "typescript_file": "$typescript_file",
  "sha256": "$sha256",
  "stdout_tail": "$(echo "$stdout_tail" | jq -Rs .)",
  "stderr_head": "$(echo "$stderr_head" | jq -Rs .)"
}
EOF

    # Call mandatory verification via session management tool (aisession)
    session_script="$AI_BIN/aisession"
    if [[ -x "$session_script" ]]; then
        "$session_script" "$session_id"
        verify_exit=$?
        
        # If verification denied (254), block workflow and return immediately
        if [[ $verify_exit -eq 254 ]]; then
            echo ""
            echo "=== AI_EXIT_CODE: 254 (UNVERIFIED - WORKFLOW BLOCKED) ==="
            return 254
        fi
        
        # If verification error (1), report and return
        if [[ $verify_exit -eq 1 ]]; then
            echo ""
            echo "=== AI_EXIT_CODE: 1 (VERIFICATION ERROR) ==="
            return 1
        fi
    else
        echo "[AIDO] ⚠ Warning: session script not found or not executable" >&2
        echo "[AIDO]   Expected: $session_script" >&2
    fi
    
    # Verification passed (or skipped), output original command exit code
    echo ""
    echo "=== AI_EXIT_CODE: $exit_code ==="
    return $exit_code
}

# ============================================================================
# GIT WHITELIST
# ============================================================================

GIT_SAFE_COMMANDS=(
    "status"
    "log"
    "diff"
    "branch"
    "tag"
    "reflog"
    "describe"
    "shortlog"
    "config.*--list"
    "remote"
    "rev-parse"
    "show"
    "ls-files"
    "ls-tree"
    "grep"
    "cat-file"
    "ls-remote"
)

# ============================================================================
# AWS WHITELIST
# ============================================================================

AWS_SAFE_PATTERNS=(
    "describe-.*"
    "get-.*"
    "list-.*"
    "head-.*"
    "auth.*status"
    "auth.*login"
    "sts.*get.*session.*token"
)

# ============================================================================
# GITHUB CLI WHITELIST
# ============================================================================

GH_SAFE_PATTERNS=(
    # Repository commands
    "repo view.*"
    "repo list.*"
    "repo search.*"
    "repo clone.*--dry-run.*"
    # Pull Request commands
    "pr list.*"
    "pr view.*"
    "pr status.*"
    "pr checks.*"
    # Issue commands
    "issue list.*"
    "issue view.*"
    # Actions commands
    "run list.*"
    "run view.*"
    "run download.*"
    "workflow list.*"
    "workflow view.*"
    # Auth commands
    "auth status.*"
    "org list.*"
    # API commands (only GET method allowed)
    "api GET.*"
)

# ============================================================================
# POWERSHELL WHITELIST
# ============================================================================

POWERSHELL_SAFE_VERBS=(
    "Get"
    "Test"
    "Measure"
    "Select"
    "Where"
    "Sort"
    "Group"
    "Compare"
)

# ============================================================================
# AIDO VALIDATION FUNCTIONS
# ============================================================================

validate_git_command() {
    local git_cmd="$1"
    
    # Extract the git subcommand (first argument after 'git')
    local subcommand="${git_cmd#git }"
    subcommand="${subcommand%% *}"
    
    # Check if subcommand is in whitelist
    for safe_cmd in "${GIT_SAFE_COMMANDS[@]}"; do
        if [[ "$subcommand" =~ ^${safe_cmd}$ ]]; then
            return 0
        fi
    done
    
    return 1
}

validate_aws_command() {
    local aws_cmd="$1"
    
    # Extract the operation (first argument after 'aws')
    local operation="${aws_cmd#aws }"
    
    # Check if operation matches a safe pattern
    for safe_pattern in "${AWS_SAFE_PATTERNS[@]}"; do
        if [[ "$operation" =~ ^${safe_pattern} ]]; then
            return 0
        fi
    done
    
    return 1
}

validate_gh_command() {
    local gh_cmd="$1"
    
    # Extract the operation (first argument after 'gh')
    local operation="${gh_cmd#gh }"
    
    # Check if operation matches a safe pattern
    for safe_pattern in "${GH_SAFE_PATTERNS[@]}"; do
        if [[ "$operation" =~ ^${safe_pattern} ]]; then
            return 0
        fi
    done
    
    return 1
}

validate_powershell_command() {
    local ps_cmd="$1"
    
    # Extract the verb (first word of command)
    local verb="${ps_cmd%% *}"
    
    # Check if verb is in whitelist
    for safe_verb in "${POWERSHELL_SAFE_VERBS[@]}"; do
        if [[ "$verb" == "$safe_verb" ]] || [[ "$verb" == "${safe_verb}${safe_verb}" ]]; then
            return 0
        fi
    done
    
    return 1
}

# ============================================================================
# MAIN AIDO ROUTER (with Session Capture)
# ============================================================================

main() {
    local full_command="$*"
    local first_word="${1,,}"  # Convert to lowercase for matching
    
    [[ -z "$full_command" ]] && {
        cat >&2 <<EOF
AIDO: Allow IDempotent Operations + Session Persistence
Whitelisted command executor with local session capture

Usage: aido <command> [args...]

Examples:
  aido git status
  aido git log --oneline
  aido aws describe-instances
  aido aws sts get-session-token
  aido gh repo list
  aido gh pr view 42
  aido gh issue list

Whitelisted Git Commands:
  status, log, diff, branch, tag, reflog, describe, shortlog
  config --list, remote, rev-parse, show, ls-files, ls-tree
  grep, cat-file, ls-remote

Whitelisted AWS Patterns:
  describe-*, get-*, list-*, head-*
  auth status, auth login
  sts get-session-token

Whitelisted GitHub CLI Commands:
  Repository: repo view, repo list, repo search, repo clone --dry-run
  Pull Requests: pr list, pr view, pr status, pr checks
  Issues: issue list, issue view
  Actions: run list, run view, run download, workflow list, workflow view
  Auth: auth status, org list
  API: api GET ... (read-only)

PowerShell Verbs (in PowerShell context):
  Get, Test, Measure, Select, Where, Sort, Group, Compare

Environment Variables:
  AIDO_DEBUG=1          - Show execution trace
  AIDO_SESSION_DIR      - Override session directory (default: ./.aisessions)
  AIDO_AGENT            - Agent identifier for session tracking (default: ai-agent)

Session Data:
  Sessions stored in: $AIDO_SESSION_DIR/
  Raw output:    SESSION_ID.typescript
  Metadata:      SESSION_ID.meta.json

EOF
        return 1
    }
    
    # Initialize session directory
    session_init || return 1
    
    # Generate unique session ID
    local session_id=$(generate_session_id)
    
    case "$first_word" in
        git)
            if validate_git_command "git $2"; then
                [[ "${AIDO_DEBUG}" == "1" ]] && echo "[AIDO] ✓ Validating: $full_command" >&2
                run_with_session "$full_command" "$session_id"
                return $?
            else
                echo "[AIDO] ✗ BLOCKED: Git command not whitelisted: $2" >&2
                echo "" >&2
                echo "Allowed git commands:" >&2
                printf "  • %s\n" "${GIT_SAFE_COMMANDS[@]}" >&2
                return 1
            fi
            ;;
        aws)
            if validate_aws_command "aws $2"; then
                [[ "${AIDO_DEBUG:-0}" == "1" ]] && echo "[AIDO] ✓ Validating: $full_command" >&2
                run_with_session "$full_command" "$session_id"
                return $?
            else
                echo "[AIDO] ✗ BLOCKED: AWS operation not whitelisted: $2" >&2
                echo "" >&2
                echo "Allowed AWS patterns:" >&2
                printf "  • %s\n" "${AWS_SAFE_PATTERNS[@]}" >&2
                return 1
            fi
            ;;
        gh)
            if validate_gh_command "gh $2 $3 $4 $5"; then
                [[ "${AIDO_DEBUG:-0}" == "1" ]] && echo "[AIDO] ✓ Validating: $full_command" >&2
                run_with_session "$full_command" "$session_id"
                return $?
            else
                echo "[AIDO] ✗ BLOCKED: GitHub CLI command not whitelisted: $2" >&2
                echo "" >&2
                echo "Allowed GitHub CLI patterns:" >&2
                printf "  • %s\n" "${GH_SAFE_PATTERNS[@]}" >&2
                return 1
            fi
            ;;
        *)
            # Check if it's a PowerShell command (if in PowerShell session)
            if [[ -n "${PSVersionTable+x}" ]]; then
                if validate_powershell_command "$first_word"; then
                    [[ "${AIDO_DEBUG:-0}" == "1" ]] && echo "[AIDO] ✓ Validating: $full_command" >&2
                    run_with_session "$full_command" "$session_id"
                    return $?
                fi
            fi
            
            echo "[AIDO] ✗ BLOCKED: Command not whitelisted: $1" >&2
            echo "Run 'aido' without arguments to see allowed commands" >&2
            return 1
            ;;
    esac
}

main "$@"

