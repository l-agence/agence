#!/usr/bin/env bash
# aicmd: Agentic command/session wrapper for all shells
# Ensures correct environment, session capture, and validation for all commands/tests

# Source Agence environment
source "$(dirname "$0")/.agencerc"

# Source core functions (agence_session_day_dir, etc.)
source "$AI_ROOT/lib/env.sh"

# Source command validation library
source "$AI_ROOT/lib/aicmd-lib.sh"


# Universal agentic wrapper logic
set -e

# Generate unique session ID with agent prefix
_agent="${AI_AGENT:-copilot}"
session_id="${_agent}-$(date +%H%M%S)-$(head -c 4 /dev/urandom | od -An -tx1 | tr -d ' \n')"
session_dir="$(agence_session_day_dir)"
typescript_file="$session_dir/${session_id}.typescript"
meta_file="$session_dir/${session_id}.meta.json"

# Run command under script for full I/O capture (skip if pipe-pane active)
if [[ "${AGENCE_PIPE_PANE:-0}" == "1" ]]; then
    # tmux pipe-pane already capturing — run directly
    "${@}" 2>&1 | tee "$typescript_file"
    exit_code=${PIPESTATUS[0]:-$?}
elif command -v script &>/dev/null; then
    script --quiet --return --command "${*}" "$typescript_file"
    exit_code=$?
else
    # Fallback: run directly, capture output
    "${@}" | tee "$typescript_file"
    exit_code=${PIPESTATUS[0]:-$?}
fi

# Write minimal metadata
cat > "$meta_file" <<EOF
{
    "session_id": "$session_id",
    "command": "${*}",
    "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
    "exit_code": $exit_code,
    "typescript_file": "$typescript_file"
}
EOF

# If aisession is available, verify session
if [[ -x "$AI_BIN/aisession" ]]; then
    "$AI_BIN/aisession" status "$session_id"
    verify_exit=$?
    exit $verify_exit
else
    exit $exit_code
fi
