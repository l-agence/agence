#!/usr/bin/env bash

################################################################################
# Agence: Agentic Engineering Collaboration Environment
# Entry point — thin command router.
#
# Author: Stephane Korning 2026
# License: MIT License with Commons Clause
#
# Command prefix table (canonical — see lib/detect-env.sh + SYMBOLS.md):
#   agence <query>         → Chat mode (LLM query)
#   agence +<request>      → AI-routed mode (autonomous)
#   agence /<command>      → External/slash-command pass-through (validated)
#   agence !<tool>         → Tool launcher / system utility  (e.g. !aider, !bash)
#   agence ^<command>      → Agence control-plane command  (^init, ^reload, ^recon …)
#   agence @<agent> <q>    → Route to named agent persona
#
# ^  stays as the Agence-native prefix because agence is a hyperagent
#    (hypervisor for other tools).  /  is kept free for pass-through to inner
#    tools (Aider, Cline, Copilot …). See SYMBOLS.md for the full table.
#
# Architecture — lib modules (all sourced below):
#   lib/env.sh         — environment bootstrap (AGENCE_ROOT, PATH, pager suppression)
#   lib/detect-env.sh  — shell detection, path normalization, security validators
#   lib/format.sh      — terminal output formatting helpers
#   lib/shell-ui.sh    — PS1, tmux titles, ANSI color, swarm shell economy
#   lib/router.sh      — LLM provider routing (multi-provider curl layer)
#   lib/ailedger.sh    — append-only Merkle-chained decision ledger
#   lib/help.sh        — show_help, show_version, mode_symbols, mode_help
#   lib/chat.sh        — mode_chat, mode_ai_routed, resolve_provider, _peers_consensus
#   lib/external.sh    — mode_external (slash-command pass-through + git shortcuts)
#   lib/init.sh        — mode_init (^commands), init/reload/install/recon/scan
#   lib/knowledge.sh   — mode_knowledge, cmd_state, task/workflow/project matrix
#   lib/tools.sh       — launch_tool, mode_system, _parse_route, model resolver
#   lib/session.sh     — mode_session, save/commit/push, handoff/pickup/pause/resume
#   lib/completion.sh  — bash tab-completion
#
# TypeScript layer (requires bun):
#   lib/matrix.ts      — task scoring DAG: score = 10P + 25S + 100H, work-stealing scheduler
#   lib/commands.ts    — knowledge management (preferred over bash fallback when bun available)
#   lib/router.ts      — typed LLM routing
#   lib/session.ts     — session lifecycle
#   lib/audit.ts       — audit trail
#   lib/peers.ts       — multi-model consensus
#   lib/watch.ts       — file/event watching
#   lib/ledger.ts      — shared ledger shard
################################################################################

set -u  # Exit on undefined variable

# ── Core bootstrap ───────────────────────────────────────────────────────────
# env.sh MUST be first: sets AGENCE_ROOT, AGENCE_LIB, PATH, pager vars.
source "$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/lib/env.sh"

# ── Low-level primitives (bash, portable, standalone) ────────────────────────
source "${AGENCE_LIB}/detect-env.sh"   # shell detection, path normalization, security
source "${AGENCE_LIB}/format.sh"       # agence_detect_format, agence_format_legend
source "${AGENCE_LIB}/shell-ui.sh"     # PS1, tmux, ANSI colors, swarm shell economy
source "${AGENCE_LIB}/router.sh"       # LLM provider routing (curl-based)
source "${AGENCE_LIB}/ailedger.sh"     # append-only decision ledger

# ── Higher-level command modules ─────────────────────────────────────────────
source "${AGENCE_LIB}/help.sh"         # show_help, show_version, mode_symbols
source "${AGENCE_LIB}/chat.sh"         # mode_chat, mode_ai_routed, resolve_provider (delegates to router.ts)
source "${AGENCE_LIB}/external.sh"     # mode_external (slash-commands, git shortcuts)
source "${AGENCE_LIB}/init.sh"         # mode_init dispatcher + resolve_org_path
source "${AGENCE_LIB}/setup.sh"        # init_agence_environment, reload, install (^init chain)
source "${AGENCE_LIB}/knowledge.sh"    # mode_knowledge, cmd_state, scan/reindex, task/wf/project matrix
source "${AGENCE_LIB}/tools.sh"        # launch_tool, mode_system (!aider, !bash …)
source "${AGENCE_LIB}/session.sh"      # mode_session, save/commit/push, handoffs
source "${AGENCE_LIB}/completion.sh"   # bash tab-completion

# ============================================================================
# AGENT PREFIX PARSER
# ============================================================================
# Parse optional @agent prefix before any mode dispatch.
# Sets AGENCE_AGENT_PARAM and strips the prefix from input.
# Example: "agence @ralph +plan-vpc" → agent=ralph, input="+plan-vpc"

parse_agent_prefix() {
  local input="$1"
  if [[ "$input" =~ ^@([A-Za-z0-9_-]*)[[:space:]]+(.*) ]]; then
    local agent_name="${BASH_REMATCH[1]}"
    _PARSED_INPUT="${BASH_REMATCH[2]}"
    [[ -z "$agent_name" ]] && export AGENCE_AGENT_PARAM="@" || export AGENCE_AGENT_PARAM="$agent_name"
  else
    export AGENCE_AGENT_PARAM="@"
    _PARSED_INPUT="$input"
  fi
}

get_agent_id() {
  echo "${AI_AGENT:-${AIDO_AGENT:-ai-agent}}"  # AI_AGENT canonical; AIDO_AGENT compat fallback
}

# ============================================================================
# MAIN — COMMAND ROUTER
# ============================================================================

main() {
  local input="$*"

  # Argument validation
  if [[ -z "$input" ]]; then
    show_help
    exit 0
  fi

  # Parse @agent prefix first (sets AGENCE_AGENT_PARAM, strips from input)
  parse_agent_prefix "$input"
  input="$_PARSED_INPUT"

  # Early exits: local-only commands that NEVER need the LLM router
  case "$1" in
    --help|-h|help)
      show_help
      exit 0
      ;;
    --version|-v|version)
      show_version
      exit 0
      ;;
    symbols)
      mode_symbols
      exit 0
      ;;
    _resolve_provider)
      resolve_provider
      exit $?
      ;;
    status)
      mode_system "status"
      exit 0
      ;;
    config)
      mode_system "config"
      exit 0
      ;;
    # Knowledge commands: never need LLM router
    # Supports both: 'agence plan list' AND 'agence ^plan list'
    lesson|log|plan|todo|note|fault|issue|task|job|workflow|project)
      mode_knowledge "$1" "${*:2}"
      exit $?
      ;;
    audit)
      # Ledger audit: agence ^audit trail|show|agent|session|diff|stats
      local _audit_ts="${AGENCE_ROOT}/lib/audit.ts"
      if command -v bun &>/dev/null && [[ -f "$_audit_ts" ]]; then
        bun run "$_audit_ts" ${*:2}
      else
        echo "Error: ^audit requires bun + lib/audit.ts" >&2
        exit 1
      fi
      exit $?
      ;;
    ledger)
      # Shared ledger shard: agence ^ledger init|list|show|add|sync|status
      local _ledger_ts="${AGENCE_ROOT}/lib/ledger.ts"
      if command -v bun &>/dev/null && [[ -f "$_ledger_ts" ]]; then
        bun run "$_ledger_ts" ${*:2}
      else
        echo "Error: ^ledger requires bun + lib/ledger.ts" >&2
        exit 1
      fi
      exit $?
      ;;
    session)
      mode_session "${*:2}"
      exit $?
      ;;
    swarm)
      bash "$AGENCE_ROOT/bin/swarm" ${*:2}
      exit $?
      ;;
    index)
      scan_knowledge_bases
      exit $?
      ;;
    reindex)
      reindex_knowledge_bases "${*:2}"
      exit $?
      ;;
    handoff)
      handoff_to_agent "${*:2}"
      exit $?
      ;;
    pickup)
      pickup_handoff "${*:2}"
      exit $?
      ;;
    pause)
      pause_session "${*:2}"
      exit $?
      ;;
    resume)
      resume_session "${*:2}"
      exit $?
      ;;
    # ── Plural shortcuts (implied ^ prefix) ────────────────────────────────
    tasks)      mode_knowledge "task" "status ${*:2}"; exit $? ;;
    projects)   mode_knowledge "project" "status ${*:2}"; exit $? ;;
    workflows)  mode_knowledge "workflow" "status ${*:2}"; exit $? ;;
    todos)      mode_knowledge "todo" "status ${*:2}"; exit $? ;;
    notes)      mode_knowledge "note" "status ${*:2}"; exit $? ;;
    jobs)       mode_knowledge "job" "status ${*:2}"; exit $? ;;
    issues)     mode_knowledge "issue" "status ${*:2}"; exit $? ;;
    plans)      mode_knowledge "plan" "status ${*:2}"; exit $? ;;
    sessions)   mode_session "status ${*:2}"; exit $? ;;
    faults)     mode_knowledge "fault" "list ${*:2}"; exit $? ;;
    logs)       mode_knowledge "log" "list ${*:2}"; exit $? ;;
    lessons)    mode_knowledge "lesson" "list ${*:2}"; exit $? ;;
    # ── Other bare commands (implied ^ prefix) ─────────────────────────────
    state)
      cmd_state
      exit $?
      ;;
    regen)
      local _matrix_ts="${AGENCE_ROOT}/lib/matrix.ts"
      if command -v bun &>/dev/null && [[ -f "$_matrix_ts" ]]; then
        bun run "$_matrix_ts" dashboard
      else
        echo "Error: regen requires bun + lib/matrix.ts" >&2
        exit 1
      fi
      exit $?
      ;;
    recall)
      if [[ -z "${*:2}" ]]; then
        echo "Usage: agence recall <pattern>" >&2
        exit 1
      fi
      "$AGENCE_BIN/figrep" "$AGENCE_ROOT/hermetic" ${*:2}
      exit $?
      ;;
    peers)
      local _peers_ts="${AGENCE_ROOT}/lib/peers.ts"
      if command -v bun &>/dev/null && [[ -f "$_peers_ts" ]]; then
        bun run "$_peers_ts" ${*:2}
      else
        echo "Error: peers requires bun + lib/peers.ts" >&2
        exit 1
      fi
      exit $?
      ;;
    watch)
      local _watch_ts="${AGENCE_ROOT}/lib/watch.ts"
      if command -v bun &>/dev/null && [[ -f "$_watch_ts" ]]; then
        bun run "$_watch_ts" ${*:2}
      else
        echo "Error: watch requires bun + lib/watch.ts" >&2
        exit 1
      fi
      exit $?
      ;;
    expect)
      local _watch_ts="${AGENCE_ROOT}/lib/watch.ts"
      if command -v bun &>/dev/null && [[ -f "$_watch_ts" ]]; then
        bun run "$_watch_ts" expect ${*:2}
      else
        echo "Error: expect requires bun + lib/watch.ts" >&2
        exit 1
      fi
      exit $?
      ;;
    aido)
      if [[ -z "${*:2}" ]]; then
        echo "Usage: agence aido <tool> [args...]" >&2
        exit 1
      fi
      bash "$AGENCE_ROOT/bin/aido" ${*:2}
      exit $?
      ;;
    init)
      init_agence_environment
      exit $?
      ;;
    reload)
      reload_agence_context
      exit $?
      ;;
    commit)
      commit_agence_changes "${*:2}"
      exit $?
      ;;
    push)
      push_agence_changes
      exit $?
      ;;
    save)
      save_session "${*:2}"
      exit $?
      ;;
    learn)
      learn_agence_changes
      exit $?
      ;;
  esac

  local first_char="${input:0:1}"

  # Mode detection and routing
  case "$first_char" in
    "")
      # Empty input
      show_help
      exit 0
      ;;
    "+")
      # AI-routed mode: LLM decides what to do
      mode_ai_routed "${input:1}"
      ;;
    "/")
      # External command: validated execution
      mode_external "${input:1}"
      ;;
    "!")
      # System command: shell utilities
      mode_system "${input:1}"
      ;;
    "^")
      # Special initialization commands
      mode_init "${input:1}"
      ;;
    "~")
      # Human-scoped recall: search masonic (gated persistent memory)
      local _tilde_cmd="${input:1}"
      local _tilde_verb="${_tilde_cmd%% *}"
      local _tilde_args="${_tilde_cmd#$_tilde_verb}"
      _tilde_args="${_tilde_args# }"
      case "$_tilde_verb" in
        "recall")
          if [[ -z "$_tilde_args" ]]; then
            echo "Usage: agence ~recall <pattern> [grep-options...]" >&2
            echo "Searches: hermetic/masonic/ (gated persistent memory)" >&2
            return 1
          fi
          "$AGENCE_BIN/figrep" "$AGENCE_ROOT/hermetic/masonic" $_tilde_args
          ;;
        "todo"|"todos")
          # ~todo → ^todo (hermetic shortcut)
          local _sub="${_tilde_args%% *}"
          [[ "$_tilde_verb" == "todos" && -z "$_sub" ]] && _sub="status"
          mode_knowledge "todo" "${_sub:-list} ${_tilde_args#$_sub}"
          ;;
        "note"|"notes")
          # ~note → ^note (hermetic shortcut)
          local _sub="${_tilde_args%% *}"
          [[ "$_tilde_verb" == "notes" && -z "$_sub" ]] && _sub="status"
          mode_knowledge "note" "${_sub:-list} ${_tilde_args#$_sub}"
          ;;
        *)
          echo "Error: Unknown ~ command: $_tilde_verb" >&2
          echo "Available: ~recall, ~todo, ~todos, ~note, ~notes" >&2
          return 1
          ;;
      esac
      ;;
    *)
      # Default: chat mode
      mode_chat "$input"
      ;;
  esac

  exit $?
}

# ============================================================================
# PROVIDER RESOLUTION
# ============================================================================
# Determines which LLM provider to use (auto-detect cascade).
# Never calls an LLM — pure config resolution.
#
# Priority:
#   1. Explicit @agent routing (AGENCE_AGENT_PARAM set by parse_agent_prefix)
#   2. AGENCE_DEFAULT_PROVIDER env var (set in .agencerc or user env)
#   3. Auto-detect: gh copilot CLI available → pilot
#   4. Auto-detect: ANTHROPIC_API_KEY set → claude
#   5. Auto-detect: OPENAI_API_KEY set → openai
#   6. none (offline/CI — callers must handle gracefully)


# ============================================================================
# ENTRY POINT
# ============================================================================
main "$@"
