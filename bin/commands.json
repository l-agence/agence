{
  "comment": "Agence Permitted External Commands (mode /)",
  "description": "Whitelist of external commands that can be executed via 'agence /<command>'",
  "updated": "2026-03-05",
  "version": "1.0.0",

  "terraform-commands": {
    "terraform-plan": true,
    "terraform-apply": true,
    "terraform-validate": true,
    "terraform-fmt": true,
    "terraform-state": true
  },

  "git-commands": {
    "git-status": true,
    "git-log": true,
    "git-diff": true,
    "git-branch": true,
    "git-tag": true,
    "git-stash": true,
    "git-blame": true,
    "git-push": true,
    "git-pull": true,
    "git-merge": true,
    "git-rebase": true,
    "git-clone": true,
    "git-init": true
  },

  "git-shortcut-commands": {
    "_comment": "Shortcuts handled directly in mode_external via route_git_command (AIPOLICY tier model). Not subject to commands.json whitelist — these bypass the jq check. Listed here for documentation only.",
    "_tiers": "T0=auto-execute T2=warn+confirm T3=blocked",
    "_conflicts": "aider also uses /git /commit /diff in its REPL — different tool context, no runtime collision",
    "git":    { "tier": "router", "desc": "Generic /git <subcmd> [args...] — full AIPOLICY tier routing" },
    "status": { "tier": "T0",     "desc": "git status — pure read-only (AIPOLICY whitelist)" },
    "log":    { "tier": "T0",     "desc": "git log [args] — pure read-only (AIPOLICY whitelist)" },
    "remote": { "tier": "T0",     "desc": "git remote [args] — pure read-only (AIPOLICY whitelist)" },
    "fetch":  { "tier": "T2",     "desc": "git fetch — mutates .git/refs (AIPOLICY blacklist, warn+confirm)" },
    "pull":   { "tier": "T2",     "desc": "git pull — merges remote state (AIPOLICY blacklist, warn+confirm)" },
    "push":   { "tier": "T2",     "desc": "git push — handled by existing /push handler (warn+confirm)" },
    "commit": { "tier": "T2",     "desc": "git commit — handled by existing /commit handler (message+confirm)" }
  },

  "aws-commands": {
    "aws-list-buckets": true,
    "aws-describe-instances": true,
    "aws-describe-vpcs": true,
    "aws-describe-security-groups": true,
    "aws-get-caller-identity": true,
    "aws-list-stacks": true,
    "aws-describe-clusters": true
  },

  "tools": {
    "gh": true,
    "copilot": true,
    "copilot-cli": true,
    "aider": true,
    "cursor": true,
    "docker": true,
    "kubernetes": true,
    "ollama": true,
    "azure": true,
    "jfrog": true,
    "terraform": true,
    "python": true
  },

  "notes": [
    "Commands can be invoked via: agence /<command>",
    "Example: agence /terraform-plan",
    "Example: agence /git-status",
    "Example: agence /aws-list-buckets",
    "Whitelist enforced for security and auditability",
    "Add new commands by extending this file",
    "Each command must be explicitly permitted"
  ]
}
