#!/usr/bin/env bash

################################################################################
# aisession: Session Management Tool
# 
# Manages AI agent session persistence (STDOUT/STDERR/STDIN capture)
# and provides verification, review, and handoff capabilities.
#
# Usage:
#   aisession <sessionid>              - Show session status (default = verify)
#   aisession status <sessionid>       - Same as above
#   aisession resume <sessionid>       - Reread session, set as current
#   aisession list                     - List all sessions (text table)
#   aisession handoff <sessionid> @agent/@user  - Handoff metadata (TBD)
#
# Exit Codes:
#   0   - Success (session verified/retrieved)
#   254 - Verification denied (workflow blocked)
#   1   - Error (missing session, invalid args, etc.)
################################################################################

set -e

# Source canonical environment (sets AI_ROOT, AI_BIN, etc.)
source "$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/lib/env.sh"

SESSION_DIR="$AI_ROOT/nexus/.aisessions"
LEDGER_DIR="$AI_ROOT/nexus/.ailedger"

# Source shared ledger library
source_if_exists "$AGENCE_LIB/ailedger.sh"

# ============================================================================
# HELPERS: Exit code parsing, metadata update, ailedger
# ============================================================================

# Parse the actual exit code embedded in a typescript file
# Looks for last: === AI_EXIT_CODE: N === line
parse_exit_code_from_typescript() {
    local typescript_file="$1"
    local parsed_exit
    parsed_exit=$(grep -oP '=== AI_EXIT_CODE: \K[0-9]+' "$typescript_file" 2>/dev/null | tail -1)
    echo "${parsed_exit:-254}"
}

# Update session metadata with verified exit code
update_metadata_verified() {
    local meta_file="$1"
    local actual_exit="$2"
    local verified_at
    verified_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

    if command -v jq &>/dev/null; then
        local tmp
        tmp=$(mktemp)
        jq --argjson code "$actual_exit" \
           --arg ts "$verified_at" \
           '.exit_code = $code | .actual_exit_code = $code | .verification_status = "verified" | .verified_at = $ts' \
           "$meta_file" > "$tmp" && mv "$tmp" "$meta_file"
    else
        # Fallback: sed-based update (best-effort)
        sed -i "s/\"exit_code\": [0-9]*/\"exit_code\": $actual_exit/" "$meta_file"
        sed -i "s/\"verification_status\": \"pending\"/\"verification_status\": \"verified\"/" "$meta_file"
    fi
}

# Append verified entry to .ailedger via shared lib/ailedger.sh
create_ailedger_entry() {
    local sid="$1"
    local exit_code="$2"
    local command_str="$3"
    ailedger_append "verify" "session-verified" "$sid" "$command_str" "$exit_code"
}

# ============================================================================
# SESSION STATUS / VERIFICATION (default mode)
# ============================================================================

session_status() {
    local sid="${1:-}"
    
    if [[ -z "$sid" ]]; then
        echo "ERROR: Session ID required" >&2
        echo "Usage: aisession <sessionid>" >&2
        echo "       aisession status <sessionid>" >&2
        echo "" >&2
        echo "The SESSION_ID must match a .typescript file in nexus/.aisessions/" >&2
        return 1
    fi
    
    local typescript_file
    local meta_file
    # Search day-sharded subdirs and flat (legacy) for the session
    typescript_file=$(find "$SESSION_DIR" -name "${sid}.typescript" -type f 2>/dev/null | head -1)
    meta_file=$(find "$SESSION_DIR" -name "${sid}.meta.json" -type f 2>/dev/null | head -1)
    
    # Validation
    if [[ -z "$typescript_file" || ! -f "$typescript_file" ]]; then
        echo "[SESSION] ✗ Session not found: $sid" >&2
        echo "[SESSION]   Searched: $SESSION_DIR/*/" >&2
        return 1
    fi
    
    if [[ ! -f "$meta_file" ]]; then
        echo "[SESSION] ✗ Session metadata missing: $sid" >&2
        echo "[SESSION]   Expected: $meta_file" >&2
        return 1
    fi
    
    # Extract metadata
    local exit_code command timestamp typescript_size typescript_lines
    
    if command -v jq &>/dev/null; then
        exit_code=$(jq -r '.exit_code' "$meta_file" 2>/dev/null || echo "?")
        command=$(jq -r '.command' "$meta_file" 2>/dev/null || echo "?")
        timestamp=$(jq -r '.timestamp' "$meta_file" 2>/dev/null || echo "?")
    else
        exit_code=$(grep -o '"exit_code": [0-9]*' "$meta_file" 2>/dev/null | grep -o '[0-9]*' || echo "?")
        command=$(grep -oP '"command": "\K[^"]*' "$meta_file" 2>/dev/null || echo "?")
        timestamp=$(grep -oP '"timestamp": "\K[^"]*' "$meta_file" 2>/dev/null || echo "?")
    fi
    
    typescript_size=$(wc -c < "$typescript_file" 2>/dev/null || echo "?")
    typescript_lines=$(wc -l < "$typescript_file" 2>/dev/null || echo "?")
    
    # Display session info
    echo ""
    echo "================================================================================"
    echo "  SESSION VERIFICATION REQUIRED"
    echo "================================================================================"
    echo ""
    echo "Session ID:   $sid"
    echo "Timestamp:    $timestamp"
    echo "Command:      $command"
    echo "Exit Code:    $exit_code"
    echo "File:         $typescript_file"
    echo "Size:         $typescript_size bytes"
    echo "Lines:        $typescript_lines"
    echo ""
    echo "================================================================================"
    echo "  SESSION OUTPUT (last 30 lines)"
    echo "================================================================================"
    echo ""
    
    tail -30 "$typescript_file" 2>/dev/null || echo "[No output available]"
    
    echo ""
    echo "================================================================================"
    echo "  VERIFICATION"
    echo "================================================================================"
    echo ""
    
    if [[ "$exit_code" == "0" ]]; then
        echo "  Status: ✓ SUCCESS (exit code 0)"
    elif [[ "$exit_code" != "?" ]]; then
        echo "  Status: ✗ FAILED (exit code $exit_code)"
    else
        echo "  Status: ? UNKNOWN (could not read exit code)"
    fi

    # Non-interactive: use ^ask to reach human via signal layer
    # Triggered by: AIDO_NO_VERIFY=1, no stdin TTY, or shellspec test runner
    if [[ "${AIDO_NO_VERIFY:-0}" == "1" ]] || \
       [[ -n "${SHELLSPEC_TMPDIR:-}" ]] || \
       [[ ! -t 0 ]]; then
        # ShellSpec: always auto-pass (test harness)
        if [[ -n "${SHELLSPEC_TMPDIR:-}" ]] || [[ "${AIDO_NO_VERIFY:-0}" == "1" ]]; then
            echo "  [aisession] Non-interactive: verification auto-passed" >&2
            local actual_exit
            actual_exit=$(parse_exit_code_from_typescript "$typescript_file" 2>/dev/null || echo "0")
            update_metadata_verified "$meta_file" "$actual_exit" 2>/dev/null || true
            return 0
        fi
        # Agentic context: escalate to human via ^ask
        if command -v airun &>/dev/null; then
            echo "  [aisession] Agentic context: escalating verification via ^ask" >&2
            local ask_summary="verify session ${sid:0:8} (exit $exit_code)"
            if eval "$(airun signal ask "$ask_summary")"; then
                if [[ "${_SIGNAL_APPROVED:-0}" == "1" ]]; then
                    local actual_exit
                    actual_exit=$(parse_exit_code_from_typescript "$typescript_file" 2>/dev/null || echo "0")
                    update_metadata_verified "$meta_file" "$actual_exit" 2>/dev/null || true
                    return 0
                fi
            fi
            echo "  [aisession] ^ask denied or timed out — workflow blocked" >&2
            return 254
        fi
        # Fallback: no airun available, auto-pass
        echo "  [aisession] Non-interactive: verification auto-passed" >&2
        local actual_exit
        actual_exit=$(parse_exit_code_from_typescript "$typescript_file" 2>/dev/null || echo "0")
        update_metadata_verified "$meta_file" "$actual_exit" 2>/dev/null || true
        return 0
    fi

    echo ""
    echo "Confirm this session output before proceeding?"
    echo ""
    echo "  - Type 'yes' to verify and proceed (exit 0)"
    echo "  - Type 'no'  to reject (exit 254, workflow blocked)"
    echo "  - Type 'show' to display full output"
    echo "  - Type 'meta' to show metadata JSON"
    echo ""
    
    # Read user input
    read -t 30 -p "Your choice: " -r choice || {
        echo ""
        echo "✗ Verification timeout (no input within 30 seconds)"
        return 1
    }
    
    case "$choice" in
        yes|YES|y|Y)
            echo ""
            echo "✓ Session verified. Proceeding..."
            # Parse actual exit code from typescript and update metadata
            local actual_exit
            actual_exit=$(parse_exit_code_from_typescript "$typescript_file")
            update_metadata_verified "$meta_file" "$actual_exit"
            create_ailedger_entry "$sid" "$actual_exit" "$command"
            echo "  [session] exit_code updated → $actual_exit | ledger entry written"
            return 0
            ;;
        no|NO|n|N)
            echo ""
            echo "✗ Session NOT verified. Workflow blocked."
            echo "   To retry: aisession $sid"
            return 254
            ;;
        show|SHOW)
            echo ""
            echo "================================================================================"
            echo "  FULL SESSION OUTPUT"
            echo "================================================================================"
            echo ""
            cat "$typescript_file"
            echo ""
            echo "================================================================================"
            echo ""
            # Recursive call to re-prompt
            session_status "$sid"
            return $?
            ;;
        meta|META)
            echo ""
            echo "================================================================================"
            echo "  SESSION METADATA"
            echo "================================================================================"
            echo ""
            cat "$meta_file"
            echo ""
            echo "================================================================================"
            echo ""
            # Recursive call to re-prompt
            session_status "$sid"
            return $?
            ;;
        *)
            echo ""
            echo "✗ Invalid choice: '$choice'"
            echo "   Please type: yes, no, show, or meta"
            # Recursive call to re-prompt
            session_status "$sid"
            return $?
            ;;
    esac
}

# ============================================================================
# SESSION RESUME
# ============================================================================

session_resume() {
    local sid="${1:-}"
    
    if [[ -z "$sid" ]]; then
        echo "ERROR: Session ID required" >&2
        echo "Usage: session resume <sessionid>" >&2
        echo "" >&2
        echo "Sets the session as \"current\" and imports it to the shell context." >&2
        return 1
    fi
    
    local meta_file="$SESSION_DIR/${sid}.meta.json"
    
    if [[ ! -f "$meta_file" ]]; then
        echo "[SESSION] ✗ Session not found: $sid" >&2
        return 1
    fi
    
    # Extract command and other metadata
    local last_command=""
    local last_exit=""
    
    if command -v jq &>/dev/null; then
        last_command=$(jq -r '.command' "$meta_file" 2>/dev/null)
        last_exit=$(jq -r '.exit_code' "$meta_file" 2>/dev/null)
    else
        last_command=$(grep -oP '"command": "\K[^"]*' "$meta_file" 2>/dev/null)
        last_exit=$(grep -o '"exit_code": [0-9]*' "$meta_file" 2>/dev/null | grep -o '[0-9]*')
    fi
    
    # Set environment variables for resumed session
    export AI_CURRENT_SESSION="$sid"
    export AI_LAST_COMMAND="$last_command"
    export AI_LAST_EXIT="$last_exit"
    
    echo ""
    echo "✓ Session resumed: $sid"
    echo ""
    echo "Command: $last_command"
    echo "Exit Code: $last_exit"
    echo ""
    echo "Environment variables set:"
    echo "  AI_CURRENT_SESSION=$sid"
    echo "  AI_LAST_COMMAND=$last_command"
    echo "  AI_LAST_EXIT=$last_exit"
    echo ""
    
    return 0
}

# ============================================================================
# SESSION LIST
# ============================================================================

session_list() {
    if [[ ! -d "$SESSION_DIR" ]]; then
        echo "[SESSION] ✗ No sessions directory: $SESSION_DIR" >&2
        return 1
    fi
    
    local sessions
    mapfile -t sessions < <(find "$SESSION_DIR" -name "*.meta.json" -type f 2>/dev/null | sort -r)
    
    if [[ ${#sessions[@]} -eq 0 ]]; then
        echo "No sessions found in $SESSION_DIR"
        return 0
    fi
    
    # Print header
    printf "%-45s %-40s %-6s %s\n" "SESSION ID" "COMMAND" "EXIT" "TIMESTAMP"
    printf '%s\n' "$(printf '=%.0s' {1..125})"
    
    # Print each session
    local meta_file
    for meta_file in "${sessions[@]}"; do
        local sid=$(basename "$meta_file" .meta.json)
        local cmd exit_code timestamp
        
        if command -v jq &>/dev/null; then
            cmd=$(jq -r '.command' "$meta_file" 2>/dev/null | cut -c1-40)
            exit_code=$(jq -r '.exit_code' "$meta_file" 2>/dev/null)
            timestamp=$(jq -r '.timestamp' "$meta_file" 2>/dev/null | cut -c1-20)
        else
            cmd=$(grep -oP '"command": "\K[^"]*' "$meta_file" 2>/dev/null | cut -c1-40)
            exit_code=$(grep -o '"exit_code": [0-9]*' "$meta_file" 2>/dev/null | grep -o '[0-9]*')
            timestamp=$(grep -oP '"timestamp": "\K[^"]*' "$meta_file" 2>/dev/null | cut -c1-20)
        fi
        
        # Color exit code
        local exit_colored="$exit_code"
        if [[ "$exit_code" == "0" ]]; then
            exit_colored="✓ $exit_code"
        else
            exit_colored="✗ $exit_code"
        fi
        
        printf "%-45s %-40s %-6s %s\n" "$sid" "$cmd" "$exit_colored" "$timestamp"
    done
    
    return 0
}

# ============================================================================
# SESSION HANDOFF
# ============================================================================

session_handoff() {
    local sid="${1:-}"
    local agent="${2:-}"

    if [[ -z "$sid" || -z "$agent" ]]; then
        echo "Usage: session handoff <sessionid> @<agent>/@<user>" >&2
        echo "This feature copies session metadata to another agent's context." >&2
        return 1
    fi

    local meta_file
    local typescript_file
    meta_file=$(find "$SESSION_DIR" -name "${sid}.meta.json" -type f 2>/dev/null | head -1)
    typescript_file=$(find "$SESSION_DIR" -name "${sid}.typescript" -type f 2>/dev/null | head -1)
    local target_dir="$SESSION_DIR/$agent"
    mkdir -p "$target_dir"

    if [[ -z "$meta_file" || ! -f "$meta_file" || -z "$typescript_file" || ! -f "$typescript_file" ]]; then
        echo "[SESSION] ✗ Session or metadata not found: $sid" >&2
        return 1
    fi

    cp "$meta_file" "$target_dir/"
    cp "$typescript_file" "$target_dir/"
    echo "[SESSION] ✓ Handoff complete: $sid → $agent"
    echo "  Metadata and transcript copied to $target_dir/"
    return 0
}

# ============================================================================
# SESSION INIT — called by aibash before script(1) starts recording
# Creates the agent subdir and writes initial .meta.json.
# The .typescript file is created by script(1) itself — not pre-created here.
# ============================================================================

session_init() {
    local sid="${1:-}"
    local role="${2:-shared}"
    local agent="${3:-unknown}"
    local shell_type="${4:-bash}"
    local git_root="${5:-$AI_ROOT}"

    if [[ -z "$sid" ]]; then
        echo "[SESSION] ✗ init requires a session ID" >&2
        echo "Usage: aisession init <session-id> [role] [agent] [shell] [git-root]" >&2
        return 1
    fi

    # Create day-sharded session directory
    local day_dir
    day_dir="$(agence_session_day_dir)"

    local meta_file="$day_dir/${sid}.meta.json"
    local typescript_file="$day_dir/${sid}.typescript"
    local ts
    ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

    # Write initial metadata — exit_code is null until session ends
    printf '{\n  "session_id": "%s",\n  "agent": "%s",\n  "role": "%s",\n  "shell": "%s",\n  "git_root": "%s",\n  "timestamp": "%s",\n  "status": "recording",\n  "exit_code": null,\n  "verification_status": "pending",\n  "typescript": "%s"\n}\n' \
        "$sid" "$agent" "$role" "$shell_type" "$git_root" "$ts" "$typescript_file" \
        > "$meta_file"

    echo "[SESSION] ✓ Initialized: $sid  agent=$agent  role=$role"
    echo "[SESSION]   typescript → $typescript_file"
    return 0
}

# ============================================================================  
# BUN DELEGATION HELPER
# ============================================================================  

# Find Bun executable; returns path on stdout, exits 1 if absent.
_bun_cmd() {
    if command -v bun &>/dev/null; then
        command -v bun
    elif [[ -x "$HOME/.bun/bin/bun" ]]; then
        echo "$HOME/.bun/bin/bun"
    else
        return 1
    fi
}

# ============================================================================  
# MAIN ROUTER
# ============================================================================  

main() {
    local SESSION_SUBCOMMAND="${1:-status}"
    local SESSION_ID="${2:-}"

    # Delegate read-heavy subcommands to Bun when available;
    # bash implementations remain as fallback.
    local bun
    bun=$(_bun_cmd 2>/dev/null) || bun=""

    case "$SESSION_SUBCOMMAND" in
        init)
            if [[ -n "$bun" ]]; then
                "$bun" run "$AGENCE_LIB/session.ts" init "${@:2}"
            else
                session_init "$SESSION_ID" "${3:-}" "${4:-}" "${5:-}" "${6:-}"
            fi
            ;;
        status)
            # Interactive verification prompt — stays in bash
            session_status "$SESSION_ID"
            ;;
        resume)
            if [[ -n "$bun" ]]; then
                "$bun" run "$AGENCE_LIB/session.ts" resume "$SESSION_ID"
            else
                session_resume "$SESSION_ID"
            fi
            ;;
        list)
            if [[ -n "$bun" ]]; then
                "$bun" run "$AGENCE_LIB/session.ts" list
            else
                session_list
            fi
            ;;
        handoff)
            session_handoff "$SESSION_ID" "${3:-}"
            ;;
        *)
            # Default: treat first arg as session ID for verification
            session_status "$SESSION_SUBCOMMAND"
            ;;
    esac
}

main "$@"
