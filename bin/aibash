#!/usr/bin/env bash
# aibash: Agentic (robot) Bash shell — THIN DISPATCHER
#
# Security envelope (bash): PATH restriction, env cleanup, signal traps, sandbox
# Config + session init (Bun): airun aibash init → eval-safe exports
# Exec layer (bash): script(1) / pipe-pane / direct
#
# Usage:
#   aibash [--session <id>] [--agent <name>] [--role <role>] [--shell <bash>] [--] [command ...]

set -euo pipefail

# ── Source canonical environment ──────────────────────────────────────────────
source "$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/lib/env.sh"

# Help — handle before security lockdown (needs full PATH for Bun help)
if [[ "${1:-}" == "--help" || "${1:-}" == "help" || "${1:-}" == "-h" ]]; then
	exec "$AGENCE_ROOT/bin/airun" aibash help
fi

# ── SECURITY ENVELOPE (must stay in bash — process-level isolation) ───────────

# Restrict PATH to minimal safe binaries
if [[ -n "${AI_BIN:-}" ]]; then
	export PATH="/usr/bin:/bin:$AI_BIN"
else
	export PATH="/usr/bin:/bin"
fi

# Unset risky env vars
unset HISTFILE HISTSIZE HISTCONTROL HISTIGNORE PROMPT_COMMAND BASH_ENV ENV CDPATH

# Disable Bash features that allow escape
set +o history
set +o braceexpand
set +o histexpand
set +o noglob
shopt -u extglob
shopt -u progcomp

# Block dangerous signals
trap '' SIGINT SIGQUIT SIGTSTP SIGSTOP

# Source policy enforcement
[[ -f "$GIT_ROOT/bin/aipolicy" ]] && source "$GIT_ROOT/bin/aipolicy"
[[ -f "$GIT_ROOT/codex/LAWS.sh" ]] && source "$GIT_ROOT/codex/LAWS.sh"

# Source format library
[[ -f "$GIT_ROOT/lib/format.sh" ]] && source "$GIT_ROOT/lib/format.sh" && export _AGENCE_FMT="${_AGENCE_FMT:-text}"

# ── DELEGATE CONFIG TO BUN (airun aibash init) ───────────────────────────────
# aibash.ts handles: arg parsing, defaults, session ID generation, metadata init.
# Returns eval-safe shell exports to stdout. Human messages to stderr.
#
# PATH was restricted above, but bun lives outside /usr/bin. Use full path.

_bun_config="$("$AGENCE_ROOT/bin/airun" aibash init "$@" 2>/dev/null)" || {
	# Bun not available — fall back to minimal bash defaults
	AI_AGENT="${AI_AGENT:-@}"
	AI_ROLE="${AI_ROLE:-agentic}"
	AI_SESSION="${AI_SESSION:-robo$$}"
	SHELL_TYPE="${SHELL_TYPE:-bash}"
	SESSION_LOG="${GIT_ROOT}/nexus/.aisessions/${AI_SESSION}.typescript"
	SESSION_META="${GIT_ROOT}/nexus/.aisessions/${AI_SESSION}.meta.json"
	_AIBASH_PIPE_PANE=0
	_AIBASH_COMMAND=""
	export AI_AGENT AI_ROLE AI_SESSION SHELL_TYPE SESSION_LOG SESSION_META
	mkdir -p "${GIT_ROOT}/nexus/.aisessions" 2>/dev/null || true
	echo "[aibash] Bun unavailable, using bash fallback" >&2
}

if [[ -n "${_bun_config:-}" ]]; then
	eval "$_bun_config"
fi
unset _bun_config

export GIT_ROOT AI_ROLE AI_SESSION AI_AGENT SESSION_LOG SESSION_META

# ── SANDBOX PATH ENFORCEMENT ─────────────────────────────────────────────────

sandbox_cd() {
	local target="${1:-.}"
	local abs_path
	abs_path="$(cd "$target" 2>/dev/null && pwd)" || {
		echo "[SANDBOX] ✗ Invalid directory: $target" >&2
		return 1
	}
	if [[ "$abs_path" == "$GIT_ROOT"* ]]; then
		cd "$abs_path" || return 1
	else
		echo "[SANDBOX] ✗ Access outside workspace denied: $target" >&2
		return 1
	fi
}

# ── AWAITING INPUT NOTIFICATION ───────────────────────────────────────────────

notify_awaiting() {
	local marker="${GIT_ROOT}/nexus/sessions/${AI_SESSION}.awaiting"
	mkdir -p "$(dirname "$marker")" 2>/dev/null || true
	echo "$(date -u +%Y-%m-%dT%H:%M:%SZ)" > "$marker"
	printf '\033]0;⏳ %s | aibash WAITING\007' "${AI_AGENT}" 2>/dev/null || true
}

clear_awaiting() {
	local marker="${GIT_ROOT}/nexus/sessions/${AI_SESSION}.awaiting"
	rm -f "$marker" 2>/dev/null || true
	printf '\033]0;🤖 %s | aibash\007' "${AI_AGENT}" 2>/dev/null || true
}

# ── DETECT script(1) (system boundary — stays in bash) ───────────────────────

SESSION_LOGGING_ENABLED=0
if command -v script &>/dev/null; then
	_script_path="$(command -v script)"
	if [[ "$_script_path" == "/usr/bin/script" || "$_script_path" == "/bin/script" ]]; then
		SESSION_LOGGING_ENABLED=1
	fi
	unset _script_path
fi

# ── EXEC: launch contained bash session ──────────────────────────────────────

cd "$GIT_ROOT" || { echo "[AIBASH] ✗ Failed to cd to $GIT_ROOT" >&2; exit 1; }

printf '\033]0;🤖 %s | aibash\007' "${AI_AGENT}" 2>/dev/null || true
echo "[aibash] agent=${AI_AGENT} session=${AI_SESSION:0:8} root=${GIT_ROOT}"

# Build bash args
_bash_args=(--noprofile --norc)
if [[ -n "${_AIBASH_COMMAND:-}" ]]; then
	_bash_args+=("-c" "$_AIBASH_COMMAND")
fi

notify_awaiting

# Choose exec mode: pipe-pane > script(1) > direct
if [[ "${_AIBASH_PIPE_PANE:-0}" == "1" ]]; then
	bash "${_bash_args[@]}" || echo "[AIBASH] ✗ pipe-pane session failed" >&2
elif [[ $SESSION_LOGGING_ENABLED -eq 1 ]]; then
	script --quiet --return --command "bash ${_bash_args[*]}" "$SESSION_LOG" \
		|| echo "[AIBASH] ✗ script(1) session failed" >&2
else
	bash "${_bash_args[@]}" || echo "[AIBASH] ✗ session failed" >&2
fi

clear_awaiting
