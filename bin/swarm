#!/usr/bin/env bash

################################################################################
# SWARM - Synchronic Work Agentic Resource Manager
# Author: Stephane Korning 2026
# Purpose: Multi-agent tmux launcher + task/workflow coordination
# Requires: bash, tmux, jq
################################################################################

set -uo pipefail

# ---------- Resolve AGENCE_ROOT ----------
source "$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/lib/env.sh"
source_if_exists "$AGENCE_LIB/ailedger.sh"
source_if_exists "$AGENCE_LIB/shell-ui.sh"

resolve_context() {
  local synthetic_dir="$AI_ROOT/synthetic"
  local link="$synthetic_dir/@"
  local default_context="l-agence.org"
  if [ -L "$link" ]; then
    local ctx
    ctx=$(readlink "$link")
    while [ -L "$synthetic_dir/$ctx" ]; do
      ctx=$(readlink "$synthetic_dir/$ctx")
    done
    echo "$ctx"
  else
    echo "$default_context"
  fi
}

resolve_agent() {
  local agent_link="$AI_ROOT/agents/@"
  local default_agent="@copilot"
  if [ -L "$agent_link" ]; then
    readlink "$agent_link"
  else
    echo "$default_agent"
  fi
}

resolve_sec_label() {
  echo "${1:-internal}"
}

# ---------- Paths ----------
context_path() {
  local type="$1"
  echo "$AI_ROOT/synthetic/$(resolve_context)/$type"
}

agent_path() {
  local type="$1"
  echo "$(context_path $type)/$(resolve_agent)"
}

sec_path() {
  local type="$1"
  local sec_label
  sec_label=$(resolve_sec_label "$2")
  echo "$(context_path $type)/$sec_label"
}

# ---------- Task Operations ----------
add_task() {
  local task_json="$1"
  local task_dir
  task_dir=$(context_path "tasks")
  mkdir -p "$task_dir"
  local id
  id=$(jq -r '.task_id' <<< "$task_json")
  echo "$task_json" > "$task_dir/$id.json"
}

list_tasks() {
  local task_dir
  task_dir=$(context_path "tasks")
  jq -s '.' "$task_dir"/*.json 2>/dev/null
}

update_task_status() {
  local task_id="$1"
  local status="$2"
  local task_file
  task_file="$(context_path "tasks")/$task_id.json"
  if [ -f "$task_file" ]; then
    jq --arg s "$status" '.status=$s' "$task_file" > "$task_file.tmp" && mv "$task_file.tmp" "$task_file"
  fi
}

# ---------- DAG / Dependency Handling ----------
resolve_dependencies() {
  local task_file="$1"
  jq -r '
    .dependencies // [] |
    map(
      if startswith("^") then {type:"hard",task:.[1:]} 
      elif startswith(";") then {type:"soft",task:.[1:]} 
      else {type:"soft",task:.} end
    )
  ' "$task_file"
}

# ---------- Knowledge Operations ----------
commit_hermetic() {
  local type="$1"
  local obj_file="$2"
  local dest
  dest=$(context_path "$type")
  mkdir -p "$dest"
  cp "$obj_file" "$dest/"
}

share_synthetic() {
  local type="$1"
  local obj_file="$2"
  local sec_label="${3:-internal}"
  local dest
  dest=$(sec_path "$type" "$sec_label")
  mkdir -p "$dest"
  cp "$obj_file" "$dest/"
}

# ---------- Job Execution ----------
run_task() {
  local task_id="$1"
  local task_file
  task_file="$(context_path "tasks")/$task_id.json"
  if [ ! -f "$task_file" ]; then echo "Task $task_id not found"; return 1; fi
  local status
  status=$(jq -r '.status' "$task_file")
  # Handle human override / pause / agent run
  case "$status" in
    "~"* | "$"* )
      echo "Human assigned task $task_id ready for execution"
      ;;
    "%"* | "&"* )
      echo "Agent assigned task $task_id executing"
      ;;
    "_"* | "#"* )
      echo "Task $task_id is paused/held, skipping execution"
      return 0
      ;;
    * )
      echo "Unknown task status $status"
      return 1
      ;;
  esac
  # simulate execution (extend for real command)
  echo "Executing task $task_id ..."
  sleep 1
  update_task_status "$task_id" "-$task_id"  # mark completed
}

# ---------- Matrix / Progress ----------
compute_progress() {
  local workflow_file="$1"
  awk -f "$AI_BIN/matrix.awk" "$workflow_file"
}

# ---------- CLI Command Parsing ----------
usage() {
  cat <<EOF
Usage: swarm <command> [args]

Tmux Commands:
  launch [agent...]          Launch tmux 1+1: ibash (human) + aibash (agent)
                             Default agent: copilot. Pass multiple for N tiles.
  attach [session]           Attach to existing swarm session
  kill [session]             Kill a swarm session
  list                       List active swarm sessions

Shell Lifecycle:
  shells                     List all agent panes with state/pid/command
  reap                       Kill completed (-) panes to free resources
  focus <agent>              Switch to an agent's pane
  signal <agent> [SIG]       Send signal to agent pane (default: INT)
  title <agent> <state>      Update an agent pane's title/state

Task Commands:
  add-task '<JSON>'          Add a task
  list-tasks                 List all tasks
  update-task <id> <status>  Update task status
  run-task <id>              Execute a task (human/agent)

Knowledge Commands:
  commit-hermetic <type> <file>
  share-synthetic <type> <file> [sec_label]
EOF
}

# ============================================================================
# TMUX 1+1 LAUNCHER
# ============================================================================

SWARM_SESSION_PREFIX="agence"

# ---------- pipe-pane helper ----------
# Wire tmux pipe-pane on an agent pane to capture output.
# Creates the session log directory + typescript file, then attaches
# a pipe-pane that appends all pane output to the file.
#
# Usage: _swarm_pipe_pane <pane-target> <agent-name>
#   e.g. _swarm_pipe_pane "agence-copilot:0.1" "copilot"
_swarm_pipe_pane() {
  local pane_target="$1"
  local agent="$2"

  # Generate session ID matching aibash convention
  local sid
  sid="bash-$(date +%Y%m%d_%H%M%S)-$$-$(openssl rand -hex 2 2>/dev/null || printf '%04x' $RANDOM)"

  local session_dir="$AI_ROOT/nexus/.aisessions"
  local typescript_file="$session_dir/${sid}.typescript"
  mkdir -p "$session_dir"

  # Start pipe-pane: -o = output only (what the pane produces), append mode
  tmux pipe-pane -o -t "$pane_target" "cat >> '${typescript_file}'"

  # Write session env into the pane so aibash can pick it up
  tmux set-environment -t "${pane_target%%.*}" "AGENCE_PIPE_PANE_SID" "$sid"
  tmux set-environment -t "${pane_target%%.*}" "AGENCE_PIPE_PANE_LOG" "$typescript_file"

  echo "[swarm] pipe-pane: ${agent} → ${typescript_file##*/}"
  ailedger_append "capture" "pipe-pane-start" "$sid" "pipe-pane ${agent} ${pane_target}" "0"
}

swarm_launch() {
  # Verify tmux is available
  if ! command -v tmux &>/dev/null; then
    echo "[swarm] ✗ tmux not found. Install: sudo apt install tmux" >&2
    return 1
  fi

  # ── ECONOMY: Reap before launch (clean completed/dead panes first) ──────
  if declare -F agence_shell_reap &>/dev/null; then
    agence_shell_reap 2>/dev/null
  fi

  # Parse agents — default to "copilot" if none given
  local -a agents=("$@")
  [[ ${#agents[@]} -eq 0 ]] && agents=("copilot")

  # ── ECONOMY: Max shell cap ──────────────────────────────────────────────
  local max_shells="${AGENCE_MAX_SHELLS:-4}"
  local current_shells=0
  current_shells=$(tmux list-panes -a -F '#{pane_id}' 2>/dev/null | wc -l) || current_shells=0
  local needed=$(( ${#agents[@]} * 2 ))  # each agent = 2 panes (human + agent)
  if (( current_shells + needed > max_shells * 2 )); then
    echo "[swarm] ⚠ Shell cap: ${current_shells} panes active, want +${needed}, cap=${max_shells} agents ($(( max_shells * 2 )) panes)" >&2
    echo "[swarm] Run 'swarm reap' or 'swarm kill <session>' to free resources" >&2
    return 1
  fi

  # ── ECONOMY: Reuse existing idle agent pane if available ────────────────
  local session_name
  if [[ ${#agents[@]} -eq 1 ]]; then
    session_name="${SWARM_SESSION_PREFIX}-${agents[0]}"
    # Check if agent already has a running session — reuse it
    if tmux has-session -t "$session_name" 2>/dev/null; then
      echo "[swarm] Session '$session_name' already running. Attaching..." >&2
      tmux attach-session -t "$session_name"
      return $?
    fi
  else
    session_name="${SWARM_SESSION_PREFIX}-multi"
  fi

  # Abort if multi-session already exists
  if [[ ${#agents[@]} -gt 1 ]] && tmux has-session -t "$session_name" 2>/dev/null; then
    echo "[swarm] Session '$session_name' already running. Use: swarm attach $session_name" >&2
    return 1
  fi

  local git_repo
  git_repo="$(git -C "$AGENCE_ROOT" rev-parse --show-toplevel 2>/dev/null || echo "$AGENCE_ROOT")"

  echo "[swarm] Launching tmux session: $session_name"
  echo "[swarm] Agents: ${agents[*]}"
  echo "[swarm] Root: $git_repo"
  echo ""

  # --- Create session with first agent's ibash (human pane, left) ---
  local first_agent="${agents[0]}"
  tmux new-session -d -s "$session_name" -x 200 -y 50 \
    -e "GIT_ROOT=$git_repo" \
    -e "AI_ROOT=$AI_ROOT" \
    -e "AI_AGENT=$first_agent" \
    -e "AI_ROLE=interactive" \
    "bash --rcfile '$AGENCE_ROOT/bin/ibash'"

  # Name the first window with state prefix
  tmux rename-window -t "$session_name:0" "[~] $first_agent"

  # Split right: aibash pane (agent pane) for first agent
  tmux split-window -h -t "$session_name:0" \
    -e "GIT_ROOT=$git_repo" \
    -e "AI_ROOT=$AI_ROOT" \
    -e "AI_AGENT=$first_agent" \
    -e "AI_ROLE=agentic" \
    -e "AGENCE_PIPE_PANE=1" \
    "bash '$AGENCE_ROOT/bin/aibash' --agent '$first_agent'"

  # Set pane titles for border display
  tmux select-pane -t "$session_name:0.0" -T "human@${first_agent}:~" 2>/dev/null || true
  tmux select-pane -t "$session_name:0.1" -T "agent@${first_agent}:~" 2>/dev/null || true

  # Wire pipe-pane capture on the agent pane (pane .1 = right)
  _swarm_pipe_pane "$session_name:0.1" "$first_agent"

  # Set left pane (ibash) as active
  tmux select-pane -t "$session_name:0.0"

  # --- Additional agents: each gets a new window with ibash|aibash split ---
  local i
  for (( i=1; i<${#agents[@]}; i++ )); do
    local agent="${agents[$i]}"
    # New window: ibash (left)
    tmux new-window -t "$session_name" -n "[~] $agent" \
      -e "GIT_ROOT=$git_repo" \
      -e "AI_ROOT=$AI_ROOT" \
      -e "AI_AGENT=$agent" \
      -e "AI_ROLE=interactive" \
      "bash --rcfile '$AGENCE_ROOT/bin/ibash'"

    # Split right: aibash (agent)
    tmux split-window -h -t "$session_name:$i" \
      -e "GIT_ROOT=$git_repo" \
      -e "AI_ROOT=$AI_ROOT" \
      -e "AI_AGENT=$agent" \
      -e "AI_ROLE=agentic" \
      -e "AGENCE_PIPE_PANE=1" \
      "bash '$AGENCE_ROOT/bin/aibash' --agent '$agent'"

    # Set pane titles
    tmux select-pane -t "$session_name:$i.0" -T "human@${agent}:~" 2>/dev/null || true
    tmux select-pane -t "$session_name:$i.1" -T "agent@${agent}:~" 2>/dev/null || true

    # Wire pipe-pane capture on agent pane
    _swarm_pipe_pane "$session_name:$i.1" "$agent"

    # Focus left pane
    tmux select-pane -t "$session_name:$i.0"
  done

  # Go back to first window
  tmux select-window -t "$session_name:0"

  # Apply agence status bar styling (colors, pane borders, titles)
  if declare -F agence_tmux_status_bar &>/dev/null; then
    agence_tmux_status_bar "$session_name"
  else
    # Fallback: basic status bar
    tmux set-option -t "$session_name" status-left "[${session_name}] "
    tmux set-option -t "$session_name" status-right "#W | %H:%M"
    tmux set-option -t "$session_name" status-style "bg=black,fg=green"
  fi

  echo "[swarm] ✓ Session '$session_name' ready (${#agents[@]} agent(s))"
  ailedger_append "launch" "swarm-launch" "" "swarm launch ${agents[*]}" "0"
  echo "[swarm] Attaching..."
  echo ""

  # Attach (interactive)
  tmux attach-session -t "$session_name"
}

swarm_attach() {
  local session_name="${1:-}"
  if [[ -z "$session_name" ]]; then
    # Try to find any agence session
    session_name=$(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep "^${SWARM_SESSION_PREFIX}" | head -1)
    if [[ -z "$session_name" ]]; then
      echo "[swarm] No active agence sessions. Use: swarm launch [agent...]" >&2
      return 1
    fi
  fi
  tmux attach-session -t "$session_name"
}

swarm_kill() {
  local session_name="${1:-}"
  if [[ -z "$session_name" ]]; then
    echo "[swarm] Usage: swarm kill <session-name>" >&2
    echo "[swarm] Active sessions:" >&2
    tmux list-sessions -F '  #{session_name}' 2>/dev/null | grep "^  ${SWARM_SESSION_PREFIX}" >&2 || echo "  (none)" >&2
    return 1
  fi

  # Stop pipe-pane on all panes before killing (flushes buffers)
  local panes
  panes=$(tmux list-panes -t "$session_name" -a -F '#{pane_id}' 2>/dev/null) || true
  for pane_id in $panes; do
    tmux pipe-pane -t "$pane_id" 2>/dev/null || true
  done

  # Finalize typescript files: append exit marker + update session metadata
  local session_dir="$AI_ROOT/nexus/.aisessions"
  local sid_var
  sid_var=$(tmux show-environment -t "$session_name" "AGENCE_PIPE_PANE_SID" 2>/dev/null | cut -d= -f2) || true
  if [[ -n "${sid_var:-}" ]]; then
    local ts_file="$session_dir/${sid_var}.typescript"
    local meta_file="$session_dir/${sid_var}.meta.json"
    if [[ -f "$ts_file" ]]; then
      printf '\n=== SESSION_END: %s ===\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" >> "$ts_file"
    fi
    if [[ -f "$meta_file" ]]; then
      # Mark session as completed in metadata (best-effort JSON update)
      local tmp_meta="${meta_file}.tmp"
      if command -v python3 &>/dev/null; then
        python3 -c "
import json, sys
with open('$meta_file') as f: m = json.load(f)
m['status'] = 'completed'
m['ended'] = '$(date -u +%Y-%m-%dT%H:%M:%SZ)'
with open('$tmp_meta', 'w') as f: json.dump(m, f, indent=2)
" 2>/dev/null && mv "$tmp_meta" "$meta_file" || rm -f "$tmp_meta"
      fi
    fi
  fi

  tmux kill-session -t "$session_name" 2>/dev/null && {
    ailedger_append "kill" "swarm-kill" "" "swarm kill $session_name" "0"
    echo "[swarm] ✓ Killed $session_name"
  } || echo "[swarm] ✗ Session not found: $session_name" >&2
}

swarm_list() {
  local sessions
  sessions=$(tmux list-sessions -F '#{session_name} (#{session_windows} windows, created #{session_created_string})' 2>/dev/null | grep "^${SWARM_SESSION_PREFIX}")
  if [[ -z "$sessions" ]]; then
    echo "[swarm] No active agence sessions"
  else
    echo "[swarm] Active sessions:"
    echo "$sessions" | sed 's/^/  /'
  fi
}

if [ $# -lt 1 ]; then
  usage
  exit 1
fi

cmd="$1"; shift
case "$cmd" in
  launch) swarm_launch "$@" ;;
  attach) swarm_attach "$@" ;;
  kill) swarm_kill "$@" ;;
  list|ls) swarm_list ;;
  # Shell lifecycle
  shells) agence_shell_list ;;
  reap) agence_shell_reap ;;
  focus) agence_shell_focus "${1:?Usage: swarm focus <agent>}" ;;
  signal) agence_shell_signal "${1:?Usage: swarm signal <agent> [SIG]}" "${2:-INT}" ;;
  title)
    _t_agent="${1:?Usage: swarm title <agent> <state>}"
    _t_state="${2:?Usage: swarm title <agent> <state>}"
    _prefix="${SWARM_SESSION_PREFIX}"
    tmux list-panes -a -F '#{session_name}:#{window_index}.#{pane_index} #{pane_title}' 2>/dev/null \
      | grep "^${_prefix}" \
      | while IFS=' ' read -r _pane _title; do
          if [[ "$_title" == *"@${_t_agent}:"* ]]; then
            agence_tmux_title "$_pane" "${AI_SESSION:-????}" "$_t_agent" "$_t_state"
            _win="${_pane%%.*}"
            tmux rename-window -t "$_win" "[${_t_state}] ${_t_agent}" 2>/dev/null || true
            echo "[swarm] Updated ${_t_agent} → state ${_t_state}"
          fi
        done
    ;;
  # Task commands
  add-task) add_task "$1" ;;
  list-tasks) list_tasks ;;
  update-task) update_task_status "$1" "$2" ;;
  run-task) run_task "$1" ;;
  commit-hermetic) commit_hermetic "$1" "$2" ;;
  share-synthetic) share_synthetic "$1" "$2" "${3:-}" ;;
  help|--help|-h) usage ;;
  *) echo "[swarm] Unknown command: $cmd" >&2; usage; exit 1 ;;
esac
