#!/usr/bin/env bash

################################################################################
# SWARM - Synchronic Work Agentic Resource Manager
# Author: Stephane Korning 2026
# Purpose: Multi-agent tmux launcher + task/workflow coordination
# Requires: bash, tmux, jq
################################################################################

set -uo pipefail

# ---------- Resolve AGENCE_ROOT ----------
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
AGENCE_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
AI_ROOT="${AI_ROOT:-$AGENCE_ROOT}"
export AGENCE_ROOT AI_ROOT
resolve_context() {
  local synthetic_dir="$AI_ROOT/synthetic"
  local link="$synthetic_dir/@"
  local default_context="l-agence.org"
  if [ -L "$link" ]; then
    local ctx
    ctx=$(readlink "$link")
    while [ -L "$synthetic_dir/$ctx" ]; do
      ctx=$(readlink "$synthetic_dir/$ctx")
    done
    echo "$ctx"
  else
    echo "$default_context"
  fi
}

resolve_agent() {
  local agent_link="$AI_ROOT/agents/@"
  local default_agent="@copilot"
  if [ -L "$agent_link" ]; then
    readlink "$agent_link"
  else
    echo "$default_agent"
  fi
}

resolve_sec_label() {
  echo "${1:-internal}"
}

# ---------- Paths ----------
context_path() {
  local type="$1"
  echo "$AI_ROOT/synthetic/$(resolve_context)/$type"
}

agent_path() {
  local type="$1"
  echo "$(context_path $type)/$(resolve_agent)"
}

sec_path() {
  local type="$1"
  local sec_label
  sec_label=$(resolve_sec_label "$2")
  echo "$(context_path $type)/$sec_label"
}

# ---------- Task Operations ----------
add_task() {
  local task_json="$1"
  local task_dir
  task_dir=$(context_path "tasks")
  mkdir -p "$task_dir"
  local id
  id=$(jq -r '.task_id' <<< "$task_json")
  echo "$task_json" > "$task_dir/$id.json"
}

list_tasks() {
  local task_dir
  task_dir=$(context_path "tasks")
  jq -s '.' "$task_dir"/*.json 2>/dev/null
}

update_task_status() {
  local task_id="$1"
  local status="$2"
  local task_file
  task_file="$(context_path "tasks")/$task_id.json"
  if [ -f "$task_file" ]; then
    jq --arg s "$status" '.status=$s' "$task_file" > "$task_file.tmp" && mv "$task_file.tmp" "$task_file"
  fi
}

# ---------- DAG / Dependency Handling ----------
resolve_dependencies() {
  local task_file="$1"
  jq -r '
    .dependencies // [] |
    map(
      if startswith("^") then {type:"hard",task:.[1:]} 
      elif startswith(";") then {type:"soft",task:.[1:]} 
      else {type:"soft",task:.} end
    )
  ' "$task_file"
}

# ---------- Knowledge Operations ----------
commit_hermetic() {
  local type="$1"
  local obj_file="$2"
  local dest
  dest=$(context_path "$type")
  mkdir -p "$dest"
  cp "$obj_file" "$dest/"
}

share_synthetic() {
  local type="$1"
  local obj_file="$2"
  local sec_label="${3:-internal}"
  local dest
  dest=$(sec_path "$type" "$sec_label")
  mkdir -p "$dest"
  cp "$obj_file" "$dest/"
}

# ---------- Job Execution ----------
run_task() {
  local task_id="$1"
  local task_file
  task_file="$(context_path "tasks")/$task_id.json"
  if [ ! -f "$task_file" ]; then echo "Task $task_id not found"; return 1; fi
  local status
  status=$(jq -r '.status' "$task_file")
  # Handle human override / pause / agent run
  case "$status" in
    "~"* | "$"* )
      echo "Human assigned task $task_id ready for execution"
      ;;
    "%"* | "&"* )
      echo "Agent assigned task $task_id executing"
      ;;
    "_"* | "#"* )
      echo "Task $task_id is paused/held, skipping execution"
      return 0
      ;;
    * )
      echo "Unknown task status $status"
      return 1
      ;;
  esac
  # simulate execution (extend for real command)
  echo "Executing task $task_id ..."
  sleep 1
  update_task_status "$task_id" "-$task_id"  # mark completed
}

# ---------- Matrix / Progress ----------
compute_progress() {
  local workflow_file="$1"
  awk -f "$AI_BIN/matrix.awk" "$workflow_file"
}

# ---------- CLI Command Parsing ----------
usage() {
  cat <<EOF
Usage: swarm <command> [args]

Tmux Commands:
  launch [agent...]          Launch tmux 1+1: ibash (human) + aibash (agent)
                             Default agent: copilot. Pass multiple for N tiles.
  attach [session]           Attach to existing swarm session
  kill [session]             Kill a swarm session
  list                       List active swarm sessions

Task Commands:
  add-task '<JSON>'          Add a task
  list-tasks                 List all tasks
  update-task <id> <status>  Update task status
  run-task <id>              Execute a task (human/agent)

Knowledge Commands:
  commit-hermetic <type> <file>
  share-synthetic <type> <file> [sec_label]
EOF
}

# ============================================================================
# TMUX 1+1 LAUNCHER
# ============================================================================

SWARM_SESSION_PREFIX="agence"

swarm_launch() {
  # Verify tmux is available
  if ! command -v tmux &>/dev/null; then
    echo "[swarm] ✗ tmux not found. Install: sudo apt install tmux" >&2
    return 1
  fi

  # Parse agents — default to "copilot" if none given
  local -a agents=("$@")
  [[ ${#agents[@]} -eq 0 ]] && agents=("copilot")

  # Session name: agence-<first_agent> or agence-multi if >1
  local session_name
  if [[ ${#agents[@]} -eq 1 ]]; then
    session_name="${SWARM_SESSION_PREFIX}-${agents[0]}"
  else
    session_name="${SWARM_SESSION_PREFIX}-multi"
  fi

  # Abort if session already exists
  if tmux has-session -t "$session_name" 2>/dev/null; then
    echo "[swarm] Session '$session_name' already running. Use: swarm attach $session_name" >&2
    return 1
  fi

  local git_repo
  git_repo="$(git -C "$AGENCE_ROOT" rev-parse --show-toplevel 2>/dev/null || echo "$AGENCE_ROOT")"

  echo "[swarm] Launching tmux session: $session_name"
  echo "[swarm] Agents: ${agents[*]}"
  echo "[swarm] Root: $git_repo"
  echo ""

  # --- Create session with first agent's ibash (human pane, left) ---
  local first_agent="${agents[0]}"
  tmux new-session -d -s "$session_name" -x 200 -y 50 \
    -e "GIT_ROOT=$git_repo" \
    -e "AI_ROOT=$AI_ROOT" \
    -e "AI_AGENT=$first_agent" \
    -e "AI_ROLE=interactive" \
    "bash --rcfile '$AGENCE_ROOT/bin/ibash'"

  # Name the first window
  tmux rename-window -t "$session_name:0" "$first_agent"

  # Split right: aibash pane (agent pane) for first agent
  tmux split-window -h -t "$session_name:0" \
    -e "GIT_ROOT=$git_repo" \
    -e "AI_ROOT=$AI_ROOT" \
    -e "AI_AGENT=$first_agent" \
    -e "AI_ROLE=agentic" \
    "bash '$AGENCE_ROOT/bin/aibash' --agent '$first_agent'"

  # Set left pane (ibash) as active
  tmux select-pane -t "$session_name:0.0"

  # --- Additional agents: each gets a new window with ibash|aibash split ---
  local i
  for (( i=1; i<${#agents[@]}; i++ )); do
    local agent="${agents[$i]}"
    # New window: ibash (left)
    tmux new-window -t "$session_name" -n "$agent" \
      -e "GIT_ROOT=$git_repo" \
      -e "AI_ROOT=$AI_ROOT" \
      -e "AI_AGENT=$agent" \
      -e "AI_ROLE=interactive" \
      "bash --rcfile '$AGENCE_ROOT/bin/ibash'"

    # Split right: aibash (agent)
    tmux split-window -h -t "$session_name:$i" \
      -e "GIT_ROOT=$git_repo" \
      -e "AI_ROOT=$AI_ROOT" \
      -e "AI_AGENT=$agent" \
      -e "AI_ROLE=agentic" \
      "bash '$AGENCE_ROOT/bin/aibash' --agent '$agent'"

    # Focus left pane
    tmux select-pane -t "$session_name:$i.0"
  done

  # Go back to first window
  tmux select-window -t "$session_name:0"

  # Status bar: show session name + agent
  tmux set-option -t "$session_name" status-left "[${session_name}] "
  tmux set-option -t "$session_name" status-right "#W | %H:%M"
  tmux set-option -t "$session_name" status-style "bg=black,fg=green"

  echo "[swarm] ✓ Session '$session_name' ready (${#agents[@]} agent(s))"
  echo "[swarm] Attaching..."
  echo ""

  # Attach (interactive)
  tmux attach-session -t "$session_name"
}

swarm_attach() {
  local session_name="${1:-}"
  if [[ -z "$session_name" ]]; then
    # Try to find any agence session
    session_name=$(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep "^${SWARM_SESSION_PREFIX}" | head -1)
    if [[ -z "$session_name" ]]; then
      echo "[swarm] No active agence sessions. Use: swarm launch [agent...]" >&2
      return 1
    fi
  fi
  tmux attach-session -t "$session_name"
}

swarm_kill() {
  local session_name="${1:-}"
  if [[ -z "$session_name" ]]; then
    echo "[swarm] Usage: swarm kill <session-name>" >&2
    echo "[swarm] Active sessions:" >&2
    tmux list-sessions -F '  #{session_name}' 2>/dev/null | grep "^  ${SWARM_SESSION_PREFIX}" >&2 || echo "  (none)" >&2
    return 1
  fi
  tmux kill-session -t "$session_name" 2>/dev/null && echo "[swarm] ✓ Killed $session_name" || echo "[swarm] ✗ Session not found: $session_name" >&2
}

swarm_list() {
  local sessions
  sessions=$(tmux list-sessions -F '#{session_name} (#{session_windows} windows, created #{session_created_string})' 2>/dev/null | grep "^${SWARM_SESSION_PREFIX}")
  if [[ -z "$sessions" ]]; then
    echo "[swarm] No active agence sessions"
  else
    echo "[swarm] Active sessions:"
    echo "$sessions" | sed 's/^/  /'
  fi
}

if [ $# -lt 1 ]; then
  usage
  exit 1
fi

cmd="$1"; shift
case "$cmd" in
  launch) swarm_launch "$@" ;;
  attach) swarm_attach "$@" ;;
  kill) swarm_kill "$@" ;;
  list|ls) swarm_list ;;
  add-task) add_task "$1" ;;
  list-tasks) list_tasks ;;
  update-task) update_task_status "$1" "$2" ;;
  run-task) run_task "$1" ;;
  commit-hermetic) commit_hermetic "$1" "$2" ;;
  share-synthetic) share_synthetic "$1" "$2" "${3:-}" ;;
  help|--help|-h) usage ;;
  *) echo "[swarm] Unknown command: $cmd" >&2; usage; exit 1 ;;
esac
