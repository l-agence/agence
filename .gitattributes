# Agence .gitattributes — enforce LF for all text files, especially scripts
# Unix-first policy: all scripts and text files use LF

# Default: auto-detect text, normalize to LF on commit
* text=auto eol=lf

# Shell scripts — always LF
*.sh        text eol=lf
*.bash      text eol=lf
bin/*       text eol=lf
lib/*.sh    text eol=lf

# TypeScript / JavaScript
*.ts        text eol=lf
*.js        text eol=lf
*.json      text eol=lf

# Markdown / YAML / TOML
*.md        text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf

# Config / env files
*.env       text eol=lf
.envrc      text eol=lf
.agencerc   text eol=lf
*.cfg       text eol=lf
*.conf      text eol=lf
*.ini       text eol=lf

# Windows batch files — keep CRLF (bat/cmd require it)
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Binary files — no line ending conversion
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.zip       binary
*.tar.gz    binary
*.tgz       binary

# TypeScript files in lib/
lib/*.ts    text eol=lf
