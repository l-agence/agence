{
  "$schema": "../AIPOLICY.schema.json",
  "version": 1,
  "description": "Agent registry: structured config for routing, launching, and model resolution. Source of truth for bin/agence dispatch.",

  "models": {
    "opus":    "claude-opus-4-5",
    "sonnet":  "claude-sonnet-4-5",
    "haiku":   "claude-haiku-3-5",
    "gpt4":    "gpt-4-turbo",
    "gpt4o":   "gpt-4o",
    "mini":    "gpt-4o-mini",
    "gemini":  "gemini-2-pro",
    "flash":   "gemini-2-flash",
    "o1":      "o1-pro",
    "qwen":    "qwen-2.5-coder",
    "deepseek":"deepseek-coder-v2",
    "llama":   "llama-3.1-70b"
  },

  "pricing": {
    "claude-opus-4-5":    { "input_per_1m": 15.00, "output_per_1m": 75.00 },
    "claude-sonnet-4-5":  { "input_per_1m": 3.00,  "output_per_1m": 15.00 },
    "claude-haiku-3-5":   { "input_per_1m": 0.80,  "output_per_1m": 4.00 },
    "gpt-4o":             { "input_per_1m": 2.50,  "output_per_1m": 10.00 },
    "gpt-4o-mini":        { "input_per_1m": 0.15,  "output_per_1m": 0.60 },
    "gpt-4-turbo":        { "input_per_1m": 10.00, "output_per_1m": 30.00 },
    "o1-pro":             { "input_per_1m": 15.00, "output_per_1m": 60.00 },
    "gemini-2-pro":       { "input_per_1m": 1.25,  "output_per_1m": 5.00 },
    "gemini-2-flash":     { "input_per_1m": 0.10,  "output_per_1m": 0.40 },
    "deepseek-coder-v2":  { "input_per_1m": 0.14,  "output_per_1m": 0.28 },
    "qwen-2.5-coder":    { "input_per_1m": 0.30,  "output_per_1m": 0.60 },
    "llama-3.1-70b":     { "input_per_1m": 0.80,  "output_per_1m": 0.80 }
  },

  "agents": {
    "aider": {
      "type": "tool",
      "binary": "aider",
      "install": "pip install aider-chat",
      "default_model": "sonnet",
      "launch_flags": "--no-auto-commits",
      "model_flag": "--model",
      "description": "Offline code editor — git patches"
    },
    "claude": {
      "type": "tool",
      "binary": "claude",
      "install": "npm install -g @anthropic-ai/claude-code",
      "default_model": "sonnet",
      "launch_flags": "",
      "model_flag": "--model",
      "description": "Claude Code CLI — agentic assistant"
    },
    "pilot": {
      "type": "tool",
      "binary": ["copilot", "gh copilot"],
      "install": "gh extension install github/gh-copilot",
      "default_model": null,
      "launch_flags": "",
      "model_flag": null,
      "fallback_cmd": "gh copilot suggest",
      "description": "GitHub Copilot CLI"
    },
    "aish": {
      "type": "tool",
      "binary": "aish",
      "install": "winget install Microsoft.AIShell",
      "default_model": null,
      "launch_flags": "",
      "model_flag": null,
      "description": "Microsoft AI Shell"
    },
    "ralph": {
      "type": "loop",
      "binary": "claude",
      "provider": "anthropic",
      "default_model": "sonnet",
      "tier": "T1",
      "skills": ["test", "review", "precommit", "break", "build", "feature", "document"],
      "backpressure": "bun test",
      "max_iterations": 10,
      "description": "Ralph Wiggum autonomous iteration loop with Principal Skinner backpressure harness"
    },
    "sonya": {
      "type": "persona",
      "provider": "anthropic",
      "default_model": "sonnet",
      "tier": "T1",
      "skills": ["design", "solve", "refactor", "analyse", "scope"],
      "description": "Full-stack engineer"
    },
    "claudia": {
      "type": "persona",
      "provider": "anthropic",
      "default_model": "opus",
      "tier": "T4",
      "skills": ["design", "review", "analyse", "solve", "spec"],
      "description": "Principal SRE/Architect"
    },
    "chad": {
      "type": "persona",
      "provider": "openai",
      "default_model": "gpt4o",
      "tier": "T2",
      "skills": ["scope", "spec", "split", "pattern", "build"],
      "description": "DevOps/CloudOps specialist"
    },
    "aiko": {
      "type": "persona",
      "provider": "anthropic",
      "default_model": "haiku",
      "tier": "T1",
      "skills": ["design", "build", "scope"],
      "description": "Cloud architect/platform engineer"
    },
    "linus": {
      "type": "persona",
      "provider": "anthropic",
      "default_model": "sonnet",
      "tier": "T3",
      "skills": ["review", "simplify", "refactor", "precommit"],
      "description": "Harsh code reviewer — Torvalds-inspired"
    },
    "feynman": {
      "type": "persona",
      "provider": "anthropic",
      "default_model": "sonnet",
      "tier": "T2",
      "skills": ["document", "analyse", "grasp", "glimpse"],
      "description": "Explainer — Feynman-inspired teaching"
    },
    "aleph": {
      "type": "persona",
      "provider": "anthropic",
      "default_model": "sonnet",
      "tier": "T3",
      "skills": ["hack", "break", "recon"],
      "description": "Red team / security analyst"
    },
    "copilot": {
      "type": "persona",
      "provider": "copilot",
      "default_model": null,
      "tier": "T2",
      "skills": ["fix", "build", "feature", "refactor", "test"],
      "description": "GitHub Copilot chat agent"
    },
    "haiku": {
      "type": "persona",
      "provider": "anthropic",
      "default_model": "haiku",
      "tier": "T0",
      "skills": ["fix", "split", "build", "break", "glimpse"],
      "description": "Fast/cheap Claude Haiku"
    },
    "azure": {
      "type": "tool",
      "binary": "az",
      "install": "curl -sL https://aka.ms/InstallAzureCLIDeb | sudo bash",
      "default_model": null,
      "launch_flags": "",
      "model_flag": null,
      "tier": "T3",
      "description": "Azure DevOps CLI — pipelines, repos, boards"
    },
    "devops": {
      "type": "tool",
      "binary": "gh",
      "install": "gh extension install github/gh-actions",
      "default_model": null,
      "launch_flags": "",
      "model_flag": null,
      "tier": "T2",
      "description": "GitHub DevOps — actions, releases, deployments"
    },
    "peers": {
      "type": "ensemble",
      "providers": ["anthropic", "openai", "gemini"],
      "tier": "T4",
      "flavors": {
        "code":  ["opus", "gpt4", "gemini"],
        "light": ["haiku", "mini", "flash"],
        "heavy": ["opus", "gpt4", "o1"]
      },
      "default_flavor": "code",
      "tangents": 3,
      "description": "3-tangent sequent — MIT-style weighted consensus (arXiv:2406.12708)"
    },
    "pair": {
      "type": "ensemble",
      "providers": ["anthropic", "openai"],
      "tier": "T3",
      "flavors": {
        "code":  ["sonnet", "gpt4o"],
        "light": ["haiku", "mini"],
        "heavy": ["opus", "gpt4"]
      },
      "default_flavor": "code",
      "tangents": 2,
      "description": "2-tangent sequent — lightweight consensus pair"
    }
  }
}
