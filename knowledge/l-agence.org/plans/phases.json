      "objectives": [
        "Implement task scheduling + collision avoidance",
        "Build execution bridge (scope validation, max_steps)",
        "Gate distributed wisdom memory (DWM)"
      ],
      "orchestrator_components": [
        "Task queue + idle agent scheduling",
        "Collision avoidance (no scope overlap)",
        "Execution bridge (validates, enforces limits)",
        "DWM approval gate (human reviews lessons)"
      ]
    },
    {
      "id": 5,
      "version": "v0.3.2+",
      "name": "Skupper Multi-Cloud Distribution",
      "status": "spec-only",
      "duration_weeks": "TBD",
      "owner": "Sonnet + DevOps",
      "objectives": [
        "Distribute swarm across clouds",
        "Maintain single orchestrator + approval authority",
        "Reuse agent logic unchanged"
      ],
      "principle": "Skupper is just distribution, architecture stays the same"
    }
  ],
  "architectural_constraints": [
    "Paths: realpath() validation only, NO auto-healing",
    "Routing: @ suffix-based (task@agent, task@user)",
    "Symbols: Hierarchical (agent-level active, swarm reserved)",
    "Container: WSL-Ubuntu + Docker (pure POSIX)",
    "State: Matrix math (no database, just Git)",
    "Scopes: HERMETIC/NEXUS/SYNTHETIC/ORGANIC (isolation enforced)"
  ],
  "handoff_points": {
