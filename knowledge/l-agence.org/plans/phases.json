    {
      "id": 2,
      "version": "v0.2.4",
      "name": "Docker Foundations & Matrix Math",
      "status": "queued",
      "duration_weeks": "3-4",
      "owner": "Haiku (lead) + Sonnet (reasoning)",
      "objectives": [
        "Containerize agents (WSL-Ubuntu + Docker)",
        "Implement matrix-based priority routing",
        "Establish Git-native state management"
      ],
      "parallel_streams": [
        {
          "stream": "Docker",
          "tasks": ["Dockerfile", "Session metadata", "/run/secrets injection", "aibash/aishell adapters"]
        },
        {
          "stream": "Matrix Math",
          "tasks": ["Complexity eval", "Priority calculation", "Agent routing table", "Git merge strategy", "Cost tracking"]
        }
      ],
      "key_decisions": [
        "Complexity = auto-computed (no explicit cost tier)",
        "Git = coordination layer (no central DB)",
        "Merge strategy = deterministic (priority-based winner)"
      ]
    },
    {
      "id": 3,
      "version": "v0.3.0",
      "name": "VSCode Tiles & Real-Time Job Control",
      "status": "queued",
      "duration_weeks": "3-4",
      "owner": "Sonnet",
      "objectives": [
        "Implement 2-column tile layout",
        "Enable POSIX job control as coordination",
        "Real-time observability + human control"
      ],
      "tile_model": {
        "left": "docker exec -it (human console, full authority)",
        "right": "aibash/aishell (agent execution, observable)"
      },
      "job_control": [
        "Ctrl+K → SIGKILL aibash",
        "Ctrl+Z → SIGSTOP aibash",
        "%jobs → show all running tasks"
      ]
    },
    {
      "id": 4,
      "version": "v0.3.1",
      "name": "Multi-Agent Orchestrator & DWM Gating",
      "status": "queued",
      "duration_weeks": "4+",
