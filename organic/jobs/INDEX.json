{
    "version": "0.4.0",
    "type": "job-registry",
    "description": "Per-job detail records. Each job is an agent execution unit linked to a task.",
    "schema": {
        "id": "string",
        "task": "string \u2014 linked task ID",
        "agent": "string \u2014 assigned agent (@ralph, etc.)",
        "status": "string \u2014 assigned|started|in-progress|complete|failed|abandoned",
        "started": "ISO 8601|null",
        "completed": "ISO 8601|null",
        "output": "string|null \u2014 result summary"
    },
    "entries": []
}
