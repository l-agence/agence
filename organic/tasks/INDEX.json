{
    "version": "0.4.0",
    "type": "task-registry",
    "description": "Per-task detail records. Each task ID in organic/tasks.json may have a corresponding file here.",
    "schema": {
        "id": "string",
        "title": "string",
        "detail": "string",
        "state": "string",
        "priority": "int 1-5",
        "stars": "int 0+",
        "heat": "float 0.0-1.0",
        "agent": "string|null",
        "project": "string",
        "workflow": "string|null",
        "created": "ISO 8601",
        "updated": "ISO 8601"
    },
    "entries": []
}
